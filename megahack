local function updateAllTextColors()
    clearRgbConnections()
    for _, obj in pairs(mainFrame:GetDescendants()) do
        if obj:IsA("TextButton") or obj:IsA("TextLabel") then
            if settings.rgbAccent then
                local connection
                connection = RunService.Heartbeat:Connect(function(t)
                    if not obj:IsDescendantOf(mainFrame) then
                        connection:Disconnect()
                        return
                    end
                    local hue = (tick() % 5) / 5
                    obj.TextColor3 = Color3.fromHSV(hue, 1, 1)
                end)
                table.insert(rgbConnections, connection)
            else
                obj.TextColor3 = settings.colors.textColor
                obj.TextTransparency = obj.Name == "Description" and 0.3 or obj.Name == "GameName" and 0.3 or obj.Name == "MegahackLabel" and 0.2 or 0.2
