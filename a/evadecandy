-- Remotes
local evChar = ReplicatedStorage:WaitForChild("Events"):FindFirstChild("Character")
local evSpeed = evChar and evChar:FindFirstChild("SpeedBoost")
local evMove = evChar and evChar:FindFirstChild("MoveSpeed")
local evInter = evChar and evChar:FindFirstChild("Interact")
local evPlayer = ReplicatedStorage:WaitForChild("Events"):FindFirstChild("Player")
local evMode = evPlayer and evPlayer:FindFirstChild("ChangePlayerMode")

local platform = nil
local platformCF = nil
local farmThread = nil
local originalPosition = nil -- Store original position for bot height adjustment
local lastBotDistance = math.huge

-- ==================== NEW: Camera Zoom Function ====================
local function setCameraZoom(zoomValue)
    local clampedZoom = math.clamp(zoomValue, 1, 1000)
    CFG.CameraZoom = clampedZoom
    pcall(function()
        if LocalPlayer.CameraMaxZoomDistance then
            LocalPlayer.CameraMaxZoomDistance = clampedZoom
        end
        Camera.FieldOfView = 70 -- Reset FOV
        if LocalPlayer.CameraMinZoomDistance then
            LocalPlayer.CameraMinZoomDistance = 1
        end
    end)
end

-- ==================== NEW: Full Bright Function ====================
local function setFullBright(enabled)
    CFG.FullBright = enabled
    if enabled then
        Lighting.Brightness = 2
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 100000
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
        Lighting.Outlines = false
        Lighting.ClockTime = 14
        Lighting.TimeOfDay = "14:00:00"
    else
        Lighting.Brightness = 1
        Lighting.GlobalShadows = true
        Lighting.FogEnd = 5000
        Lighting.OutdoorAmbient = Color3.fromRGB(127, 127, 127)
        Lighting.Outlines = true
    end
end

-- ==================== NEW: Speed Function ====================
local function setSpeed(speedMultiplier)
    CFG.SpeedMultiplier = speedMultiplier
    if STATE.speed then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = CFG.WalkSpeed * speedMultiplier
        end
        if evMove then
            evMove:FireServer(CFG.WalkSpeed * speedMultiplier)
        end
    end
end

-- ==================== ESP v2 ====================
local espObjects = {}
local espTracked = {}

local function cleanESP(key)
    if espObjects[key] then
        for _, o in ipairs(espObjects[key]) do
            pcall(function() o:Destroy() end)
        end
        espObjects[key] = nil
    end
end

local function makeBox(adornee, color)
    local box = Instance.new("BoxHandleAdornment")
    box.Adornee = adornee
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Size = adornee.Size + Vector3.new(0.1, 0.1, 0.1)
    box.Color3 = color
    box.Transparency = 0.5
    box.Parent = workspace
    return box
end

local function makeBillboard(adornee, color)
    local bb = Instance.new("BillboardGui")
    bb.Name = "NESP"
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 110, 0, 36)
    bb.StudsOffset = Vector3.new(0, 3.2, 0)
    bb.Adornee = adornee
    bb.Parent = adornee
    
    local lbl = Instance.new("TextLabel", bb)
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.TextColor3 = color
    lbl.TextStrokeTransparency = 0
    lbl.Font = Enum.Font.GothamBold
    lbl.TextScaled = true
    lbl.Text = "..."
    return bb, lbl
end

local function distTo(pos)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        return math.floor((hrp.Position - pos).Magnitude)
    end
    return 0
end

-- Player ESP
local function setupPlayerESP(player)
    if player == LocalPlayer then return end
    local uid = "pl_" .. player.UserId
    
    local function attachToChar(char)
        cleanESP(uid)
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end
        
        local bb, lbl = makeBillboard(hrp, CFG.ESP.Color.Players)
        local box = makeBox(hrp, CFG.ESP.Color.Players)
        espObjects[uid] = {bb, box}
        
        RunService.Heartbeat:Connect(function()
            if not (STATE.esp and CFG.ESP.Players) then cleanESP(uid); return end
            if lbl and lbl.Parent then
                lbl.Text = player.DisplayName .. " " .. distTo(hrp.Position) .. "m"
            end
            if box and box.Parent then
                box.Size = hrp.Size + Vector3.new(0.1, 0.1, 0.1)
            end
        end)
    end
    
    if player.Character then task.spawn(attachToChar, player.Character) end
    player.CharacterAdded:Connect(attachToChar)
    player.CharacterRemoving:Connect(function() cleanESP(uid) end)
end

for _, p in ipairs(Players:GetPlayers()) do task.spawn(setupPlayerESP, p) end
Players.PlayerAdded:Connect(setupPlayerESP)
Players.PlayerRemoving:Connect(function(p) cleanESP("pl_" .. p.UserId) end)

-- Bot + Candy ESP
task.spawn(function()
    while true do
        task.wait(0.8)
        if not STATE.esp then continue end
        
        -- Bots
        if CFG.ESP.Bots then
            local folder = workspace:FindFirstChild("Bots") or workspace:FindFirstChild("NPCs")
            if folder then
                for _, bot in ipairs(folder:GetChildren()) do
                    local hrp = bot:FindFirstChild("HumanoidRootPart")
                    local key = "bot_" .. bot:GetDebugId()
                    if hrp and not espTracked[key] then
                        espTracked[key] = true
                        local bb, lbl = makeBillboard(hrp, CFG.ESP.Color.Bots)
                        local box = makeBox(hrp, CFG.ESP.Color.Bots)
                        RunService.Heartbeat:Connect(function()
                            if not (STATE.esp and CFG.ESP.Bots) then return end
                            if lbl and lbl.Parent then
                                lbl.Text = (bot.Name or "Bot") .. " " .. distTo(hrp.Position) .. "m"
                            end
                            if box and box.Parent then
                                box.Size = hrp.Size + Vector3.new(0.1, 0.1, 0.1)
                            end
                        end)
                    end
                end
            end
        end
        
        -- Candies
        if CFG.ESP.Candies then
            for _, d in ipairs(CFG.TicketsFolder:GetDescendants()) do
                if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then
                    local key = "candy_" .. d:GetDebugId()
                    if not espTracked[key] then
                        espTracked[key] = true
                        local name = (d.Parent and d.Parent.Name) or "Candy"
                        local bb, lbl = makeBillboard(d, CFG.ESP.Color.Candies)
                        local box = makeBox(d, CFG.ESP.Color.Candies)
                        RunService.Heartbeat:Connect(function()
                            if not (STATE.esp and CFG.ESP.Candies) then return end
                            if lbl and lbl.Parent then
                                lbl.Text = name .. " " .. distTo(d.Position) .. "m"
                            end
                            if box and box.Parent then
                                box.Size = d.Size + Vector3.new(0.1, 0.1, 0.1)
                            end
                        end)
                    end
                end
            end
        end
    end
end)

-- ==================== NEW: Auto Height Near Bot ====================
task.spawn(function()
    while true do
        task.wait(0.1)
        if not STATE.autoHeightNearBot then continue end
        
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        
        local nearestBot = nil
        local minDistance = math.huge
        
        -- Find nearest bot
        local folder = workspace:FindFirstChild("Bots") or workspace:FindFirstChild("NPCs")
        if folder then
            for _, bot in ipairs(folder:GetChildren()) do
                local botHRP = bot:FindFirstChild("HumanoidRootPart")
                if botHRP then
                    local distance = (hrp.Position - botHRP.Position).Magnitude
                    if distance < minDistance then
                        minDistance = distance
                        nearestBot = botHRP
                    end
                end
            end
        end
        
        -- Check if bot is within range (50 studs)
        if nearestBot and minDistance < 50 then
            -- Bot is nearby, store original position and teleport above bot
            if lastBotDistance >= 50 then
                originalPosition = hrp.Position
            end
            local botPosition = nearestBot.Position
            hrp.CFrame = CFrame.new(botPosition.X, botPosition.Y + CFG.BotHeightOffset, botPosition.Z)
            lastBotDistance = minDistance
        else
            -- Bot is not nearby, return to original position if stored
            if originalPosition and lastBotDistance < 50 then
                hrp.CFrame = CFrame.new(originalPosition)
                originalPosition = nil
            end
            lastBotDistance = minDistance
        end
    end
end)

-- ==================== Platform ====================
local function spawnPlatform()
    if platform and platform.Parent then platform:Destroy() end
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local pos = Vector3.new(hrp.Position.X, CFG.PlatformHeight, hrp.Position.Z)
    
    platform = Instance.new("Part")
    platform.Name = "CandyFarmPlatform"
    platform.Size = CFG.PlatformSize
    platform.Anchored = true
    platform.Transparency = 0.5
    platform.CFrame = CFrame.new(pos)
    platform.Parent = workspace
    
    platformCF = CFrame.new(pos + Vector3.new(0, 5, 0))
    hrp.CFrame = platformCF
    
    NexusUI.Notify({Title = "✦ Platform", Description = "Created at height " .. CFG.PlatformHeight, Duration = 3})
end

local function destroyPlatform()
    if platform and platform.Parent then
        platform:Destroy()
        platform = nil
        platformCF = nil
        NexusUI.Notify({Title = "✦ Platform", Description = "Destroyed", Duration = 2})
    end
end

local function goHome()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp and platformCF then
        hrp.CFrame = platformCF
    end
end

-- ==================== Jitter Farm ====================
local function jitterCollect(hrp, targetCF)
    for i = 1, CFG.JitterCount do
        local jx = (math.random() - 0.5) * 2 * CFG.JitterRange
        local jz = (math.random() - 0.5) * 2 * CFG.JitterRange
        hrp.CFrame = targetCF + Vector3.new(jx, 2 + i * 0.1, jz)
        task.wait(CFG.JitterDelay)
    end
end

local function farmLoop()
    while STATE.farm do
        local candies = {}
        for _, d in ipairs(CFG.TicketsFolder:GetDescendants()) do
            if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then
                table.insert(candies, d)
            end
        end
        
        if #candies > 0 then
            for _, candy in ipairs(candies) do
                if not STATE.farm then break end
                local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp and candy.Parent then
                    jitterCollect(hrp, candy.CFrame)
                    task.wait(CFG.CollectDelay)
                end
            end
            
            task.wait(CFG.ReturnDelay)
            
            if STATE.platform and platformCF then
                goHome()
            end
        end
        task.wait(0.4)
    end
end

-- ==================== Auto Help Downed Players ====================
task.spawn(function()
    while true do
        task.wait(0.5)
        if not STATE.autoHelpDowned then continue end
        
        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then continue end
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            local char = plr.Character
            if char and char:GetAttribute("Downed") then
                local tHRP = char:FindFirstChild("HumanoidRootPart")
                if tHRP and (myHRP.Position - tHRP.Position).Magnitude < 80 then
                    myHRP.CFrame = tHRP.CFrame * CFrame.new(3, 0, 3)
                    task.wait(0.8)
                end
            end
        end
    end
end)

-- ==================== Background Loops ====================
task.spawn(function()
    while true do
        task.wait(0.3)
        if STATE.speed then
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = CFG.WalkSpeed * CFG.SpeedMultiplier end
            if evSpeed then evSpeed:FireServer(true) end
            if evMove then evMove:FireServer(CFG.WalkSpeed * CFG.SpeedMultiplier) end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.4)
        local char = LocalPlayer.Character
        if not char then continue end
        
        if STATE.antiDown and char:GetAttribute("Downed") then
            if evMode then evMode:FireServer(true) end
        end
        
        if STATE.autoRevive then
            local myHRP = char:FindFirstChild("HumanoidRootPart")
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:GetAttribute("Downed") then
                    local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
                    if tHRP and myHRP and (myHRP.Position - tHRP.Position).Magnitude < 50 then
                        if evInter then
                            evInter:FireServer("Revive", true, p.Name)
                        end
                    end
                end
            end
        end
    end
end)

-- Character handler
local function onCharacter(char)
    char:WaitForChild("HumanoidRootPart")
    task.wait(2)
    
    if STATE.platform then spawnPlatform() end
    
    if STATE.farm then
        if farmThread then task.cancel(farmThread) end
        farmThread = task.spawn(farmLoop)
    end
    
    if STATE.hat then spawnHat() end
    if STATE.aura then spawnAura() end
end

LocalPlayer.CharacterAdded:Connect(onCharacter)
if LocalPlayer.Character then task.spawn(onCharacter, LocalPlayer.Character) end

