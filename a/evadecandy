            for _, d in ipairs(CFG.TicketsFolder:GetDescendants()) do
                if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then
                    local key  = "candy_" .. d:GetDebugId()
                    if not espTracked[key] then
                        espTracked[key] = true
                        local name = (d.Parent and d.Parent.Name) or "Candy"
                        local bb, lbl = makeBillboard(d, CFG.ESP.Color.Candies)
                        local box     = makeBox(d, CFG.ESP.Color.Candies)
