-- ── Services ──────────────────────────────────────────────────────────
local Players          = game:GetService("Players")
local ReplicatedStorage= game:GetService("ReplicatedStorage")
local LocalPlayer      = Players.LocalPlayer

-- ── Config ────────────────────────────────────────────────────────────
local CFG = {
    PlatformHeight = 1000,
    PlatformSize   = Vector3.new(18, 2, 18),
    CollectDelay   = 0.12,
    ReturnDelay    = 0.5,
    WalkSpeed      = 80,
    TicketsFolder  = game.Workspace:WaitForChild("Game")
                        :WaitForChild("Effects")
                        :WaitForChild("Tickets"),
}

local STATE = {
    platform   = true,
    farm       = true,
    speed      = true,
    antiDown   = true,
    autoRevive = true,
}

-- ── Remote Events ─────────────────────────────────────────────────────
local evChar   = ReplicatedStorage:WaitForChild("Events"):FindFirstChild("Character")
local evSpeed  = evChar and evChar:FindFirstChild("SpeedBoost")
local evMove   = evChar and evChar:FindFirstChild("MoveSpeed")
local evInter  = evChar and evChar:FindFirstChild("Interact")
local evPlayer = ReplicatedStorage:WaitForChild("Events"):FindFirstChild("Player")
local evMode   = evPlayer and evPlayer:FindFirstChild("ChangePlayerMode")

local platform   = nil
local platformCF = nil
local farmThread = nil
local collecting = false

-- ══════════════════════════════════════════
--  NAMECALL HOOK (Speed spoof)
-- ══════════════════════════════════════════
local meta = getrawmetatable(game)
setreadonly(meta, false)
local origNamecall = meta.__namecall
meta.__namecall = newcclosure(function(self, ...)
    local args   = {...}
    local method = getnamecallmethod()
    if tostring(self) == "PassCharacterInfoUnreliable" and method == "FireServer" then
        local data = args[2]
        if STATE.speed and typeof(data) == "table" and typeof(data[2]) == "Vector2int16" then
            data[1] = CFG.WalkSpeed
            args[2] = data
        end
        return origNamecall(self, unpack(args))
    end
    return origNamecall(self, ...)
end)

-- ══════════════════════════════════════════
--  ЛОГИКА
-- ══════════════════════════════════════════
local function spawnPlatform()
    if platform and platform.Parent then platform:Destroy() end
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = Vector3.new(hrp.Position.X, CFG.PlatformHeight, hrp.Position.Z)
    platform = Instance.new("Part")
    platform.Name         = "CandyFarmPlatform"
    platform.Size         = CFG.PlatformSize
    platform.Anchored     = true
    platform.Transparency = 0.5
    platform.CFrame       = CFrame.new(pos)
    platform.Parent       = workspace

    platformCF = CFrame.new(pos + Vector3.new(0, 5, 0))
    hrp.CFrame = platformCF

    NexusUI.Notify({
        Title       = "✦ Платформа",
        Description = "Платформа создана на высоте " .. CFG.PlatformHeight,
        Duration    = 3,
    })
end

local function destroyPlatform()
    if platform and platform.Parent then
        platform:Destroy()
        platform   = nil
        platformCF = nil
        NexusUI.Notify({
            Title       = "✦ Платформа",
            Description = "Платформа удалена",
            Duration    = 2,
        })
    end
end

local function goHome()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp and platformCF then hrp.CFrame = platformCF end
end

local function farmLoop()
    while STATE.farm do
        local candies = {}
        for _, d in ipairs(CFG.TicketsFolder:GetDescendants()) do
            if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then
                table.insert(candies, d)
            end
        end

        if #candies > 0 then
            collecting = true
            for _, candy in ipairs(candies) do
                if not STATE.farm then break end
                local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp and candy.Parent then
                    hrp.CFrame = candy.CFrame + Vector3.new(0, 3, 0)
                    task.wait(CFG.CollectDelay)
                end
            end
            task.wait(CFG.ReturnDelay)
            goHome()
            collecting = false
        end
        task.wait(0.5)
    end
end

-- Speed Loop
task.spawn(function()
    while true do
        task.wait(0.3)
        if STATE.speed then
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = CFG.WalkSpeed end
            if evSpeed then evSpeed:FireServer(true) end
            if evMove  then evMove:FireServer(CFG.WalkSpeed) end
        end
    end
end)

-- Anti-Down & Auto-Revive Loop
task.spawn(function()
    while true do
        task.wait(0.4)
        local char = LocalPlayer.Character
        if not char then continue end

        if STATE.antiDown and char:GetAttribute("Downed") then
            if evMode then evMode:FireServer(true) end
        end

        if STATE.autoRevive then
            local myHRP = char:FindFirstChild("HumanoidRootPart")
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:GetAttribute("Downed") then
                    local targetHRP = p.Character:FindFirstChild("HumanoidRootPart")
                    if targetHRP and myHRP and (myHRP.Position - targetHRP.Position).Magnitude < 50 then
                        if evInter then evInter:FireServer("Revive", true, p.Name) end
                    end
                end
            end
        end
    end
end)

local function onCharacter(char)
    char:WaitForChild("HumanoidRootPart")
    task.wait(2)
    if STATE.platform then spawnPlatform() end
    if STATE.farm then
        if farmThread then task.cancel(farmThread) end
        farmThread = task.spawn(farmLoop)
    end
end

LocalPlayer.CharacterAdded:Connect(onCharacter)
if LocalPlayer.Character then task.spawn(onCharacter, LocalPlayer.Character) end

