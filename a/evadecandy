local espObjects = {}

local function removeESP(key)
    if espObjects[key] then
        for _, obj in ipairs(espObjects[key]) do
            if obj and obj.Parent then obj:Destroy() end
        end
        espObjects[key] = nil
    end
end

local function createBillboard(adornee, text, color, studOffset)
    local bb = Instance.new("BillboardGui")
    bb.Name          = "NexusESP"
    bb.AlwaysOnTop   = true
    bb.Size          = UDim2.new(0, 120, 0, 40)
    bb.StudsOffset   = studOffset or Vector3.new(0, 3, 0)
    bb.Adornee       = adornee
    bb.Parent        = adornee

    local frame = Instance.new("Frame", bb)
    frame.BackgroundTransparency = 1
    frame.Size = UDim2.new(1, 0, 1, 0)

    local label = Instance.new("TextLabel", frame)
    label.BackgroundTransparency = 1
    label.Size       = UDim2.new(1, 0, 1, 0)
    label.TextColor3 = color
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3       = Color3.new(0, 0, 0)
    label.Font       = Enum.Font.GothamBold
    label.TextScaled = true
    label.Text       = text

    return bb, label
end

local function createBox(part, color)
    local box = Instance.new("SelectionBox")
    box.Color3         = color
    box.LineThickness  = 0.05
    box.SurfaceTransparency = 1
    box.Adornee        = part
    box.Parent         = workspace
    return box
end

-- Player ESP
local function setupPlayerESP(player)
    if player == LocalPlayer then return end
    local key = "player_" .. player.UserId

    local function onChar(char)
        removeESP(key)
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local objects = {}

        local function updateLabel()
            if not STATE.esp or not CFG.ESP.Players then return end
            local dist = math.floor((LocalPlayer.Character and
                LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and
                (LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude) or 0)
            return player.DisplayName .. "\n" .. dist .. "m"
        end

        local bb, label = createBillboard(hrp, updateLabel() or player.DisplayName, CFG.ESP.Color.Players, Vector3.new(0, 3.5, 0))
        local box = createBox(hrp, CFG.ESP.Color.Players)

        table.insert(objects, bb)
        table.insert(objects, box)
        espObjects[key] = objects

        RunService.Heartbeat:Connect(function()
            if not STATE.esp or not CFG.ESP.Players then
                for _, o in ipairs(objects) do if o and o.Parent then o:Destroy() end end
                return
            end
            if label and label.Parent then
                label.Text = updateLabel() or player.DisplayName
            end
        end)
    end

    if player.Character then task.spawn(onChar, player.Character) end
    player.CharacterAdded:Connect(onChar)
end

Players.PlayerAdded:Connect(setupPlayerESP)
Players.PlayerRemoving:Connect(function(p)
    removeESP("player_" .. p.UserId)
end)
for _, p in ipairs(Players:GetPlayers()) do
    task.spawn(setupPlayerESP, p)
end

-- Bot + Candy ESP (scan workspace loop)
local espTracked = {}

task.spawn(function()
    while true do
        task.wait(1)
        if not STATE.esp then continue end

        -- Bots
        if CFG.ESP.Bots then
            local botsFolder = workspace:FindFirstChild("Bots") or workspace:FindFirstChild("NPCs")
            if botsFolder then
                for _, bot in ipairs(botsFolder:GetChildren()) do
                    local hrp = bot:FindFirstChild("HumanoidRootPart")
                    local key = "bot_" .. bot:GetDebugId()
                    if hrp and not espTracked[key] then
                        espTracked[key] = true
                        local dist = 0
                        local bb, label = createBillboard(hrp, (bot.Name or "Bot") .. "\n0m", CFG.ESP.Color.Bots, Vector3.new(0, 3, 0))
                        createBox(hrp, CFG.ESP.Color.Bots)

                        RunService.Heartbeat:Connect(function()
                            if not hrp or not hrp.Parent then return end
                            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            if myHRP then
                                dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
                            end
                            if label and label.Parent then
                                label.Text = (bot.Name or "Bot") .. "\n" .. dist .. "m"
                            end
                        end)
                    end
                end
            end
        end

        -- Candies / Tickets
        if CFG.ESP.Candies then
            for _, d in ipairs(CFG.TicketsFolder:GetDescendants()) do
                if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then
                    local key = "candy_" .. d:GetDebugId()
                    if not espTracked[key] then
                        espTracked[key] = true
                        local parent = d.Parent
                        local name = (parent and parent.Name) or "Candy"
                        local bb, label = createBillboard(d, name .. "\n0m", CFG.ESP.Color.Candies, Vector3.new(0, 2, 0))
                        createBox(d, CFG.ESP.Color.Candies)

                        RunService.Heartbeat:Connect(function()
                            if not d or not d.Parent then return end
                            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            local dist = 0
                            if myHRP then
                                dist = math.floor((myHRP.Position - d.Position).Magnitude)
                            end
                            if label and label.Parent then
                                label.Text = name .. "\n" .. dist .. "m"
                            end
                        end)
                    end
                end
            end
        end
    end
end)

