--  PLATFORM
-- ══════════════════════════════════════════
local function spawnPlatform()
    if platform and platform.Parent then platform:Destroy() end
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local pos = Vector3.new(hrp.Position.X, CFG.PlatformHeight, hrp.Position.Z)
    platform = Instance.new("Part")
    platform.Name         = "CandyFarmPlatform"
    platform.Size         = CFG.PlatformSize
    platform.Anchored     = true
    platform.Transparency = 0.5
    platform.CFrame       = CFrame.new(pos)
    platform.Parent       = workspace
    platformCF = CFrame.new(pos + Vector3.new(0, 5, 0))
    hrp.CFrame = platformCF
    NexusUI.Notify({ Title = "✦ Platform", Description = "Создана на высоте " .. CFG.PlatformHeight, Duration = 3 })
end

local function destroyPlatform()
    if platform and platform.Parent then
        platform:Destroy(); platform = nil; platformCF = nil
        NexusUI.Notify({ Title = "✦ Platform", Description = "Удалена", Duration = 2 })
    end
end

local function goHome()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp and platformCF then hrp.CFrame = platformCF end
end

-- ══════════════════════════════════════════
--  FARM LOOP — JITTER TELEPORT
--  Телепортируемся к конфете JitterCount раз
--  с небольшими случайными смещениями,
--  чтобы сервер гарантированно засчитал.
-- ══════════════════════════════════════════
local function jitterCollect(hrp, targetCF)
    for i = 1, CFG.JitterCount do
        local jx = (math.random() - 0.5) * 2 * CFG.JitterRange
        local jz = (math.random() - 0.5) * 2 * CFG.JitterRange
        hrp.CFrame = targetCF + Vector3.new(jx, 2 + i * 0.1, jz)
        task.wait(CFG.JitterDelay)
    end
end

local function farmLoop()
    while STATE.farm do
        local candies = {}
        for _, d in ipairs(CFG.TicketsFolder:GetDescendants()) do
            if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then
                table.insert(candies, d)
            end
        end

        if #candies > 0 then
            for _, candy in ipairs(candies) do
                if not STATE.farm then break end
                local hrp = LocalPlayer.Character
                         and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp and candy.Parent then
                    jitterCollect(hrp, candy.CFrame)
                    task.wait(CFG.CollectDelay)
                end
            end
            task.wait(CFG.ReturnDelay)
            goHome()
        end
        task.wait(0.4)
    end
end

-- ── Фоновые петли ─────────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(0.3)
        if STATE.speed then
            local hum = LocalPlayer.Character
                     and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = CFG.WalkSpeed end
            if evSpeed then evSpeed:FireServer(true) end
            if evMove  then evMove:FireServer(CFG.WalkSpeed) end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.4)
        local char = LocalPlayer.Character
        if not char then continue end
        if STATE.antiDown and char:GetAttribute("Downed") then
            if evMode then evMode:FireServer(true) end
        end
        if STATE.autoRevive then
            local myHRP = char:FindFirstChild("HumanoidRootPart")
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character
                and p.Character:GetAttribute("Downed") then
                    local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
                    if tHRP and myHRP
                    and (myHRP.Position - tHRP.Position).Magnitude < 50 then
                        if evInter then evInter:FireServer("Revive", true, p.Name) end
                    end
                end
            end
        end
    end
end)

local function onCharacter(char)
    char:WaitForChild("HumanoidRootPart")
    task.wait(2)
    if STATE.platform then spawnPlatform() end
    if STATE.farm then
        if farmThread then task.cancel(farmThread) end
        farmThread = task.spawn(farmLoop)
    end
    if STATE.hat  then spawnHat()  end
    if STATE.aura then spawnAura() end
end

LocalPlayer.CharacterAdded:Connect(onCharacter)
if LocalPlayer.Character then task.spawn(onCharacter, LocalPlayer.Character) end

