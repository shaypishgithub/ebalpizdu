-- ══════════════════════════════════════════
--  ESP v2 — BoxHandleAdornment + Billboard
--  Используем BoxHandleAdornment вместо
--  SelectionBox (нет глюков с прозрачностью)
--  и простые BillboardGui для текста.
-- ══════════════════════════════════════════
local espObjects = {}   -- [key] = { adornments... }

local function cleanESP(key)
    if espObjects[key] then
        for _, o in ipairs(espObjects[key]) do
            pcall(function() o:Destroy() end)
        end
        espObjects[key] = nil
    end
end

-- Создаёт BoxHandleAdornment вокруг part
local function makeBox(adornee, color)
    local box = Instance.new("BoxHandleAdornment")
    box.Adornee       = adornee
    box.AlwaysOnTop   = true
    box.ZIndex        = 5
    box.Size          = adornee.Size + Vector3.new(0.1, 0.1, 0.1)
    box.Color3        = color
    box.Transparency  = 0.5
    box.Parent        = workspace
    return box
end

-- Создаёт BillboardGui с именем и дистанцией
local function makeBillboard(adornee, color)
    local bb = Instance.new("BillboardGui")
    bb.Name         = "NESP"
    bb.AlwaysOnTop  = true
    bb.Size         = UDim2.new(0, 110, 0, 36)
    bb.StudsOffset  = Vector3.new(0, 3.2, 0)
    bb.Adornee      = adornee
    bb.Parent       = adornee

    local lbl = Instance.new("TextLabel", bb)
    lbl.BackgroundTransparency = 1
    lbl.Size                   = UDim2.new(1, 0, 1, 0)
    lbl.TextColor3             = color
    lbl.TextStrokeTransparency = 0
    lbl.Font                   = Enum.Font.GothamBold
    lbl.TextScaled             = true
    lbl.Text                   = "..."
    return bb, lbl
end

-- Дистанция от LocalPlayer до точки
local function distTo(pos)
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        return math.floor((hrp.Position - pos).Magnitude)
    end
    return 0
end

-- ── Player ESP ────────────────────────────────────────────
local function setupPlayerESP(player)
    if player == LocalPlayer then return end
    local uid = "pl_" .. player.UserId

    local function attachToChar(char)
        cleanESP(uid)
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local bb, lbl = makeBillboard(hrp, CFG.ESP.Color.Players)
        local box     = makeBox(hrp, CFG.ESP.Color.Players)

        espObjects[uid] = { bb, box }

        RunService.Heartbeat:Connect(function()
            if not (STATE.esp and CFG.ESP.Players) then
                cleanESP(uid); return
            end
            if lbl and lbl.Parent then
                lbl.Text = player.DisplayName .. "  " .. distTo(hrp.Position) .. "m"
            end
            if box and box.Parent then
                box.Size = hrp.Size + Vector3.new(0.1, 0.1, 0.1)
            end
        end)
    end

    if player.Character then task.spawn(attachToChar, player.Character) end
    player.CharacterAdded:Connect(attachToChar)
    player.CharacterRemoving:Connect(function() cleanESP(uid) end)
end

Players.PlayerAdded:Connect(setupPlayerESP)
Players.PlayerRemoving:Connect(function(p) cleanESP("pl_" .. p.UserId) end)
for _, p in ipairs(Players:GetPlayers()) do task.spawn(setupPlayerESP, p) end

-- ── Bot + Candy ESP (периодический скан) ─────────────────
local espTracked = {}

task.spawn(function()
    while true do
        task.wait(0.8)
        if not STATE.esp then continue end

        -- Боты
        if CFG.ESP.Bots then
            local folder = workspace:FindFirstChild("Bots")
