--  CONICAL HAT
-- ══════════════════════════════════════════
local hatPart = nil

local function spawnHat()
    local char = LocalPlayer.Character
    local head = char and char:FindFirstChild("Head")
    if not head then return end
    if hatPart and hatPart.Parent then hatPart:Destroy() end

    local cone = Instance.new("Part")
    cone.Name       = "NexusHat"
    cone.Size       = Vector3.new(1.5, 2.5, 1.5)
    cone.Anchored   = false
    cone.CanCollide = false
    cone.CastShadow = false
    cone.Color      = Color3.fromRGB(180, 30, 200)
    cone.Material   = Enum.Material.SmoothPlastic
    cone.Parent     = char

    local mesh = Instance.new("SpecialMesh", cone)
    mesh.MeshType = Enum.MeshType.FileMesh
    mesh.MeshId   = "rbxassetid://1033714"
    mesh.Scale    = Vector3.new(1.2, 2.0, 1.2)

    local weld = Instance.new("WeldConstraint")
    weld.Part0  = head
    weld.Part1  = cone
    weld.Parent = cone
    cone.CFrame = head.CFrame * CFrame.new(0, 1.6, 0)
    hatPart = cone
end

local function removeHat()
    if hatPart and hatPart.Parent then hatPart:Destroy(); hatPart = nil end
end

-- ══════════════════════════════════════════
--  AURA
-- ══════════════════════════════════════════
local auraParts = {}
local AURA_COLORS = {
    Black = Color3.fromRGB(10, 10, 10),
    Gray  = Color3.fromRGB(120, 120, 120),
    White = Color3.fromRGB(240, 240, 240),
}

local function spawnAura()
    for _, p in ipairs(auraParts) do pcall(function() p:Destroy() end) end
    auraParts = {}
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local col = AURA_COLORS[CFG.Aura.Color] or AURA_COLORS.Black

    for i = 1, 3 do
        local ring = Instance.new("Part")
        ring.Name        = "NexusAura"
        ring.Anchored    = false
        ring.CanCollide  = false
        ring.CastShadow  = false
        ring.Size        = Vector3.new(4 + i * 0.6, 0.15, 4 + i * 0.6)
        ring.Color       = col
        ring.Material    = Enum.Material.Neon
        ring.Transparency= 0.3 + i * 0.15
        ring.Parent      = char

        local mesh = Instance.new("SpecialMesh", ring)
        mesh.MeshType = Enum.MeshType.FileMesh
        mesh.MeshId   = "rbxassetid://3270017"
        mesh.Scale    = Vector3.new(1, 0.3, 1)

        local weld = Instance.new("WeldConstraint")
        weld.Part0  = hrp
        weld.Part1  = ring
        weld.Parent = ring
        ring.CFrame = hrp.CFrame * CFrame.new(0, -1 + i * 0.4, 0)
        table.insert(auraParts, ring)
    end

    local angle = 0
    RunService.Heartbeat:Connect(function(dt)
        if not STATE.aura then return end
        angle = angle + dt * 90
        for idx, p in ipairs(auraParts) do
            if p and p.Parent and hrp and hrp.Parent then
                p.CFrame = hrp.CFrame
                    * CFrame.new(0, -0.8 + idx * 0.5, 0)
                    * CFrame.Angles(0, math.rad(angle * (idx % 2 == 0 and -1 or 1)), 0)
            end
        end
    end)
end

local function removeAura()
    for _, p in ipairs(auraParts) do pcall(function() p:Destroy() end) end
    auraParts = {}
end

-- ══════════════════════════════════════════
--  NAMECALL HOOK (SpeedHack)
-- ══════════════════════════════════════════
local meta = getrawmetatable(game)
setreadonly(meta, false)
local origNC = meta.__namecall
meta.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    if tostring(self) == "PassCharacterInfoUnreliable" and method == "FireServer" then
        local data = args[2]
        if STATE.speed and typeof(data) == "table" and typeof(data[2]) == "Vector2int16" then
            data[1] = CFG.WalkSpeed
            args[2] = data
        end
        return origNC(self, unpack(args))
    end
    return origNC(self, ...)
end)

