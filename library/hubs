			lbl.Position = UDim2.new(0, 14, 0, IsMobile and 4 or 6)
			lbl.Text = sName
			lbl.TextColor3 = Theme.Text
			lbl.TextSize = IsMobile and 11 or 12
			lbl.FontFace = FONT_MED
			lbl.TextXAlignment = Enum.TextXAlignment.Left
			lbl.TextTruncate = Enum.TextTruncate.AtEnd
			lbl.Parent = f

			local vlbl = Instance.new("TextLabel")
			vlbl.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
			vlbl.BackgroundTransparency = 0.3
			vlbl.Size = UDim2.new(0, IsMobile and 46 or 55, 0, IsMobile and 20 or 22)
			vlbl.Position = UDim2.new(1, IsMobile and -54 or -65, 0, IsMobile and 5 or 8)
			vlbl.Text = tostring(math.floor(val))
			vlbl.TextColor3 = Color3.fromRGB(200, 200, 200)
			vlbl.TextSize = IsMobile and 10 or 11
			vlbl.FontFace = FONT_BOLD
			vlbl.Parent = f
			corner(vlbl, 5)

			local track = Instance.new("Frame")
			track.BackgroundColor3 = Theme.SliderTrack
			track.Size = UDim2.new(1, -28, 0, 6)
			track.Position = UDim2.new(0, 14, 1, IsMobile and -16 or -18)
			track.Parent = f
			corner(track, 3)

			local pctFill = (val - mn) / (mx - mn)

			local fill = Instance.new("Frame")
			fill.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
			fill.Size = UDim2.new(pctFill, 0, 1, 0)
			fill.BorderSizePixel = 0
			fill.Parent = track
			corner(fill, 3)
			gradient(fill, 0)

			local knb = Instance.new("Frame")
			knb.BackgroundColor3 = Color3.new(1, 1, 1)
			knb.Size = UDim2.new(0, 16, 0, 16)
			knb.Position = UDim2.new(pctFill, 0, 0.5, 0)
			knb.AnchorPoint = Vector2.new(0.5, 0.5)
			knb.ZIndex = 5
			knb.Parent = track
			corner(knb, 8)

			local dragging = false

			local function updSlider(ix)
				local ax = track.AbsolutePosition.X
				local aw = track.AbsoluteSize.X
				local r = math.clamp((ix - ax) / aw, 0, 1)
				val = math.floor(mn + (mx - mn) * r)
				local np = (val - mn) / (mx - mn)
				tween(fill, {Size = UDim2.new(np, 0, 1, 0)}, 0.06, Enum.EasingStyle.Quad)
				tween(knb,  {Position = UDim2.new(np, 0, 0.5, 0)}, 0.06, Enum.EasingStyle.Quad)
				vlbl.Text = tostring(val)
				if cb then pcall(cb, val) end
			end

			track.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true; updSlider(i.Position.X)
				end
			end)
			knb.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true
				end
			end)
			UserInputService.InputChanged:Connect(function(i)
				if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
				or i.UserInputType == Enum.UserInputType.Touch) then
					updSlider(i.Position.X)
				end
			end)
			UserInputService.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			f.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseMovement then
					tween(f, {BackgroundColor3 = Theme.CardHover}, 0.15)
				end
			end)
			f.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseMovement then
					tween(f, {BackgroundColor3 = Theme.CardBG}, 0.15)
				end
			end)

			return {
				Frame = f,
				Set = function(_, v)
					val = math.clamp(v, mn, mx)
					local p = (val - mn) / (mx - mn)
					tween(fill, {Size = UDim2.new(p, 0, 1, 0)}, 0.2)
					tween(knb,  {Position = UDim2.new(p, 0, 0.5, 0)}, 0.2)
					vlbl.Text = tostring(val)
				end,
				Get = function() return val end,
			}
		end

