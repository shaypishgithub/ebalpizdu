		sc.ScrollBarImageColor3      = T.TextMuted
		sc.ScrollBarImageTransparency= 0.4
		sc.CanvasSize                = UDim2.new(0, 0, 0, 0)
		sc.AutomaticCanvasSize       = Enum.AutomaticSize.Y
