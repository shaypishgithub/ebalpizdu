		-- ─── CreateSlider ─────────────────────
		function T:CreateSlider(sName, mn, mx, def, cb)
			T.ElCnt = T.ElCnt + 1
			mn = mn or 0; mx = mx or 100
			def = math.clamp(def or mn, mn, mx)
			local val = def

			local f = Instance.new("Frame")
			f.BackgroundColor3 = Theme.CardBG
			f.Size = UDim2.new(1, 0, 0, IsMobile and 58 or 64)
