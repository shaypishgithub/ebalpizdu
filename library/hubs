-- ═══════════════════════════════════════════
function Library.CreateWindow(windowName)
	local W = {}
	W.Tabs      = {}
	W.ActiveTab = nil
	W.Minimized = false

	initNotifs()

	local gui = Instance.new("ScreenGui")
	gui.Name = "vertelevsepoel"
	gui.ResetOnSpawn = false
	gui.DisplayOrder = 100
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.Parent = Player:WaitForChild("PlayerGui")

	local ww = IsMobile and 400 or 680
	local wh = IsMobile and 430 or 520
	local tw = IsMobile and 52 or 160

	-- Main frame
	local main = Instance.new("Frame")
	main.Name = "Main"
	main.BackgroundColor3 = Theme.Background
	main.Size = UDim2.new(0, ww, 0, wh)
	main.Position = UDim2.new(0.5, -ww/2, 0.5, -wh/2)
	main.AnchorPoint = Vector2.new(0, 0)
	main.ClipsDescendants = true
	main.Visible = false
	main.Parent = gui
	corner(main, 12)
	stroke(main, Theme.Border, 1, 0.3)
	shadow(main, 50, 0.4)

	-- ─── Title bar ──────────────────────────
	local titleBar = Instance.new("Frame")
	titleBar.BackgroundColor3 = Theme.SideBG
	titleBar.Size = UDim2.new(1, 0, 0, IsMobile and 40 or 46)
	titleBar.BorderSizePixel = 0
	titleBar.ZIndex = 2
	titleBar.Parent = main
	corner(titleBar, 12)

	local tbFix = Instance.new("Frame")
	tbFix.BackgroundColor3 = Theme.SideBG
	tbFix.Size = UDim2.new(1, 0, 0, 14)
	tbFix.Position = UDim2.new(0, 0, 1, -14)
	tbFix.BorderSizePixel = 0
	tbFix.ZIndex = 2
	tbFix.Parent = titleBar

	-- Gradient accent line below title
	local accentLine = Instance.new("Frame")
	accentLine.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
	accentLine.Size = UDim2.new(1, 0, 0, 2)
	accentLine.Position = UDim2.new(0, 0, 1, 0)
	accentLine.BorderSizePixel = 0
	accentLine.ZIndex = 3
	accentLine.Parent = titleBar
	gradient(accentLine, 0)

	-- Diamond icon
	local tIcon = Instance.new("TextLabel")
	tIcon.BackgroundTransparency = 1
	tIcon.Size = UDim2.new(0, 28, 0, 28)
	tIcon.Position = UDim2.new(0, IsMobile and 8 or 12, 0.5, 0)
	tIcon.AnchorPoint = Vector2.new(0, 0.5)
	tIcon.Text = "◆"
	tIcon.TextColor3 = Color3.fromRGB(220, 220, 220)
	tIcon.TextSize = IsMobile and 14 or 18
	tIcon.FontFace = FONT_BOLD
	tIcon.ZIndex = 3
	tIcon.Parent = titleBar

	task.spawn(function()
		while tIcon.Parent do
			tween(tIcon, {Rotation = 360}, 3, Enum.EasingStyle.Linear)
			task.wait(3)
			if tIcon.Parent then tIcon.Rotation = 0 end
		end
	end)

	local tText = Instance.new("TextLabel")
	tText.BackgroundTransparency = 1
	tText.Size = UDim2.new(1, -110, 1, 0)
	tText.Position = UDim2.new(0, IsMobile and 34 or 42, 0, 0)
	tText.Text = windowName
	tText.TextColor3 = Theme.Text
	tText.TextSize = IsMobile and 14 or 16
	tText.FontFace = FONT_BOLD
	tText.TextXAlignment = Enum.TextXAlignment.Left
	tText.TextTruncate = Enum.TextTruncate.AtEnd
	tText.ZIndex = 3
	tText.Parent = titleBar

	-- ── CLOSE button ─────────────────────────
	local closeBtn = Instance.new("TextButton")
	closeBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
	closeBtn.BackgroundTransparency = 0.85
	closeBtn.Size = UDim2.new(0, IsMobile and 26 or 30, 0, IsMobile and 26 or 30)
	closeBtn.Position = UDim2.new(1, IsMobile and -32 or -38, 0.5, 0)
	closeBtn.AnchorPoint = Vector2.new(0, 0.5)
	closeBtn.Text = "✕"
	closeBtn.TextColor3 = Color3.fromRGB(220, 80, 80)
	closeBtn.TextSize = IsMobile and 12 or 14
	closeBtn.FontFace = FONT_BOLD
	closeBtn.AutoButtonColor = false
	closeBtn.ZIndex = 3
	closeBtn.Parent = titleBar
	corner(closeBtn, 8)

	closeBtn.MouseEnter:Connect(function()
		tween(closeBtn, {BackgroundTransparency = 0.3, TextColor3 = Color3.new(1,1,1)}, 0.2)
	end)
	closeBtn.MouseLeave:Connect(function()
		tween(closeBtn, {BackgroundTransparency = 0.85, TextColor3 = Color3.fromRGB(220,80,80)}, 0.2)
	end)
	closeBtn.MouseButton1Click:Connect(function()
		tween(main, {Size = UDim2.new(0, ww*0.8, 0, wh*0.8), BackgroundTransparency = 1}, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In)
		task.wait(0.4)
		gui:Destroy()
	end)

	-- ── MINIMIZE button ───────────────────────
	local minBtn = Instance.new("TextButton")
	minBtn.BackgroundColor3 = Color3.fromRGB(200, 200, 60)
	minBtn.BackgroundTransparency = 0.85
	minBtn.Size = UDim2.new(0, IsMobile and 26 or 30, 0, IsMobile and 26 or 30)
	minBtn.Position = UDim2.new(1, IsMobile and -62 or -74, 0.5, 0)
	minBtn.AnchorPoint = Vector2.new(0, 0.5)
	minBtn.Text = "─"
	minBtn.TextColor3 = Color3.fromRGB(200, 200, 80)
	minBtn.TextSize = IsMobile and 12 or 14
	minBtn.FontFace = FONT_BOLD
	minBtn.AutoButtonColor = false
	minBtn.ZIndex = 3
	minBtn.Parent = titleBar
	corner(minBtn, 8)

	minBtn.MouseEnter:Connect(function()
		tween(minBtn, {BackgroundTransparency = 0.3, TextColor3 = Color3.new(1,1,1)}, 0.2)
	end)
	minBtn.MouseLeave:Connect(function()
		tween(minBtn, {BackgroundTransparency = 0.85, TextColor3 = Color3.fromRGB(200,200,80)}, 0.2)
	end)
	minBtn.MouseButton1Click:Connect(function()
		W.Minimized = not W.Minimized
		if W.Minimized then
			tween(main, {Size = UDim2.new(0, ww, 0, IsMobile and 42 or 50)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In)
			minBtn.Text = "＋"
		else
			tween(main, {Size = UDim2.new(0, ww, 0, wh)}, 0.4, Enum.EasingStyle.Back)
			minBtn.Text = "─"
		end
	end)

	-- ── Drag (перетаскивание по всему экрану) ─
	do
		local dragging = false
		local dragOffsetX = 0
		local dragOffsetY = 0

		titleBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				-- Считаем смещение курсора относительно левого верхнего угла окна
				dragOffsetX = input.Position.X - main.AbsolutePosition.X
				dragOffsetY = input.Position.Y - main.AbsolutePosition.Y
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if dragging and (
				input.UserInputType == Enum.UserInputType.MouseMovement or
				input.UserInputType == Enum.UserInputType.Touch
			) then
				local newX = input.Position.X - dragOffsetX
				local newY = input.Position.Y - dragOffsetY
				main.Position = UDim2.new(0, newX, 0, newY)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	end

	-- ── Body ─────────────────────────────────
	local body = Instance.new("Frame")
	body.BackgroundTransparency = 1
	body.Size = UDim2.new(1, 0, 1, -(IsMobile and 42 or 48))
	body.Position = UDim2.new(0, 0, 0, IsMobile and 42 or 48)
	body.Parent = main

	-- Sidebar
	local sidebar = Instance.new("Frame")
	sidebar.BackgroundColor3 = Theme.SideBG
	sidebar.Size = UDim2.new(0, tw, 1, 0)
	sidebar.BorderSizePixel = 0
	sidebar.Parent = body

	local sidebarBorder = Instance.new("Frame")
	sidebarBorder.BackgroundColor3 = Theme.Border
	sidebarBorder.BackgroundTransparency = 0.5
	sidebarBorder.Size = UDim2.new(0, 1, 1, 0)
	sidebarBorder.Position = UDim2.new(1, 0, 0, 0)
	sidebarBorder.BorderSizePixel = 0
	sidebarBorder.Parent = sidebar

	local tabScroll = Instance.new("ScrollingFrame")
	tabScroll.BackgroundTransparency = 1
	tabScroll.Size = UDim2.new(1, 0, 1, 0)
	tabScroll.ScrollBarThickness = 2
	tabScroll.ScrollBarImageColor3 = Color3.fromRGB(180, 180, 180)
	tabScroll.ScrollBarImageTransparency = 0.5
	tabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	tabScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	tabScroll.ScrollingDirection = Enum.ScrollingDirection.Y
	tabScroll.Parent = sidebar

	local tabLayout = Instance.new("UIListLayout")
