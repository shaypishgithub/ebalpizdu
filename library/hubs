	local closeBtn = makeCtrlBtn(IsMobile and -42 or -48, "✕",
		Color3.fromRGB(200, 55, 55), Color3.fromRGB(230, 100, 100), true)

	-- Minimize button
	local minBtn = makeCtrlBtn(IsMobile and -78 or -88, "─",
		Color3.fromRGB(70, 70, 70), Color3.fromRGB(190, 190, 190), false)

	closeBtn.MouseButton1Click:Connect(function()
		ripple(closeBtn,
			closeBtn.AbsolutePosition.X + closeBtn.AbsoluteSize.X / 2,
			closeBtn.AbsolutePosition.Y + closeBtn.AbsoluteSize.Y / 2)
		tw(main, {
			Size = UDim2.new(0, WW * 0.85, 0, WH * 0.85),
			BackgroundTransparency = 1
		}, .3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
