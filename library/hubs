					tween(arw, {Rotation = 180}, 0.25)
				else
					tween(f, {Size = UDim2.new(1, 0, 0, closedH)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
					tween(arw, {Rotation = 0}, 0.25)
				end
			end)
			header.MouseEnter:Connect(function() tween(f, {BackgroundColor3 = Theme.CardHover}, 0.15) end)
			header.MouseLeave:Connect(function() tween(f, {BackgroundColor3 = Theme.CardBG}, 0.15) end)

			return {Frame = f, Set = function(_, v) sel = v; selLbl.Text = tostring(v) end, Get = function() return sel end}
		end

		-- ─── CreateLabel ──────────────────────
		function T:CreateLabel(txt)
			T.ElCnt = T.ElCnt + 1
			local f = Instance.new("Frame")
			f.BackgroundTransparency = 1
			f.Size = UDim2.new(1, 0, 0, IsMobile and 24 or 28)
			f.LayoutOrder = T.ElCnt
			f.Parent = sc

			local line = Instance.new("Frame")
			line.BackgroundColor3 = Theme.Border
			line.BackgroundTransparency = 0.5
			line.Size = UDim2.new(1, 0, 0, 1)
			line.Position = UDim2.new(0, 0, 0.5, 0)
			line.BorderSizePixel = 0
			line.Parent = f

			local l = Instance.new("TextLabel")
			l.BackgroundColor3 = Theme.Background
			l.Size = UDim2.new(0, 0, 0, IsMobile and 18 or 20)
			l.AutomaticSize = Enum.AutomaticSize.X
			l.Position = UDim2.new(0, 6, 0.5, 0)
			l.AnchorPoint = Vector2.new(0, 0.5)
			l.Text = "  " .. txt .. "  "
			l.TextColor3 = Theme.TextMuted
			l.TextSize = IsMobile and 9 or 10
			l.FontFace = FONT_REG
			l.Parent = f
		end

		return T
	end

	-- ═══════════════════════════════════════
	-- Notify
	-- ═══════════════════════════════════════
	function W:Notify(txt, dur, nType)
		dur = dur or 3; nType = nType or "info"
		local col = Color3.fromRGB(180, 180, 180)
		local ico = "ℹ"
		if nType == "success" then col = Theme.Success; ico = "✓"
		elseif nType == "error" then col = Theme.Error;   ico = "✕"
		elseif nType == "warning" then col = Theme.Warning; ico = "⚠" end

		local nf = Instance.new("Frame")
		nf.BackgroundColor3 = Theme.NotifyBG
		nf.Size = UDim2.new(1, 0, 0, IsMobile and 48 or 54)
		nf.ClipsDescendants = true
		nf.Parent = NotifHolder
		corner(nf, 9)
		stroke(nf, col, 1, 0.4)

		local bar = Instance.new("Frame")
		bar.BackgroundColor3 = col
		bar.Size = UDim2.new(0, 3, 0.65, 0)
		bar.Position = UDim2.new(0, 0, 0.175, 0)
		bar.BorderSizePixel = 0
		bar.Parent = nf
		corner(bar, 2)

		local ni = Instance.new("TextLabel")
		ni.BackgroundTransparency = 1
		ni.Size = UDim2.new(0, 20, 0, 20)
		ni.Position = UDim2.new(0, 10, 0.5, 0)
		ni.AnchorPoint = Vector2.new(0, 0.5)
		ni.Text = ico; ni.TextColor3 = col
		ni.TextSize = IsMobile and 14 or 16
		ni.FontFace = FONT_BOLD
		ni.Parent = nf

		local nt = Instance.new("TextLabel")
		nt.BackgroundTransparency = 1
		nt.Size = UDim2.new(1, -42, 1, -6)
		nt.Position = UDim2.new(0, 35, 0, 3)
		nt.Text = txt; nt.TextColor3 = Theme.Text
		nt.TextSize = IsMobile and 11 or 12
		nt.FontFace = FONT_MED
		nt.TextXAlignment = Enum.TextXAlignment.Left
		nt.TextWrapped = true
		nt.Parent = nf

		local prog = Instance.new("Frame")
		prog.BackgroundColor3 = col
		prog.BackgroundTransparency = 0.3
		prog.Size = UDim2.new(1, 0, 0, 2)
		prog.Position = UDim2.new(0, 0, 1, -2)
		prog.BorderSizePixel = 0
		prog.Parent = nf
		gradient(prog, 0)

		nf.Position = UDim2.new(1, 15, 0, 0)
		tween(nf,   {Position = UDim2.new(0, 0, 0, 0)}, 0.35, Enum.EasingStyle.Back)
		tween(prog, {Size = UDim2.new(0, 0, 0, 2)}, dur, Enum.EasingStyle.Linear)

		task.delay(dur, function()
			tween(nf, {Position = UDim2.new(1, 15, 0, 0), BackgroundTransparency = 1}, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In)
			task.wait(0.4)
			if nf.Parent then nf:Destroy() end
		end)
	end

	-- ═══════════════════════════════════════
	-- Ask (dialog)
	-- ═══════════════════════════════════════
	function W:Ask(txt, answers, cb)
		answers = answers or {"Yes", "No"}

		local ov = Instance.new("TextButton")
		ov.BackgroundColor3 = Color3.new(0, 0, 0)
		ov.BackgroundTransparency = 1
		ov.Size = UDim2.new(1, 0, 1, 0)
		ov.Text = ""; ov.AutoButtonColor = false
		ov.ZIndex = 200; ov.Parent = gui
		tween(ov, {BackgroundTransparency = 0.55}, 0.3)

		local dw  = IsMobile and 290 or 370
		local bh  = IsMobile and 36 or 40
		local cols = math.min(#answers, 3)
		local rows = math.ceil(#answers / cols)
		local dh   = (IsMobile and 115 or 130) + rows * (bh + 6)

		local df = Instance.new("Frame")
		df.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
		df.Size = UDim2.new(0, dw * 0.75, 0, dh * 0.75)
		df.Position = UDim2.new(0.5, 0, 0.5, 0)
		df.AnchorPoint = Vector2.new(0.5, 0.5)
		df.ZIndex = 210; df.ClipsDescendants = true
		df.Parent = gui
		corner(df, 14)
		stroke(df, Color3.fromRGB(150, 150, 150), 1, 0.3)
		shadow(df, 50, 0.2)
		tween(df, {Size = UDim2.new(0, dw, 0, dh)}, 0.4, Enum.EasingStyle.Back)

		local tb = Instance.new("Frame")
		tb.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
		tb.Size = UDim2.new(1, 0, 0, 3)
		tb.BorderSizePixel = 0; tb.ZIndex = 211
		tb.Parent = df
		gradient(tb, 0)

		local qi = Instance.new("TextLabel")
		qi.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
		qi.BackgroundTransparency = 0.8
		qi.Size = UDim2.new(0, 0, 0, 0)
		qi.Position = UDim2.new(0.5, 0, 0, IsMobile and 14 or 18)
		qi.AnchorPoint = Vector2.new(0.5, 0)
		qi.Text = "?"; qi.TextColor3 = Color3.fromRGB(200, 200, 200)
		qi.TextSize = IsMobile and 18 or 22
		qi.FontFace = FONT_BOLD; qi.ZIndex = 212
		qi.Parent = df
		corner(qi, 20)
		task.delay(0.1, function()
			tween(qi, {Size = UDim2.new(0, IsMobile and 34 or 40, 0, IsMobile and 34 or 40)}, 0.35, Enum.EasingStyle.Back)
		end)

		local qt = Instance.new("TextLabel")
		qt.BackgroundTransparency = 1
		qt.Size = UDim2.new(1, -30, 0, IsMobile and 36 or 44)
		qt.Position = UDim2.new(0, 15, 0, IsMobile and 52 or 64)
		qt.Text = txt; qt.TextColor3 = Theme.Text; qt.TextTransparency = 1
		qt.TextSize = IsMobile and 13 or 15
		qt.FontFace = FONT_MED; qt.TextWrapped = true; qt.ZIndex = 212
		qt.Parent = df
		task.delay(0.15, function() tween(qt, {TextTransparency = 0}, 0.3) end)

		local function closeAsk(ans)
			tween(df, {Size = UDim2.new(0, dw*0.75, 0, dh*0.75), BackgroundTransparency = 0.8}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
			tween(ov, {BackgroundTransparency = 1}, 0.25)
			task.wait(0.35)
			if df.Parent then df:Destroy() end
			if ov.Parent then ov:Destroy() end
			if cb then pcall(cb, ans) end
		end

		local bw = #answers == 1 and (dw - 30)
			or #answers == 2 and (dw - 30 - 6) / 2
			or (dw - 30 - 6 * (cols - 1)) / cols
		local startY = IsMobile and 92 or 112

		for i, ans in ipairs(answers) do
			local row = math.ceil(i / cols) - 1
			local col = (i - 1) % cols

			local ab = Instance.new("TextButton")
			ab.Size = UDim2.new(0, bw, 0, bh)
			ab.Position = UDim2.new(0, 15 + col * (bw + 6), 0, startY + row * (bh + 6))
			ab.Text = ans
			ab.TextColor3 = i == 1 and Color3.new(1, 1, 1) or Theme.Text
			ab.TextSize = IsMobile and 12 or 13
			ab.FontFace = i == 1 and FONT_BOLD or FONT_MED
			ab.AutoButtonColor = false; ab.ZIndex = 213
			ab.ClipsDescendants = true; ab.Parent = df

			if i == 1 then
				ab.BackgroundColor3 = Color3.fromRGB(90, 90, 90)
				gradient(ab, 0)
			else
				ab.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				stroke(ab, Theme.Border, 1, 0.4)
			end
			corner(ab, 9)

			ab.BackgroundTransparency = 1; ab.TextTransparency = 1
			task.delay(0.2 + i * 0.06, function()
				tween(ab, {BackgroundTransparency = 0, TextTransparency = 0}, 0.25, Enum.EasingStyle.Back)
			end)

			local origCol = i == 1 and Color3.fromRGB(90, 90, 90) or Color3.fromRGB(30, 30, 30)
			ab.MouseEnter:Connect(function()
				tween(ab, {BackgroundColor3 = i == 1 and Color3.fromRGB(130, 130, 130) or Theme.CardHover}, 0.12)
			end)
			ab.MouseLeave:Connect(function()
				tween(ab, {BackgroundColor3 = origCol}, 0.12)
			end)
			ab.MouseButton1Click:Connect(function()
				ripple(ab,
					IsMobile and (ab.AbsolutePosition.X + ab.AbsoluteSize.X/2) or Mouse.X,
					IsMobile and (ab.AbsolutePosition.Y + ab.AbsoluteSize.Y/2) or Mouse.Y)
				task.delay(0.12, function() closeAsk(ans) end)
			end)
		end

		ov.MouseButton1Click:Connect(function() closeAsk(nil) end)
	end

	-- ═══════════════════════════════════════
	-- Toggle visibility  (RightCtrl / F4)
	-- ═══════════════════════════════════════
	local vis = true
	UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode == Enum.KeyCode.RightControl
		or input.KeyCode == Enum.KeyCode.F4 then
			vis = not vis
			main.Visible = vis
		end
	end)

	-- Mobile toggle button
	if IsMobile then
		local mt = Instance.new("TextButton")
		mt.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
		mt.Size = UDim2.new(0, 38, 0, 38)
		mt.Position = UDim2.new(0, 8, 0, 8)
		mt.Text = "◆"; mt.TextColor3 = Color3.new(1, 1, 1)
		mt.TextSize = 16; mt.FontFace = FONT_BOLD
		mt.ZIndex = 999; mt.Parent = gui
		corner(mt, 19)
		gradient(mt, 45)

		local mtDrag, mtStart, mtPos = false, nil, nil
		mt.InputBegan:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.Touch then
				mtDrag = true; mtStart = i.Position; mtPos = mt.Position
			end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if mtDrag and i.UserInputType == Enum.UserInputType.Touch then
				local d = i.Position - mtStart
				mt.Position = UDim2.new(mtPos.X.Scale, mtPos.X.Offset + d.X, mtPos.Y.Scale, mtPos.Y.Offset + d.Y)
			end
		end)
		UserInputService.InputEnded:Connect(function(i)
			if i.UserInputType == Enum.UserInputType.Touch and mtDrag then
				mtDrag = false
				if (i.Position - mtStart).Magnitude < 10 then
					vis = not vis; main.Visible = vis
				end
			end
		end)
	end

	-- ═══════════════════════════════════════
	-- Show loading → then reveal window
	-- ═══════════════════════════════════════
	showLoading(windowName, gui, function()
		main.Visible = true
		main.Size = UDim2.new(0, ww * 0.85, 0, wh * 0.85)
		main.BackgroundTransparency = 0.3
		tween(main, {Size = UDim2.new(0, ww, 0, wh), BackgroundTransparency = 0}, 0.45, Enum.EasingStyle.Back)
	end)

	return W
end

return Library
