-- ══════════════════════════════════════════════════════
-- HELPERS
-- ══════════════════════════════════════════════════════
local function corner(p, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, r or 8)
	c.Parent = p
end

local function stroke(p, col, th, tr)
	local s = Instance.new("UIStroke")
	s.Color = col or T.Border
	s.Thickness = th or 1
	s.Transparency = tr or 0.5
	s.Parent = p
end

local function pad(p, t, b, l, r)
	local pd = Instance.new("UIPadding")
	pd.PaddingTop    = UDim.new(0, t or 0)
	pd.PaddingBottom = UDim.new(0, b or 0)
	pd.PaddingLeft   = UDim.new(0, l or 0)
	pd.PaddingRight  = UDim.new(0, r or 0)
	pd.Parent = p
end

local function tw(obj, props, dur, sty, dir)
	if not obj or not obj.Parent then return end
	TweenService:Create(
		obj,
		TweenInfo.new(dur or 0.3, sty or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
		props
	):Play()
end

local function ripple(btn, x, y)
	local r = Instance.new("Frame")
	r.BackgroundColor3    = Color3.new(1, 1, 1)
	r.BackgroundTransparency = 0.78
	r.BorderSizePixel     = 0
	r.ZIndex              = btn.ZIndex + 5
	r.AnchorPoint         = Vector2.new(0.5, 0.5)
	r.Position            = UDim2.new(0, x - btn.AbsolutePosition.X, 0, y - btn.AbsolutePosition.Y)
	r.Size                = UDim2.new(0, 0, 0, 0)
	r.Parent              = btn
	corner(r, 999)
	local ms = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.5
	tw(r, {Size = UDim2.new(0, ms, 0, ms), BackgroundTransparency = 1}, 0.55, Enum.EasingStyle.Quad)
	task.delay(0.6, function() if r.Parent then r:Destroy() end end)
end

-- ══════════════════════════════════════════════════════
-- ANIMATED SHIMMER STRIPE
-- ══════════════════════════════════════════════════════
local function makeShimmer(parent, h, zidx)
	h = h or 2
	local holder = Instance.new("Frame")
	holder.BackgroundTransparency = 1
	holder.BorderSizePixel        = 0
	holder.Size                   = UDim2.new(1, 0, 0, h)
	holder.ClipsDescendants       = true
	holder.ZIndex                 = zidx or (parent.ZIndex + 1)
	holder.Parent                 = parent

	local stripe = Instance.new("Frame")
	stripe.BackgroundColor3  = Color3.new(1, 1, 1)
	stripe.BorderSizePixel   = 0
	stripe.Size              = UDim2.new(3, 0, 1, 0)
	stripe.Position          = UDim2.new(-2, 0, 0, 0)
	stripe.ZIndex            = holder.ZIndex
	stripe.Parent            = holder

	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0.00, Color3.fromRGB(18,  18,  18 )),
		ColorSequenceKeypoint.new(0.30, Color3.fromRGB(90,  90,  90 )),
		ColorSequenceKeypoint.new(0.50, Color3.fromRGB(255, 255, 255)),
		ColorSequenceKeypoint.new(0.70, Color3.fromRGB(90,  90,  90 )),
		ColorSequenceKeypoint.new(1.00, Color3.fromRGB(18,  18,  18 )),
	})
	g.Rotation = 0
	g.Parent   = stripe

	local function loop()
		stripe.Position = UDim2.new(-2, 0, 0, 0)
		tw(stripe, {Position = UDim2.new(1, 0, 0, 0)}, 2.2, Enum.EasingStyle.Linear)
		task.wait(2.2)
		if stripe.Parent then loop() end
	end
	task.spawn(loop)

	return holder
end

