local function showLoading(title, gui, onDone)
	local bg = Instance.new("Frame")
	bg.Name = "Loading"
	bg.BackgroundColor3 = Theme.LoadingBG
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.ZIndex = 100
