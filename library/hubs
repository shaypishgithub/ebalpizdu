		-- ─── BUTTON ───────────────────────────────────
		function TAB:CreateButton(bName, cb)
			TAB.ElCnt = TAB.ElCnt + 1
			local f = makeCard(IsMobile and 46 or 52)
			f.ClipsDescendants = true

			-- Animated left-side accent stripe
			local acLine = Instance.new("Frame")
			acLine.BackgroundColor3 = Color3.fromRGB(160, 160, 160)
			acLine.BorderSizePixel  = 0
			acLine.Size             = UDim2.new(0, 3, 0.55, 0)
			acLine.Position         = UDim2.new(0, 0, 0.225, 0)
			acLine.Parent           = f
			corner(acLine, 2)
			do
				local ag = Instance.new("UIGradient")
				ag.Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, Color3.fromRGB(50,  50,  50 )),
					ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
				})
				ag.Rotation = 90
				ag.Parent   = acLine
			end

			makeLabel(f, bName, 18)

			local arr = Instance.new("TextLabel")
			arr.BackgroundTransparency = 1
			arr.Size     = UDim2.new(0, 24, 1, 0)
			arr.Position = UDim2.new(1, -34, 0, 0)
			arr.Text     = "→"
			arr.TextColor3    = T.TextMuted
			arr.TextSize      = 15
			arr.FontFace      = FM
			arr.TextXAlignment= Enum.TextXAlignment.Center
			arr.Parent        = f

			local ob = overlayBtn(f)
			ob.MouseEnter:Connect(function()
				tw(f,{BackgroundColor3=T.CardHover},.12)
				tw(arr,{TextColor3=T.White},.12)
			end)
			ob.MouseLeave:Connect(function()
				tw(f,{BackgroundColor3=T.CardBG},.12)
				tw(arr,{TextColor3=T.TextMuted},.12)
			end)
			ob.MouseButton1Click:Connect(function()
				ripple(f,
					IsMobile and f.AbsolutePosition.X+f.AbsoluteSize.X/2 or Mouse.X,
					IsMobile and f.AbsolutePosition.Y+f.AbsoluteSize.Y/2 or Mouse.Y)
				tw(f,{BackgroundColor3=T.CardHover},.06)
				task.delay(.1, function() tw(f,{BackgroundColor3=T.CardBG},.22) end)
				if cb then pcall(cb) end
			end)
			return f
		end

		-- ─── TOGGLE ───────────────────────────────────
		function TAB:CreateToggle(name, def, cb)
			TAB.ElCnt = TAB.ElCnt + 1
			local on = def or false
			local f  = makeCard(IsMobile and 46 or 52)

			makeLabel(f, name, 18)

			local tbg = Instance.new("Frame")
			tbg.BackgroundColor3 = on and Color3.fromRGB(165,165,165) or T.ToggleOff
			tbg.BorderSizePixel  = 0
			tbg.Size             = UDim2.new(0, IsMobile and 46 or 52, 0, IsMobile and 26 or 30)
			tbg.Position         = UDim2.new(1, -(IsMobile and 56 or 66), 0.5, 0)
			tbg.AnchorPoint      = Vector2.new(0, 0.5)
			tbg.Parent           = f
			corner(tbg, 15)

			local knob = Instance.new("Frame")
			knob.BackgroundColor3 = Color3.new(1, 1, 1)
			knob.BorderSizePixel  = 0
			knob.Size     = UDim2.new(0, IsMobile and 20 or 24, 0, IsMobile and 20 or 24)
			knob.Position = on
				and UDim2.new(1, -(IsMobile and 22 or 26), 0.5, 0)
				or  UDim2.new(0, 3, 0.5, 0)
			knob.AnchorPoint = Vector2.new(0, 0.5)
			knob.Parent      = tbg
			corner(knob, 12)

			local function upd()
				if on then
					tw(tbg,  {BackgroundColor3=Color3.fromRGB(165,165,165)}, .22)
					tw(knob, {Position=UDim2.new(1,-(IsMobile and 22 or 26),.5,0)}, .22, Enum.EasingStyle.Back)
				else
					tw(tbg,  {BackgroundColor3=T.ToggleOff}, .22)
					tw(knob, {Position=UDim2.new(0,3,.5,0)}, .22, Enum.EasingStyle.Back)
				end
			end

			local ob = overlayBtn(f)
			ob.MouseEnter:Connect(function() tw(f,{BackgroundColor3=T.CardHover},.12) end)
			ob.MouseLeave:Connect(function() tw(f,{BackgroundColor3=T.CardBG},.12) end)
			ob.MouseButton1Click:Connect(function()
				on = not on; upd()
				if cb then pcall(cb, on) end
			end)

			return {
				Frame = f,
				Set   = function(_, v) on = v; upd() end,
				Get   = function() return on end,
			}
		end

		-- ─── SLIDER ───────────────────────────────────
		function TAB:CreateSlider(name, mn, mx, def, cb)
			TAB.ElCnt = TAB.ElCnt + 1
			mn=mn or 0; mx=mx or 100; def=math.clamp(def or mn,mn,mx)
			local val = def
			local f   = makeCard(IsMobile and 66 or 76)

			makeLabel(f, name, 18, T.Text, IsMobile and 11 or 12, FM)

			local vlbl = Instance.new("TextLabel")
			vlbl.BackgroundColor3       = Color3.fromRGB(16, 16, 16)
			vlbl.BackgroundTransparency = 0.15
			vlbl.BorderSizePixel        = 0
			vlbl.Size     = UDim2.new(0, IsMobile and 48 or 58, 0, IsMobile and 22 or 26)
			vlbl.Position = UDim2.new(1, -(IsMobile and 58 or 70), 0, IsMobile and 6 or 8)
			vlbl.Text     = tostring(val)
			vlbl.TextColor3    = T.White
			vlbl.TextSize      = IsMobile and 10 or 12
			vlbl.FontFace      = FB
			vlbl.Parent        = f
			corner(vlbl, 6)

			local track = Instance.new("Frame")
			track.BackgroundColor3 = T.SliderTrack
			track.BorderSizePixel  = 0
			track.Size     = UDim2.new(1, -32, 0, 6)
			track.Position = UDim2.new(0, 16, 1, IsMobile and -20 or -24)
			track.Parent   = f
			corner(track, 3)

			local p0   = (val-mn)/(mx-mn)
			local fill = Instance.new("Frame")
			fill.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
			fill.BorderSizePixel  = 0
			fill.Size             = UDim2.new(p0, 0, 1, 0)
			fill.Parent           = track
			corner(fill, 3)
			do
				local fg = Instance.new("UIGradient")
				fg.Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, Color3.fromRGB(50,  50,  50 )),
					ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
				})
				fg.Rotation = 0
				fg.Parent   = fill
			end

			local knb = Instance.new("Frame")
			knb.BackgroundColor3 = Color3.new(1, 1, 1)
			knb.BorderSizePixel  = 0
			knb.Size             = UDim2.new(0, 16, 0, 16)
			knb.Position         = UDim2.new(p0, 0, 0.5, 0)
			knb.AnchorPoint      = Vector2.new(0.5, 0.5)
			knb.ZIndex           = f.ZIndex + 3
			knb.Parent           = track
			corner(knb, 8)

			local dragging = false
			local function updSl(ix)
				local r = math.clamp((ix - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
				val = math.floor(mn + (mx - mn) * r)
				local np = (val-mn)/(mx-mn)
				tw(fill, {Size=UDim2.new(np,0,1,0)}, .05, Enum.EasingStyle.Quad)
				tw(knb,  {Position=UDim2.new(np,0,.5,0)}, .05, Enum.EasingStyle.Quad)
				vlbl.Text = tostring(val)
				if cb then pcall(cb, val) end
			end

			track.InputBegan:Connect(function(i)
				if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
					dragging=true; updSl(i.Position.X)
				end
			end)
			knb.InputBegan:Connect(function(i)
				if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
					dragging=true
				end
			end)
			UserInputService.InputChanged:Connect(function(i)
				if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
					updSl(i.Position.X)
				end
			end)
			UserInputService.InputEnded:Connect(function(i)
				if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
					dragging=false
				end
			end)

			return {
				Frame = f,
				Set = function(_,v)
					val=math.clamp(v,mn,mx)
					local np=(val-mn)/(mx-mn)
					tw(fill,{Size=UDim2.new(np,0,1,0)},.2)
					tw(knb,{Position=UDim2.new(np,0,.5,0)},.2)
					vlbl.Text=tostring(val)
				end,
				Get = function() return val end,
			}
		end

		-- ─── DROPDOWN ─────────────────────────────────
		function TAB:CreateDropdown(name, opts, def, cb)
			TAB.ElCnt = TAB.ElCnt + 1
			opts = opts or {}
			local sel     = def or opts[1] or "..."
			local open    = false
			local closedH = IsMobile and 46 or 52

			local f = makeCard(closedH)
			f.ClipsDescendants = true

			local hdr = Instance.new("TextButton")
			hdr.BackgroundTransparency = 1
			hdr.BorderSizePixel        = 0
			hdr.Size             = UDim2.new(1, 0, 0, closedH)
			hdr.Text             = ""
			hdr.AutoButtonColor  = false
			hdr.Parent           = f

			makeLabel(hdr, name, 18, T.Text, IsMobile and 11 or 12, FM)

			local selBG = Instance.new("Frame")
			selBG.BackgroundColor3       = Color3.fromRGB(18, 18, 18)
			selBG.BackgroundTransparency = 0.15
			selBG.BorderSizePixel        = 0
			selBG.Size     = UDim2.new(0, IsMobile and 96 or 140, 0, IsMobile and 28 or 32)
			selBG.Position = UDim2.new(1, -(IsMobile and 128 or 178), 0.5, 0)
			selBG.AnchorPoint = Vector2.new(0, 0.5)
			selBG.Parent   = hdr
			corner(selBG, 7)

			local selLbl = Instance.new("TextLabel")
			selLbl.BackgroundTransparency = 1
			selLbl.Size     = UDim2.new(1, -8, 1, 0)
			selLbl.Position = UDim2.new(0, 8, 0, 0)
			selLbl.Text     = tostring(sel)
			selLbl.TextColor3    = T.White
			selLbl.TextSize      = IsMobile and 10 or 11
			selLbl.FontFace      = FM
			selLbl.TextXAlignment= Enum.TextXAlignment.Left
			selLbl.TextTruncate  = Enum.TextTruncate.AtEnd
			selLbl.Parent        = selBG

			local arw = Instance.new("TextLabel")
			arw.BackgroundTransparency = 1
			arw.Size     = UDim2.new(0, 22, 1, 0)
			arw.Position = UDim2.new(1, -26, 0, 0)
			arw.Text     = "▼"
			arw.TextColor3    = T.TextMuted
			arw.TextSize      = IsMobile and 9 or 10
			arw.FontFace      = FM
			arw.Parent        = hdr

			local optFrame = Instance.new("Frame")
			optFrame.BackgroundTransparency = 1
			optFrame.BorderSizePixel        = 0
			optFrame.Size     = UDim2.new(1, 0, 0, 0)
			optFrame.Position = UDim2.new(0, 0, 0, closedH)
			optFrame.Parent   = f

			local ol2 = Instance.new("UIListLayout")
			ol2.SortOrder = Enum.SortOrder.LayoutOrder
			ol2.Padding   = UDim.new(0, 2)
			ol2.Parent    = optFrame
			pad(optFrame, 3, 6, IsMobile and 6 or 10, IsMobile and 6 or 10)

			local optBtns = {}
			local function makeOpt(txt, idx)
				local ob = Instance.new("TextButton")
				ob.BackgroundColor3       = Color3.fromRGB(24, 24, 24)
				ob.BackgroundTransparency = 0.15
				ob.BorderSizePixel        = 0
				ob.Size             = UDim2.new(1, 0, 0, IsMobile and 34 or 38)
				ob.Text             = ""
				ob.AutoButtonColor  = false
				ob.LayoutOrder      = idx
				ob.Parent           = optFrame
				corner(ob, 7)

				local oLbl = Instance.new("TextLabel")
				oLbl.BackgroundTransparency = 1
				oLbl.Size     = UDim2.new(1, -30, 1, 0)
				oLbl.Position = UDim2.new(0, 12, 0, 0)
				oLbl.Text     = txt
				oLbl.TextColor3    = txt==sel and T.White or T.TextDim
				oLbl.TextSize      = IsMobile and 10 or 11
				oLbl.FontFace      = FM
				oLbl.TextXAlignment= Enum.TextXAlignment.Left
				oLbl.TextTruncate  = Enum.TextTruncate.AtEnd
				oLbl.Parent        = ob

				local chk = Instance.new("TextLabel")
				chk.BackgroundTransparency = 1
				chk.Size     = UDim2.new(0, 18, 1, 0)
				chk.Position = UDim2.new(1, -22, 0, 0)
				chk.Text     = txt==sel and "✓" or ""
				chk.TextColor3    = T.White
				chk.TextSize      = IsMobile and 11 or 12
				chk.FontFace      = FB
				chk.Parent        = ob

				ob.MouseEnter:Connect(function() tw(ob,{BackgroundTransparency=0},.1) end)
				ob.MouseLeave:Connect(function() tw(ob,{BackgroundTransparency=0.15},.1) end)
				ob.MouseButton1Click:Connect(function()
					sel = txt; selLbl.Text = txt
					for _, b in ipairs(optBtns) do
						for _, ch in ipairs(b:GetChildren()) do
							if ch:IsA("TextLabel") then
								if ch.Size==UDim2.new(0,18,1,0) then ch.Text="" end
								if ch.Size~=UDim2.new(0,18,1,0) then tw(ch,{TextColor3=T.TextDim},.1) end
							end
						end
					end
					oLbl.TextColor3 = T.White
					chk.Text        = "✓"
					task.delay(.1, function()
						open = false
						tw(f,{Size=UDim2.new(1,0,0,closedH)},.28,Enum.EasingStyle.Back,Enum.EasingDirection.In)
						tw(arw,{Rotation=0},.22)
					end)
					if cb then pcall(cb, sel) end
				end)
				table.insert(optBtns, ob)
			end

			for i, o in ipairs(opts) do makeOpt(o, i) end

			hdr.MouseButton1Click:Connect(function()
				open = not open
				if open then
					local rh  = IsMobile and 36 or 40
					local tot = math.min(closedH + #opts*rh + 16, IsMobile and 260 or 320)
					tw(f, {Size=UDim2.new(1,0,0,tot)}, .32, Enum.EasingStyle.Back)
					tw(arw, {Rotation=180}, .22)
				else
					tw(f, {Size=UDim2.new(1,0,0,closedH)}, .28, Enum.EasingStyle.Back, Enum.EasingDirection.In)
					tw(arw, {Rotation=0}, .22)
				end
			end)
			hdr.MouseEnter:Connect(function() tw(f,{BackgroundColor3=T.CardHover},.12) end)
			hdr.MouseLeave:Connect(function() tw(f,{BackgroundColor3=T.CardBG},.12) end)

			return {
				Frame = f,
				Set   = function(_,v) sel=v; selLbl.Text=tostring(v) end,
				Get   = function() return sel end,
			}
		end

		-- ─── TEXT INPUT ───────────────────────────────
		function TAB:CreateInput(name, placeholder, cb)
			TAB.ElCnt = TAB.ElCnt + 1
			local f = makeCard(IsMobile and 64 or 74)

			makeLabel(f, name, 18, T.TextDim, IsMobile and 9 or 10, FR)

			local box = Instance.new("TextBox")
			box.BackgroundColor3       = Color3.fromRGB(14, 14, 14)
			box.BackgroundTransparency = 0.15
			box.BorderSizePixel        = 0
			box.Size     = UDim2.new(1, -32, 0, IsMobile and 32 or 36)
			box.Position = UDim2.new(0, 16, 1, -(IsMobile and 40 or 46))
			box.PlaceholderText  = placeholder or "..."
			box.PlaceholderColor3= T.TextMuted
			box.Text             = ""
			box.TextColor3       = T.Text
			box.TextSize         = IsMobile and 11 or 12
			box.FontFace         = FM
			box.ClearTextOnFocus = false
			box.ZIndex           = f.ZIndex + 2
			box.Parent           = f
			corner(box, 7)
			stroke(box, T.Border, 1, 0.4)
			pad(box, 0, 0, 10, 10)

			box.Focused:Connect(function()   tw(box,{BackgroundTransparency=0},.15) end)
			box.FocusLost:Connect(function(enter)
				tw(box,{BackgroundTransparency=0.15},.15)
				if cb then pcall(cb, box.Text, enter) end
			end)

			return {
				Frame = f,
				Get   = function() return box.Text end,
				Set   = function(_,v) box.Text = v end,
			}
		end

		return TAB
	end -- W:CreateTab

