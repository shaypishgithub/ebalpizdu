	-- ── switchTab ────────────────────────────
	local function switchTab(tab)
		if W.ActiveTab == tab then return end
		if W.ActiveTab then
			W.ActiveTab.Frame.Visible = false
			tween(W.ActiveTab.Btn, {BackgroundColor3 = Theme.TabInactive, BackgroundTransparency = 0.5}, 0.2)
			local ol = W.ActiveTab.Btn:FindFirstChild("Lbl")
			if ol then tween(ol, {TextColor3 = Theme.TextDim}, 0.2) end
			local oi = W.ActiveTab.Btn:FindFirstChild("Ico")
			if oi then tween(oi, {TextColor3 = Theme.TextDim}, 0.2) end
		end

		W.ActiveTab = tab
		tab.Frame.Visible = true

		local by = tab.Btn.AbsolutePosition.Y - sidebar.AbsolutePosition.Y
		tween(indicator, {Position = UDim2.new(1, -3, 0, by + 4)}, 0.3, Enum.EasingStyle.Back)
		tween(tab.Btn, {BackgroundColor3 = Color3.fromRGB(60, 60, 60), BackgroundTransparency = 0.3}, 0.2)
		local nl = tab.Btn:FindFirstChild("Lbl")
		if nl then tween(nl, {TextColor3 = Theme.Text}, 0.2) end
		local ni = tab.Btn:FindFirstChild("Ico")
		if ni then tween(ni, {TextColor3 = Color3.fromRGB(220, 220, 220)}, 0.2) end

		-- Slide-in elements
		local elems = {}
		for _, ch in ipairs(tab.Scroll:GetChildren()) do
			if ch:IsA("GuiObject") and not ch:IsA("UIListLayout") and not ch:IsA("UIPadding") then
				table.insert(elems, ch)
			end
		end
		for idx, el in ipairs(elems) do
			local orig = el.Position
			el.Position = UDim2.new(orig.X.Scale, orig.X.Offset + 20, orig.Y.Scale, orig.Y.Offset)
			task.delay(idx * 0.025, function()
				if el.Parent then tween(el, {Position = orig}, 0.3, Enum.EasingStyle.Back) end
			end)
		end
	end

