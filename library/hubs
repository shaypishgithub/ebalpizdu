	-- ── switchTab ─────────────────────────────────────
	local function switchTab(tab)
		if W.ActiveTab == tab then return end
		if W.ActiveTab then
			W.ActiveTab.Frame.Visible = false
			tw(W.ActiveTab.Btn, {BackgroundColor3=T.SideBG, BackgroundTransparency=0}, .18)
			local ol = W.ActiveTab.Btn:FindFirstChild("Lbl")
			if ol then tw(ol, {TextColor3=T.TextDim}, .18) end
		end
		W.ActiveTab       = tab
		tab.Frame.Visible = true

		local by = tab.Btn.AbsolutePosition.Y - sidebar.AbsolutePosition.Y
		tw(indicator, {Position=UDim2.new(1,-3,0,by+6)}, .32, Enum.EasingStyle.Back)
		tw(tab.Btn, {BackgroundColor3=T.CardHover, BackgroundTransparency=0}, .18)
		local nl = tab.Btn:FindFirstChild("Lbl")
		if nl then tw(nl, {TextColor3=T.White}, .18) end

		-- Stagger slide-in
		local kids = {}
		for _, ch in ipairs(tab.Scroll:GetChildren()) do
			if ch:IsA("GuiObject") and not ch:IsA("UIListLayout") and not ch:IsA("UIPadding") then
				table.insert(kids, ch)
			end
		end
		for i, el in ipairs(kids) do
			local orig = el.Position
			el.Position = UDim2.new(orig.X.Scale, orig.X.Offset + 20, orig.Y.Scale, orig.Y.Offset)
			task.delay(i * 0.03, function()
				if el.Parent then tw(el, {Position=orig}, .28, Enum.EasingStyle.Back) end
			end)
		end
	end

	-- ══════════════════════════════════════════════════
	-- CREATE TAB
	-- ══════════════════════════════════════════════════
	local tCnt = 0

	function W:CreateTab(tabName)
		tCnt = tCnt + 1
		local TAB = { Name=tabName, ElCnt=0 }

		local btn = Instance.new("TextButton")
		btn.Name                  = "TabBtn_"..tabName
		btn.BackgroundColor3      = T.SideBG
		btn.BackgroundTransparency= 0
		btn.BorderSizePixel       = 0
		btn.Size        = UDim2.new(1, 0, 0, IsMobile and 42 or 48)
		btn.Text        = ""
		btn.AutoButtonColor = false
		btn.LayoutOrder = tCnt
		btn.Parent      = tabScroll
		corner(btn, 9)

		local lbl = Instance.new("TextLabel")
		lbl.Name                  = "Lbl"
		lbl.BackgroundTransparency= 1
		lbl.Size     = UDim2.new(1, -12, 1, 0)
