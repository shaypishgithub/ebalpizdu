		b.BackgroundColor3       = bgR
		b.BackgroundTransparency = isClose and 0.65 or 0.82
		b.BorderSizePixel        = 0
		b.Size     = UDim2.new(0, IsMobile and 30 or 34, 0, IsMobile and 30 or 34)
		b.Position = UDim2.new(1, xOff, 0.5, 0)
		b.AnchorPoint     = Vector2.new(0, 0.5)
		b.Text            = lbl
		b.TextColor3      = fgCol
		b.TextSize        = IsMobile and 13 or 14
		b.FontFace        = FB
		b.AutoButtonColor = false
		b.ZIndex          = 6
		b.Parent          = titleBar
		corner(b, isClose and 9 or 8)
		if isClose then
			stroke(b, Color3.fromRGB(180, 50, 50), 1, 0.5)
		end
		b.MouseEnter:Connect(function()
			tw(b, {BackgroundTransparency = isClose and 0.1 or 0.28, TextColor3 = T.White}, .15)
		end)
		b.MouseLeave:Connect(function()
