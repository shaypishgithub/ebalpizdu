	-- NOTIFY
	-- ══════════════════════════════════════════════════
	function W:Notify(txt, dur, nType)
		dur = dur or 3; nType = nType or "info"
		local col = Color3.fromRGB(155, 155, 155)
		local ico = "•"
		if nType=="success" then col=T.Success; ico="✓"
		elseif nType=="error"   then col=T.Error;   ico="✕"
		elseif nType=="warning" then col=T.Warning;  ico="!" end

		local nf = Instance.new("Frame")
		nf.BackgroundColor3    = Color3.fromRGB(13, 13, 13)
		nf.BackgroundTransparency = 0
		nf.BorderSizePixel        = 0
		nf.Size    = UDim2.new(1, 0, 0, IsMobile and 54 or 60)
		nf.ClipsDescendants = true
		nf.Parent  = NotifHolder
		corner(nf, 10)
		stroke(nf, col, 1, 0.25)

		local nb = Instance.new("Frame"); nb.BackgroundColor3=col; nb.BorderSizePixel=0
		nb.Size=UDim2.new(0,3,.6,0); nb.Position=UDim2.new(0,0,.2,0); nb.Parent=nf; corner(nb,2)

		local ni = Instance.new("TextLabel"); ni.BackgroundTransparency=1
		ni.Size=UDim2.new(0,20,0,20); ni.Position=UDim2.new(0,12,.5,0); ni.AnchorPoint=Vector2.new(0,.5)
		ni.Text=ico; ni.TextColor3=col; ni.TextSize=IsMobile and 14 or 16; ni.FontFace=FB; ni.Parent=nf

		local nt = Instance.new("TextLabel"); nt.BackgroundTransparency=1
		nt.Size=UDim2.new(1,-44,1,-6); nt.Position=UDim2.new(0,38,0,3)
		nt.Text=txt; nt.TextColor3=T.Text; nt.TextSize=IsMobile and 11 or 12; nt.FontFace=FM
		nt.TextXAlignment=Enum.TextXAlignment.Left; nt.TextWrapped=true; nt.Parent=nf

		local prog = Instance.new("Frame"); prog.BackgroundColor3=col; prog.BackgroundTransparency=0.3
		prog.BorderSizePixel=0; prog.Size=UDim2.new(1,0,0,2); prog.Position=UDim2.new(0,0,1,-2); prog.Parent=nf

		nf.Position = UDim2.new(1, 15, 0, 0)
		tw(nf, {Position=UDim2.new(0,0,0,0)}, .32, Enum.EasingStyle.Back)
		tw(prog, {Size=UDim2.new(0,0,0,2)}, dur, Enum.EasingStyle.Linear)
		task.delay(dur, function()
			tw(nf, {Position=UDim2.new(1,15,0,0), BackgroundTransparency=1}, .3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
			task.wait(.35)
			if nf.Parent then nf:Destroy() end
		end)
	end

	-- ══════════════════════════════════════════════════
	-- DIALOG
	-- ══════════════════════════════════════════════════
	function W:Ask(txt, answers, cb)
		answers = answers or {"Да", "Нет"}
		local ov = Instance.new("TextButton")
		ov.BackgroundColor3=Color3.new(0,0,0); ov.BackgroundTransparency=1
		ov.BorderSizePixel=0; ov.Size=UDim2.new(1,0,1,0); ov.Text=""
		ov.AutoButtonColor=false; ov.ZIndex=200; ov.Parent=gui
		tw(ov,{BackgroundTransparency=0.6},.25)

		local dw=IsMobile and 300 or 420; local bh=IsMobile and 42 or 48
		local cols=math.min(#answers,3); local rows=math.ceil(#answers/cols)
		local dh=(IsMobile and 115 or 136)+rows*(bh+8)

		local df = Instance.new("Frame")
		df.BackgroundColor3=Color3.fromRGB(13,13,13); df.BorderSizePixel=0
		df.Size=UDim2.new(0,dw*.8,0,dh*.8); df.Position=UDim2.new(.5,0,.5,0); df.AnchorPoint=Vector2.new(.5,.5)
		df.ZIndex=210; df.ClipsDescendants=true; df.Parent=gui
		corner(df,14); stroke(df,T.Border,1,0.1)
		tw(df,{Size=UDim2.new(0,dw,0,dh)},.38,Enum.EasingStyle.Back)

		local stb = Instance.new("Frame")
		stb.BackgroundColor3=Color3.fromRGB(100,100,100); stb.BorderSizePixel=0
		stb.Size=UDim2.new(1,0,0,2); stb.ZIndex=211; stb.Parent=df
		makeShimmer(stb, 2, 212)

		local qt = Instance.new("TextLabel"); qt.BackgroundTransparency=1
		qt.Size=UDim2.new(1,-30,0,IsMobile and 52 or 66); qt.Position=UDim2.new(0,15,0,IsMobile and 18 or 22)
		qt.Text=txt; qt.TextColor3=T.Text; qt.TextTransparency=1
		qt.TextSize=IsMobile and 13 or 15; qt.FontFace=FM; qt.TextWrapped=true; qt.ZIndex=212; qt.Parent=df
		task.delay(.1,function() tw(qt,{TextTransparency=0},.25) end)

		local function closeAsk(ans)
			tw(df,{Size=UDim2.new(0,dw*.8,0,dh*.8),BackgroundTransparency=.9},.28,Enum.EasingStyle.Back,Enum.EasingDirection.In)
			tw(ov,{BackgroundTransparency=1},.22)
			task.wait(.32)
			if df.Parent then df:Destroy() end; if ov.Parent then ov:Destroy() end
			if cb then pcall(cb,ans) end
		end

		local bw = #answers==1 and (dw-30) or #answers==2 and (dw-30-8)/2 or (dw-30-8*(cols-1))/cols
		local sy  = IsMobile and 84 or 100
		for i,ans in ipairs(answers) do
			local row=(math.ceil(i/cols)-1); local col=(i-1)%cols
			local ab = Instance.new("TextButton")
			ab.BorderSizePixel=0
			ab.Size=UDim2.new(0,bw,0,bh); ab.Position=UDim2.new(0,15+col*(bw+8),0,sy+row*(bh+8))
			ab.Text=ans; ab.TextColor3=T.White; ab.TextSize=IsMobile and 12 or 13; ab.FontFace=i==1 and FB or FM
			ab.AutoButtonColor=false; ab.ZIndex=213; ab.ClipsDescendants=true; ab.Parent=df
			ab.BackgroundColor3 = i==1 and Color3.fromRGB(68,68,68) or Color3.fromRGB(26,26,26)
			corner(ab,9); if i~=1 then stroke(ab,T.Border,1,0.35) end
			ab.BackgroundTransparency=1; ab.TextTransparency=1
			task.delay(.15+i*.06,function() tw(ab,{BackgroundTransparency=0,TextTransparency=0},.22,Enum.EasingStyle.Back) end)
			local origC = i==1 and Color3.fromRGB(68,68,68) or Color3.fromRGB(26,26,26)
			ab.MouseEnter:Connect(function() tw(ab,{BackgroundColor3=Color3.fromRGB(96,96,96)},.12) end)
			ab.MouseLeave:Connect(function() tw(ab,{BackgroundColor3=origC},.12) end)
			ab.MouseButton1Click:Connect(function()
				ripple(ab, IsMobile and ab.AbsolutePosition.X+ab.AbsoluteSize.X/2 or Mouse.X,
				           IsMobile and ab.AbsolutePosition.Y+ab.AbsoluteSize.Y/2 or Mouse.Y)
				task.delay(.1, function() closeAsk(ans) end)
			end)
		end
		ov.MouseButton1Click:Connect(function() closeAsk(nil) end)
	end

	-- ══════════════════════════════════════════════════
	-- VISIBILITY TOGGLE  RightCtrl / F4
	-- ══════════════════════════════════════════════════
	local vis = true
	UserInputService.InputBegan:Connect(function(i, gp)
		if gp then return end
		if i.KeyCode==Enum.KeyCode.RightControl or i.KeyCode==Enum.KeyCode.F4 then
			vis = not vis; main.Visible = vis
		end
	end)

	-- Mobile toggle button → "M"
	if IsMobile then
		local mt = Instance.new("TextButton")
		mt.BackgroundColor3=Color3.fromRGB(20,20,20)
		mt.BorderSizePixel=0
		mt.Size=UDim2.new(0,44,0,44)
		mt.Position=UDim2.new(0,12,0,12)
		mt.Text="M"
		mt.TextColor3=T.Text
		mt.TextSize=16
		mt.FontFace=FB
		mt.ZIndex=999
		mt.Parent=gui
		corner(mt,22)
		stroke(mt, T.Border, 1, 0.3)
		do
			local mg = Instance.new("UIGradient")
			mg.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(22, 22, 22)),
				ColorSequenceKeypoint.new(1, Color3.fromRGB(38, 38, 38)),
			})
			mg.Rotation = 90
			mg.Parent   = mt
		end
		local mtD,mtS,mtP=false,nil,nil
		mt.InputBegan:Connect(function(i)
			if i.UserInputType==Enum.UserInputType.Touch then
				mtD=true; mtS=i.Position; mtP=mt.Position
			end
		end)
		UserInputService.InputChanged:Connect(function(i)
			if mtD and i.UserInputType==Enum.UserInputType.Touch then
				local d=i.Position-mtS
				mt.Position=UDim2.new(mtP.X.Scale,mtP.X.Offset+d.X,mtP.Y.Scale,mtP.Y.Offset+d.Y)
			end
		end)
		UserInputService.InputEnded:Connect(function(i)
			if i.UserInputType==Enum.UserInputType.Touch and mtD then
				mtD=false
				if (i.Position-mtS).Magnitude<10 then
					vis=not vis
					main.Visible=vis
					tw(mt, {BackgroundColor3 = vis and Color3.fromRGB(28,28,28) or Color3.fromRGB(50,50,50)}, .2)
				end
			end
		end)
	end

	-- ── Entrance pop animation ───
	main.Size                = UDim2.new(0, WW * 0.88, 0, WH * 0.88)
	main.BackgroundTransparency = 0.4
	task.defer(function()
		tw(main, {Size=UDim2.new(0,WW,0,WH), BackgroundTransparency=0}, .44, Enum.EasingStyle.Back)
	end)

	return W
end

return Library
