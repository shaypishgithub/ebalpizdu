	pHolder.BackgroundTransparency = 1
	pHolder.Size = UDim2.new(1, 0, 1, 0)
	pHolder.ZIndex = 101
	pHolder.ClipsDescendants = true
	pHolder.Parent = bg

	local pList = {}
	for i = 1, 20 do
		local p = Instance.new("Frame")
		p.BackgroundColor3 = Color3.fromRGB(math.random(80, 255), math.random(80, 255), math.random(80, 255))
		local sz = math.random(2, 5)
		p.Size = UDim2.new(0, sz, 0, sz)
		p.Position = UDim2.new(math.random(), 0, math.random(), 0)
		p.BackgroundTransparency = math.random(50, 85) / 100
		p.ZIndex = 102
		p.Parent = pHolder
		corner(p, 999)
		table.insert(pList, p)
		task.spawn(function()
			while p.Parent do
				tween(p, {
					Position = UDim2.new(math.random(), 0, math.random(), 0),
					BackgroundTransparency = math.random(40, 90) / 100,
				}, math.random(3, 7), Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
				task.wait(math.random(3, 7))
			end
		end)
	end

	local center = Instance.new("Frame")
	center.BackgroundTransparency = 1
	center.Size = UDim2.new(0, IsMobile and 280 or 360, 0, IsMobile and 280 or 340)
	center.Position = UDim2.new(0.5, 0, 0.5, 0)
	center.AnchorPoint = Vector2.new(0.5, 0.5)
	center.ZIndex = 110
	center.Parent = bg

	-- Diamond logo (white/gray)
	local diamond = Instance.new("Frame")
	diamond.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
	diamond.BackgroundTransparency = 0.1
	diamond.Size = UDim2.new(0, 0, 0, 0)
	diamond.Position = UDim2.new(0.5, 0, 0, IsMobile and 50 or 60)
	diamond.AnchorPoint = Vector2.new(0.5, 0.5)
	diamond.Rotation = 45
	diamond.ZIndex = 115
	diamond.Parent = center
	corner(diamond, 14)
	stroke(diamond, Color3.fromRGB(255, 255, 255), 2, 0.2)
	gradient(diamond, 45)

	local dIcon = Instance.new("TextLabel")
	dIcon.BackgroundTransparency = 1
	dIcon.Size = UDim2.new(1, 0, 1, 0)
	dIcon.Text = "◆"
	dIcon.TextColor3 = Color3.new(1, 1, 1)
	dIcon.TextSize = IsMobile and 20 or 26
	dIcon.FontFace = FONT_BOLD
	dIcon.Rotation = -45
	dIcon.ZIndex = 116
	dIcon.Parent = diamond

	local glow = Instance.new("Frame")
	glow.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
	glow.BackgroundTransparency = 0.85
	glow.Size = UDim2.new(0, 0, 0, 0)
	glow.Position = UDim2.new(0.5, 0, 0, IsMobile and 50 or 60)
	glow.AnchorPoint = Vector2.new(0.5, 0.5)
	glow.ZIndex = 111
	glow.Parent = center
	corner(glow, 999)

	local ttl = Instance.new("TextLabel")
	ttl.BackgroundTransparency = 1
	ttl.Size = UDim2.new(1, 0, 0, 40)
	ttl.Position = UDim2.new(0, 0, 0, IsMobile and 100 or 120)
	ttl.Text = title
	ttl.TextColor3 = Theme.Text
	ttl.TextTransparency = 1
	ttl.TextSize = IsMobile and 22 or 28
	ttl.FontFace = FONT_BOLD
	ttl.ZIndex = 115
	ttl.Parent = center

	local sub = Instance.new("TextLabel")
	sub.BackgroundTransparency = 1
	sub.Size = UDim2.new(1, 0, 0, 20)
	sub.Position = UDim2.new(0, 0, 0, IsMobile and 135 or 158)
	sub.Text = "vertelevsepoel"
	sub.TextColor3 = Color3.fromRGB(160, 160, 160)
	sub.TextTransparency = 1
	sub.TextSize = IsMobile and 11 or 13
	sub.FontFace = FONT_REG
	sub.ZIndex = 115
	sub.Parent = center

	local barBG = Instance.new("Frame")
	barBG.BackgroundColor3 = Theme.SliderTrack
	barBG.BackgroundTransparency = 1
	barBG.Size = UDim2.new(0.65, 0, 0, 4)
	barBG.Position = UDim2.new(0.175, 0, 0, IsMobile and 170 or 200)
	barBG.ZIndex = 115
	barBG.Parent = center
	corner(barBG, 2)

	local barFill = Instance.new("Frame")
	barFill.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
	barFill.Size = UDim2.new(0, 0, 1, 0)
	barFill.ZIndex = 116
	barFill.BorderSizePixel = 0
	barFill.Parent = barBG
	corner(barFill, 2)
	gradient(barFill, 0)

	local pct = Instance.new("TextLabel")
	pct.BackgroundTransparency = 1
	pct.Size = UDim2.new(0.65, 0, 0, 18)
	pct.Position = UDim2.new(0.175, 0, 0, IsMobile and 180 or 212)
	pct.Text = "0%"
	pct.TextColor3 = Theme.TextDim
	pct.TextTransparency = 1
	pct.TextSize = IsMobile and 10 or 11
	pct.FontFace = FONT_REG
	pct.ZIndex = 115
	pct.Parent = center

	local statusLbl = Instance.new("TextLabel")
	statusLbl.BackgroundTransparency = 1
	statusLbl.Size = UDim2.new(1, 0, 0, 18)
	statusLbl.Position = UDim2.new(0, 0, 0, IsMobile and 205 or 240)
	statusLbl.Text = ""
	statusLbl.TextColor3 = Theme.TextMuted
	statusLbl.TextTransparency = 1
	statusLbl.TextSize = IsMobile and 9 or 10
	statusLbl.FontFace = FONT_REG
	statusLbl.ZIndex = 115
	statusLbl.Parent = center

	task.spawn(function()
		task.wait(0.2)
		tween(diamond, {Size = UDim2.new(0, IsMobile and 60 or 80, 0, IsMobile and 60 or 80)}, 0.7, Enum.EasingStyle.Back)
		tween(glow,    {Size = UDim2.new(0, IsMobile and 120 or 160, 0, IsMobile and 120 or 160)}, 0.8, Enum.EasingStyle.Back)
		task.wait(0.4)
		tween(ttl,    {TextTransparency = 0}, 0.5)
		task.wait(0.2)
		tween(sub,    {TextTransparency = 0}, 0.4)
		task.wait(0.2)
		tween(barBG,  {BackgroundTransparency = 0}, 0.3)
		tween(pct,    {TextTransparency = 0}, 0.3)
		tween(statusLbl, {TextTransparency = 0}, 0.3)

		task.spawn(function()
			while diamond.Parent do
				tween(diamond, {Rotation = diamond.Rotation + 360}, 6, Enum.EasingStyle.Linear)
				task.wait(6)
			end
		end)

		task.spawn(function()
			while glow.Parent do
				tween(glow, {BackgroundTransparency = 0.75,
					Size = UDim2.new(0, IsMobile and 140 or 180, 0, IsMobile and 140 or 180)},
					1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
				task.wait(1.2)
				if not glow.Parent then break end
				tween(glow, {BackgroundTransparency = 0.88,
					Size = UDim2.new(0, IsMobile and 120 or 160, 0, IsMobile and 120 or 160)},
					1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
				task.wait(1.2)
			end
		end)

		task.wait(0.3)

		local steps = {
			{0.15, "Initializing core...",    0.30},
			{0.30, "Loading framework...",    0.35},
			{0.50, "Preparing engine...",     0.30},
			{0.65, "Connecting services...",  0.40},
			{0.80, "Loading configs...",      0.30},
			{0.92, "Applying settings...",    0.30},
			{1.00, "Ready!",                  0.20},
		}

		for _, s in ipairs(steps) do
			tween(barFill, {Size = UDim2.new(s[1], 0, 1, 0)}, s[3], Enum.EasingStyle.Quad)
			pct.Text = math.floor(s[1] * 100) .. "%"
			statusLbl.Text = s[2]
			task.wait(s[3] + math.random(5, 12) / 100)
		end

		task.wait(0.4)

		tween(diamond,   {BackgroundTransparency = 1}, 0.4)
		tween(glow,      {BackgroundTransparency = 1}, 0.4)
		tween(ttl,       {TextTransparency = 1}, 0.3)
		tween(sub,       {TextTransparency = 1}, 0.3)
		tween(barBG,     {BackgroundTransparency = 1}, 0.3)
		tween(barFill,   {BackgroundTransparency = 1}, 0.3)
		tween(pct,       {TextTransparency = 1}, 0.3)
		tween(statusLbl, {TextTransparency = 1}, 0.3)
		for _, pp in ipairs(pList) do
			if pp.Parent then tween(pp, {BackgroundTransparency = 1}, 0.3) end
		end

		task.wait(0.45)
		if onDone then onDone() end
		tween(bg, {BackgroundTransparency = 1}, 0.5)
		task.wait(0.55)
		if bg.Parent then bg:Destroy() end
	end)
end

