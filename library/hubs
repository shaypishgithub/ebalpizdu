		-- ─── Card factory ─────────────────────────────
		local function makeCard(h)
			local f = Instance.new("Frame")
			f.BackgroundColor3  = T.CardBG
			f.BorderSizePixel   = 0
			f.Size              = UDim2.new(1, 0, 0, h)
			f.LayoutOrder       = TAB.ElCnt
			f.Parent            = sc
			corner(f, 10)
			stroke(f, T.Border, 1, 0.5)
			return f
		end

		local function makeLabel(parent, txt, xOff, col, sz, font)
			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Size     = UDim2.new(1, -(xOff or 14)-10, 1, 0)
			l.Position = UDim2.new(0, xOff or 14, 0, 0)
			l.Text     = txt
			l.TextColor3     = col or T.Text
			l.TextSize       = sz or (IsMobile and 12 or 13)
			l.FontFace       = font or FM
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextYAlignment = Enum.TextYAlignment.Center
			l.TextTruncate   = Enum.TextTruncate.AtEnd
			l.Parent         = parent
			return l
		end

		local function overlayBtn(parent)
			local b = Instance.new("TextButton")
			b.BackgroundTransparency = 1
			b.BorderSizePixel        = 0
			b.Size             = UDim2.new(1, 0, 1, 0)
			b.Text             = ""
			b.AutoButtonColor  = false
			b.ZIndex           = parent.ZIndex + 3
			b.Parent           = parent
			return b
		end

