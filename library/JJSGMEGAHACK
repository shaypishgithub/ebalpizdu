local Players           = game:GetService("Players")
local UserInputService  = game:GetService("UserInputService")
local TweenService      = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

-- ══════════════════════════════════
--  CONFIG
-- ══════════════════════════════════
local CFG = {
    PlatformHeight = 1000,
    PlatformSize   = Vector3.new(18, 2, 18),
    CollectDelay   = 0.12,
    ReturnDelay    = 0.5,
    WalkSpeed      = 80,
    TicketsFolder  = game.Workspace:WaitForChild("Game")
                        :WaitForChild("Effects")
                        :WaitForChild("Tickets"),
}

-- Remote events
local evChar   = ReplicatedStorage:WaitForChild("Events"):FindFirstChild("Character")
local evSpeed  = evChar and evChar:FindFirstChild("SpeedBoost")
local evMove   = evChar and evChar:FindFirstChild("MoveSpeed")
local evInter  = evChar and evChar:FindFirstChild("Interact")
local evPlayer = ReplicatedStorage:WaitForChild("Events"):FindFirstChild("Player")
local evMode   = evPlayer and evPlayer:FindFirstChild("ChangePlayerMode")

-- ══════════════════════════════════
--  STATE
-- ══════════════════════════════════
local STATE = {
    platform   = false,
    farm       = false,
    speed      = false,
    antiDown   = false,
    autoRevive = false,
}

local platform   = nil
local platformCF = nil
local collecting = false
local farmThread = nil

-- ══════════════════════════════════
--  SPEED HOOK  (metamethod)
-- ══════════════════════════════════
local meta = getrawmetatable(game)
setreadonly(meta, false)
local origNamecall = meta.__namecall
meta.__namecall = newcclosure(function(self, ...)
    local args   = { ... }
    local method = getnamecallmethod()
    if tostring(self) == "PassCharacterInfoUnreliable" and method == "FireServer" then
        local data = args[2]
        if STATE.speed and typeof(data) == "table" and typeof(data[2]) == "Vector2int16" then
            data[1] = CFG.WalkSpeed
            args[2] = data
        end
        return origNamecall(self, unpack(args))
    end
    return origNamecall(self, ...)
end)
setreadonly(meta, true)

-- ══════════════════════════════════
--  PLATFORM
-- ══════════════════════════════════
local function spawnPlatform()
    if platform and platform.Parent then platform:Destroy() end
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    local pos = Vector3.new(hrp.Position.X, CFG.PlatformHeight, hrp.Position.Z)
    platform = Instance.new("Part")
    platform.Name         = "CandyFarmPlatform"
    platform.Size         = CFG.PlatformSize
    platform.Color        = Color3.fromRGB(220, 220, 220)
    platform.Material     = Enum.Material.SmoothPlastic
    platform.Anchored     = true
    platform.CanCollide   = true
    platform.CastShadow   = false
    platform.Transparency = 0.25
    platform.CFrame       = CFrame.new(pos)
    platform.Parent       = workspace

    platformCF = CFrame.new(pos + Vector3.new(0, CFG.PlatformSize.Y / 2 + 3.5, 0))
    task.wait(0.1)
    local c = LocalPlayer.Character
    if c and c:FindFirstChild("HumanoidRootPart") then
        c.HumanoidRootPart.CFrame = platformCF
    end
    return true
end

local function removePlatform()
    if platform and platform.Parent then
        platform:Destroy()
        platform = nil
    end
end

-- ══════════════════════════════════
--  FARM LOGIC
-- ══════════════════════════════════
local function goHome()
    for _ = 1, 3 do
        task.wait(0.04)
        local c = LocalPlayer.Character
        if c and c:FindFirstChild("HumanoidRootPart") and platformCF then
            c.HumanoidRootPart.CFrame = platformCF
        end
    end
end

local function farmLoop()
    while STATE.farm do
        collecting = false
        local candies = {}
        for _, d in ipairs(CFG.TicketsFolder:GetDescendants()) do
            if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then
                table.insert(candies, d)
            end
        end
        if #candies > 0 then
            collecting = true
            for _, candy in ipairs(candies) do
                if not STATE.farm then break end
                if candy and candy.Parent then
                    local c = LocalPlayer.Character
                    if c and c:FindFirstChild("HumanoidRootPart") then
                        c.HumanoidRootPart.CFrame = candy.CFrame + Vector3.new(0, 3, 0)
                        task.wait(CFG.CollectDelay)
                    end
                end
            end
            task.wait(CFG.ReturnDelay)
            goHome()
        else
            task.wait(0.2)
        end
    end
    goHome()
end

local function startFarmThread()
    if farmThread then task.cancel(farmThread); farmThread = nil end
    farmThread = task.spawn(farmLoop)
end

-- Реакция на новый тикет
CFG.TicketsFolder.DescendantAdded:Connect(function(d)
    if d:IsA("BasePart") and d.Name == "HumanoidRootPart" and STATE.farm and not collecting then
        task.wait(0.05)
        if d and d.Parent then
            local c = LocalPlayer.Character
            if c and c:FindFirstChild("HumanoidRootPart") then
                c.HumanoidRootPart.CFrame = d.CFrame + Vector3.new(0, 3, 0)
                task.wait(CFG.CollectDelay)
                goHome()
            end
        end
    end
end)

-- ══════════════════════════════════
--  SPEED LOOPS
-- ══════════════════════════════════
task.spawn(function()
    while true do
        task.wait(0.1)
        if STATE.speed then
            local char = LocalPlayer.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then pcall(function() hum.WalkSpeed = CFG.WalkSpeed end) end
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.3)
        if STATE.speed then
            if evSpeed then pcall(function() evSpeed:FireServer(true) end) end
            if evMove  then pcall(function() evMove:FireServer(CFG.WalkSpeed) end) end
        end
    end
end)

-- ══════════════════════════════════
--  ANTI-DOWN + AUTO REVIVE
-- ══════════════════════════════════
task.spawn(function()
    while true do
        task.wait(0.25)
        local myChar = LocalPlayer.Character
        if not myChar then task.wait(1); continue end

        if STATE.antiDown then
            if myChar:GetAttribute("Downed") == true then
                if evMode then pcall(function() evMode:FireServer(true) end) end
            end
        end

        if STATE.autoRevive then
            local myHRP = myChar:FindFirstChild("HumanoidRootPart")
            if myHRP then
                local closest, closestDist = nil, math.huge
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer then
                        local c = p.Character
                        if c and c:GetAttribute("Downed") == true then
                            local hrp = c:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local dist = (myHRP.Position - hrp.Position).Magnitude
                                if dist < closestDist then
                                    closestDist = dist
                                    closest = p
                                end
                            end
                        end
                    end
                end
                if closest and evInter then
                    pcall(function() evInter:FireServer("Revive", true, closest.Name) end)
                end
            end
        end
    end
end)

-- ══════════════════════════════════
--  АВТО-РЕСТОР ПОСЛЕ СМЕРТИ/РЕСПАВНА
-- ══════════════════════════════════
local function onCharacterAdded(char)
    char:WaitForChild("HumanoidRootPart")
    char:WaitForChild("Humanoid")
    task.wait(2)
    if STATE.platform then spawnPlatform() end
    if STATE.farm     then task.wait(0.5); startFarmThread() end
    char:FindFirstChildOfClass("Humanoid").Died:Connect(function()
        if farmThread then task.cancel(farmThread); farmThread = nil end
        collecting = false
        platform   = nil
    end)
end

if LocalPlayer.Character then task.spawn(onCharacterAdded, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

