-- УТИЛИТЫ
local function Tween(obj, props, duration)
    local tweenInfo = TweenInfo.new(duration or Library.Config.AnimationSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
    return TweenService:Create(obj, tweenInfo, props)
end

local function Corner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or Library.Config.CornerRadius
    corner.Parent = parent
end

local function Stroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Library.CurrentTheme.Border
    stroke.Thickness = thickness or Library.Config.StrokeThickness
    stroke.Parent = parent
end

local function Gradient(parent, color1, color2, rotation)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color1),
        ColorSequenceKeypoint.new(1, color2)
    })
    gradient.Rotation = rotation or 90
    gradient.Parent = parent
end

