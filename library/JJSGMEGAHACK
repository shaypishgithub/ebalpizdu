-- ── TAB: FARM ──────────────────────────────────────────
local tabFarm = window:CreateTab("Farm")

tabFarm:CreateLabel("── Platform & Collect ──")

tabFarm:CreateToggle("Auto Platform  (Y=1000)", false, function(v)
    STATE.platform = v
    if v then
        spawnPlatform()
        window:Notify("Platform spawned at Y=1000", 3)
    else
        removePlatform()
        window:Notify("Platform removed", 2)
    end
end)

tabFarm:CreateToggle("Auto Farm  (collect candies)", false, function(v)
    STATE.farm = v
    if v then
        if STATE.platform and (not platform or not platform.Parent) then
            spawnPlatform()
        end
        startFarmThread()
        window:Notify("Auto Farm started!", 3)
    else
        if farmThread then task.cancel(farmThread); farmThread = nil end
        window:Notify("Auto Farm stopped", 2)
    end
end)

tabFarm:CreateButton("Spawn Platform Now", function()
    spawnPlatform()
    window:Notify("Platform spawned!", 2)
end)

tabFarm:CreateButton("Remove Platform", function()
    removePlatform()
    window:Notify("Platform removed", 2)
end)

tabFarm:CreateButton("Teleport to Platform", function()
    if platformCF then
        local c = LocalPlayer.Character
        if c and c:FindFirstChild("HumanoidRootPart") then
            c.HumanoidRootPart.CFrame = platformCF
        end
    else
        window:Notify("No platform active!", 2)
    end
end)

-- ── TAB: SPEED ─────────────────────────────────────────
local tabSpeed = window:CreateTab("Speed")

tabSpeed:CreateLabel("── Speed Hack ──")

tabSpeed:CreateToggle("Speed Hack", false, function(v)
    STATE.speed = v
    if v then
        window:Notify("Speed ON — " .. CFG.WalkSpeed, 2)
    else
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then pcall(function() hum.WalkSpeed = 16 end) end
        end
        window:Notify("Speed OFF — restored to 16", 2)
    end
end)

tabSpeed:CreateSlider("WalkSpeed", 16, 200, 80, function(v)
    CFG.WalkSpeed = v
end)

-- ── TAB: COMBAT ────────────────────────────────────────
local tabCombat = window:CreateTab("Combat")

tabCombat:CreateLabel("── Anti-Down & Revive ──")

tabCombat:CreateToggle("Anti-Down  (auto stand)", false, function(v)
    STATE.antiDown = v
    window:Notify(v and "Anti-Down ON" or "Anti-Down OFF", 2)
end)

tabCombat:CreateToggle("Auto Revive  (teammates)", false, function(v)
    STATE.autoRevive = v
    window:Notify(v and "Auto Revive ON" or "Auto Revive OFF", 2)
end)

-- ── TAB: SETTINGS ──────────────────────────────────────
local tabSet = window:CreateTab("Settings")

tabSet:CreateLabel("── Farm Settings ──")

tabSet:CreateSlider("Collect Delay (ms × 100)", 1, 20, 1, function(v)
    CFG.CollectDelay = v * 0.01  -- 0.01 .. 0.20 сек
end)

tabSet:CreateSlider("Return Delay (ms × 100)", 1, 20, 5, function(v)
    CFG.ReturnDelay = v * 0.1
end)

tabSet:CreateSlider("Platform Height", 100, 2000, 1000, function(v)
    CFG.PlatformHeight = v
end)

tabSet:CreateButton("Disable All & Remove Platform", function()
    window:Ask("Disable everything?", {"Yes", "No"}, function(ans)
        if ans == "Yes" then
            STATE.platform   = false
            STATE.farm       = false
            STATE.speed      = false
            STATE.antiDown   = false
            STATE.autoRevive = false
            if farmThread then task.cancel(farmThread); farmThread = nil end
            removePlatform()
            collecting = false
            local char = LocalPlayer.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then pcall(function() hum.WalkSpeed = 16 end) end
            end
            window:Notify("All features disabled", 3)
        end
    end)
end)

