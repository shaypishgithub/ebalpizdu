        sliderKnob.BackgroundColor3 = Library.CurrentTheme.Accent
        sliderKnob.BorderSizePixel = 0
        sliderKnob.Size = UDim2.new(0, 16, 0, 16)
        sliderKnob.Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
        sliderKnob.Parent = container
        
        Corner(sliderKnob)
        Stroke(sliderKnob, Library.CurrentTheme.Accent, 1)
        
        local currentValue = default
        
        local function updateSlider(pos)
            local size = sliderBg.AbsoluteSize.X
            local relativePos = math.max(0, math.min(pos - sliderBg.AbsolutePosition.X, size))
            local percentage = relativePos / size
            currentValue = math.floor(min + percentage * (max - min))
            
            Tween(sliderFill, {Size = UDim2.new(percentage, 0, 1, 0)}, 0):Play()
            Tween(sliderKnob, {Position = UDim2.new(percentage, -8, 0.5, -8)}, 0):Play()
            
            valueLabel.Text = tostring(currentValue)
            if config.Callback then config.Callback(currentValue) end
        end
        
        sliderBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                updateSlider(Players.LocalPlayer:GetMouse().X)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                if sliderBg.Parent then
                    updateSlider(Players.LocalPlayer:GetMouse().X)
                end
            end
        end)
        
        return container
    end
    
