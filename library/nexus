-- ── Palette ───────────────────────────────────────────────────────────
local COLORS = {
    Black      = Color3.fromRGB(8,  8,  10),
    Dark       = Color3.fromRGB(18, 18, 22),
    Dark2      = Color3.fromRGB(26, 26, 32),
    Mid        = Color3.fromRGB(40, 40, 50),
    Mid2       = Color3.fromRGB(60, 60, 72),
    Grey       = Color3.fromRGB(100,100,115),
    LightGrey  = Color3.fromRGB(160,160,175),
    White      = Color3.fromRGB(235,235,240),
    PureWhite  = Color3.fromRGB(255,255,255),
    Accent     = Color3.fromRGB(200,200,215),
    Shimmer1   = Color3.fromRGB(255,255,255),
    Shimmer2   = Color3.fromRGB(180,180,195),
}

-- ── Utility ───────────────────────────────────────────────────────────
local function Tween(obj, info, props)
    TweenService:Create(obj, info, props):Play()
end

local function QuickTween(obj, t, props)
    Tween(obj, TweenInfo.new(t, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props)
end

local function MakeShadow(parent, size)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "Shadow"
    shadow.AnchorPoint = Vector2.new(0.5, 0.5)
    shadow.BackgroundTransparency = 1
    shadow.Position = UDim2.new(0.5, 0, 0.5, 8)
    shadow.Size = UDim2.new(1, size or 40, 1, size or 40)
    shadow.ZIndex = parent.ZIndex - 1
    shadow.Image = "rbxassetid://6014261993"
    shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    shadow.ImageTransparency = 0.5
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(49, 49, 450, 450)
    shadow.Parent = parent
    return shadow
end

local function MakeGradient(parent, rotation, c0, c1)
    local g = Instance.new("UIGradient")
    g.Rotation = rotation or 90
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   c0 or COLORS.Dark),
        ColorSequenceKeypoint.new(0.5, COLORS.Mid),
        ColorSequenceKeypoint.new(1,   c1 or COLORS.Dark2),
    })
    g.Parent = parent
    return g
end

local function MakeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function MakeStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or COLORS.Mid2
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

-- ── Shimmer Animation ─────────────────────────────────────────────────
local function AddShimmer(frame)
    local shimmerFrame = Instance.new("Frame")
    shimmerFrame.Name = "Shimmer"
    shimmerFrame.Size = UDim2.new(0.4, 0, 1, 0)
    shimmerFrame.Position = UDim2.new(-0.5, 0, 0, 0)
    shimmerFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    shimmerFrame.BackgroundTransparency = 1
    shimmerFrame.ZIndex = frame.ZIndex + 5
    shimmerFrame.ClipsDescendants = false
    shimmerFrame.Parent = frame

    local shimmerGrad = Instance.new("UIGradient")
    shimmerGrad.Rotation = 15
    shimmerGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(255,255,255)),
    })
    shimmerGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0,   1),
        NumberSequenceKeypoint.new(0.4, 0.75),
        NumberSequenceKeypoint.new(0.5, 0.6),
        NumberSequenceKeypoint.new(0.6, 0.75),
        NumberSequenceKeypoint.new(1,   1),
    })
    shimmerGrad.Parent = shimmerFrame

    local function runShimmer()
        shimmerFrame.Position = UDim2.new(-0.5, 0, 0, 0)
        QuickTween(shimmerFrame, 1.8, {Position = UDim2.new(1.2, 0, 0, 0)})
        task.wait(1.8)
        task.wait(math.random(10, 25) / 10)
        if shimmerFrame.Parent then
            runShimmer()
        end
    end

    task.spawn(runShimmer)
    return shimmerFrame
end

-- ── Pulse Glow ────────────────────────────────────────────────────────
local function AddPulseGlow(frame)
    local glow = Instance.new("ImageLabel")
    glow.Name = "Glow"
    glow.AnchorPoint = Vector2.new(0.5, 0.5)
    glow.BackgroundTransparency = 1
    glow.Position = UDim2.new(0.5, 0, 0.5, 0)
    glow.Size = UDim2.new(1, 60, 1, 60)
    glow.ZIndex = frame.ZIndex - 1
    glow.Image = "rbxassetid://5028857084"
    glow.ImageColor3 = COLORS.LightGrey
    glow.ImageTransparency = 0.85
    glow.Parent = frame

    local function pulse()
        QuickTween(glow, 1.5, {ImageTransparency = 0.6, Size = UDim2.new(1, 80, 1, 80)})
        task.wait(1.5)
        QuickTween(glow, 1.5, {ImageTransparency = 0.9, Size = UDim2.new(1, 50, 1, 50)})
        task.wait(1.5)
        if glow.Parent then pulse() end
    end
    task.spawn(pulse)
    return glow
end

