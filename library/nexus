local NexusUI = {}
NexusUI.__index = NexusUI

local Players          = game:GetService("Players")
local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui          = game:GetService("CoreGui")

local LP = Players.LocalPlayer

-- Palette
local C = {
    Black     = Color3.fromRGB(8,   8,   10),
    Dark      = Color3.fromRGB(18,  18,  22),
    Dark2     = Color3.fromRGB(26,  26,  32),
    Mid       = Color3.fromRGB(40,  40,  50),
    Mid2      = Color3.fromRGB(60,  60,  72),
    Grey      = Color3.fromRGB(100, 100, 115),
    LightGrey = Color3.fromRGB(160, 160, 175),
    White     = Color3.fromRGB(235, 235, 240),
    Pure      = Color3.fromRGB(255, 255, 255),
}

-- Helpers
local function Tween(obj, t, props, style)
    TweenService:Create(obj,
        TweenInfo.new(t, style or Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        props):Play()
end

local function Corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
end

local function Stroke(p, col, w)
    local s = Instance.new("UIStroke")
    s.Color = col or C.Mid2
    s.Thickness = w or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p
end

local function Gradient(p, rot, a, b)
    local g = Instance.new("UIGradient")
    g.Rotation = rot or 90
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   a or C.Dark),
        ColorSequenceKeypoint.new(0.5, C.Mid),
        ColorSequenceKeypoint.new(1,   b or C.Dark2),
    })
    g.Parent = p
end

-- ── Open/Close Toggle Button ──────────────────────────────────────────
local function MakeToggleButton(screenGui, mainFrame, size)
    local btn = Instance.new("TextButton")
    btn.Name        = "NexusToggle"
    btn.Size        = UDim2.fromOffset(110, 34)
    btn.Position    = UDim2.new(0, 16, 1, -56)
    btn.BackgroundColor3 = C.Dark
    btn.Text        = "Open Menu"
    btn.TextColor3  = C.White
    btn.TextSize    = 13
    btn.Font        = Enum.Font.GothamBold
    btn.ZIndex      = 100
    btn.Parent      = screenGui
    Corner(btn, 8)
    Stroke(btn, C.Mid2, 1)
    Gradient(btn, 90, C.Black, C.Mid)

    local open = false

    -- Animate gradient shimmer on the button
    local shimmerActive = true
    task.spawn(function()
        while shimmerActive and btn.Parent do
            Tween(btn, 1.2, {TextColor3 = C.Pure})
            task.wait(1.2)
            Tween(btn, 1.2, {TextColor3 = C.LightGrey})
            task.wait(1.2)
        end
    end)

    btn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            btn.Text = "Close Menu"
            Tween(btn, 0.2, {BackgroundColor3 = C.Mid})
            Tween(mainFrame, 0.4, {Size = size, BackgroundTransparency = 0})
        else
            btn.Text = "Open Menu"
            Tween(btn, 0.2, {BackgroundColor3 = C.Dark})
            Tween(mainFrame, 0.35, {Size = UDim2.fromOffset(0, 0), BackgroundTransparency = 1})
        end
    end)

    -- Mobile: TouchTap
    btn.Activated:Connect(function() end)

    return btn
end

-- ═════════════════════════════════════════════════════════════════
--  CreateWindow
-- ═════════════════════════════════════════════════════════════════
function NexusUI:CreateWindow(opts)
    opts = opts or {}
    local Title    = opts.Title    or "NexusUI"
    local SubTitle = opts.SubTitle or "v2.0"
    local Size     = opts.Size     or UDim2.new(0, 560, 0, 400)

    local Win = {}

    -- ScreenGui
    local SG = Instance.new("ScreenGui")
    SG.Name          = "NexusUI"
    SG.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    SG.ResetOnSpawn  = false
    SG.IgnoreGuiInset = true
    pcall(function() SG.Parent = CoreGui end)
    if not SG.Parent then SG.Parent = LP:WaitForChild("PlayerGui") end

    -- Main Frame (hidden by default)
    local Main = Instance.new("Frame")
    Main.Name               = "Main"
    Main.AnchorPoint        = Vector2.new(0.5, 0.5)
    Main.Position           = UDim2.new(0.5, 0, 0.5, 0)
    Main.Size               = UDim2.fromOffset(0, 0)
    Main.BackgroundColor3   = C.Dark
    Main.BackgroundTransparency = 1
    Main.BorderSizePixel    = 0
    Main.ZIndex             = 10
    Main.ClipsDescendants   = true
    Main.Parent             = SG
    Corner(Main, 12)
    Gradient(Main, 145, C.Black, C.Dark2)
    Stroke(Main, C.Mid2, 1)

    -- Open/Close button
    MakeToggleButton(SG, Main, Size)

    -- Clip inner content
    local Clip = Instance.new("Frame")
    Clip.Size = UDim2.new(1,0,1,0)
    Clip.BackgroundTransparency = 1
    Clip.ZIndex = 10
    Clip.ClipsDescendants = true
    Clip.Parent = Main

    -- ── TopBar ────────────────────────────────────────────────────
    local Top = Instance.new("Frame")
    Top.Size             = UDim2.new(1,0,0,48)
    Top.BackgroundColor3 = C.Black
    Top.BorderSizePixel  = 0
    Top.ZIndex           = 12
    Top.Parent           = Clip
    Gradient(Top, 90, C.Black, C.Dark)

    -- Divider under topbar
