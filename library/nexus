        -- Notify (toast inside window)
        function Tab:Notify(notOptions)
            notOptions = notOptions or {}
            NexusUI.Notify(notOptions)
        end

        return Tab
    end

    -- ── Global Notify ──────────────────────────────────────────────
    function NexusUI.Notify(notOptions)
        notOptions = notOptions or {}
        local Title   = notOptions.Title   or "Notification"
        local Desc    = notOptions.Description or ""
        local Duration= notOptions.Duration or 4

        local NotifHolder = ScreenGui:FindFirstChild("NotifHolder")
        if not NotifHolder then
            NotifHolder = Instance.new("Frame")
            NotifHolder.Name = "NotifHolder"
            NotifHolder.Size = UDim2.new(0,280,1,0)
            NotifHolder.Position = UDim2.new(1,-295,0,0)
            NotifHolder.BackgroundTransparency = 1
            NotifHolder.ZIndex = 50
            NotifHolder.Parent = ScreenGui

            local NL = Instance.new("UIListLayout")
            NL.Padding = UDim.new(0,8)
            NL.SortOrder = Enum.SortOrder.LayoutOrder
            NL.VerticalAlignment = Enum.VerticalAlignment.Bottom
            NL.Parent = NotifHolder

            local NP = Instance.new("UIPadding")
            NP.PaddingBottom = UDim.new(0,16)
            NP.Parent = NotifHolder
        end

        local N = Instance.new("Frame")
        N.Size = UDim2.new(1,0,0,0)
        N.BackgroundColor3 = COLORS.Dark
        N.BorderSizePixel = 0
        N.BackgroundTransparency = 1
        N.ZIndex = 51
        N.ClipsDescendants = true
        N.Parent = NotifHolder
        MakeCorner(N, 10)
        MakeStroke(N, COLORS.Mid2, 1)
        MakeGradient(N, 135, COLORS.Dark, COLORS.Mid)
        AddShimmer(N)

        local NT = Instance.new("TextLabel")
        NT.Size = UDim2.new(1,-16,0,20)
        NT.Position = UDim2.new(0,12,0,10)
        NT.BackgroundTransparency = 1
        NT.Text = Title
        NT.TextColor3 = COLORS.White
        NT.TextSize = 13
        NT.Font = Enum.Font.GothamBold
        NT.TextXAlignment = Enum.TextXAlignment.Left
        NT.ZIndex = 52
        NT.Parent = N

        local ND = Instance.new("TextLabel")
        ND.Size = UDim2.new(1,-16,0,30)
        ND.Position = UDim2.new(0,12,0,32)
        ND.BackgroundTransparency = 1
        ND.Text = Desc
        ND.TextColor3 = COLORS.Grey
        ND.TextSize = 11
        ND.Font = Enum.Font.Gotham
        ND.TextWrapped = true
        ND.TextXAlignment = Enum.TextXAlignment.Left
        ND.ZIndex = 52
        ND.Parent = N

        local ProgressBg = Instance.new("Frame")
        ProgressBg.Size = UDim2.new(1,-24,0,2)
        ProgressBg.Position = UDim2.new(0,12,1,-10)
        ProgressBg.BackgroundColor3 = COLORS.Mid
        ProgressBg.BorderSizePixel = 0
        ProgressBg.ZIndex = 53
        ProgressBg.Parent = N
        MakeCorner(ProgressBg, 1)

        local ProgressFill = Instance.new("Frame")
        ProgressFill.Size = UDim2.new(1,0,1,0)
        ProgressFill.BackgroundColor3 = COLORS.White
        ProgressFill.BorderSizePixel = 0
        ProgressFill.ZIndex = 54
        ProgressFill.Parent = ProgressBg
        MakeCorner(ProgressFill, 1)

        -- animate in
        QuickTween(N, 0.3, {Size = UDim2.new(1,0,0,76), BackgroundTransparency = 0})
        Tween(ProgressFill, TweenInfo.new(Duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0,0,1,0)})

        task.delay(Duration, function()
            QuickTween(N, 0.3, {Size = UDim2.new(1,0,0,0), BackgroundTransparency = 1})
            task.delay(0.35, function() N:Destroy() end)
        end)
    end

    return Window
end

return NexusUI
