local LP   = Players.LocalPlayer
local PGui = LP:WaitForChild("PlayerGui")

-- ── Palette ──────────────────────────────────────────────────────────
local C = {
    Black  = Color3.fromRGB(8,   8,  10),
    Dark   = Color3.fromRGB(18,  18,  22),
    Dark2  = Color3.fromRGB(26,  26,  32),
    Mid    = Color3.fromRGB(40,  40,  50),
    Mid2   = Color3.fromRGB(60,  60,  72),
    Grey   = Color3.fromRGB(100,100,115),
    LGrey  = Color3.fromRGB(160,160,175),
    White  = Color3.fromRGB(235,235,240),
    Pure   = Color3.fromRGB(255,255,255),
}

-- ── Helpers ───────────────────────────────────────────────────────────
local function QT(obj, t, props)
    TweenService:Create(obj,
        TweenInfo.new(t, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        props):Play()
end

local function Corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
end

local function Stroke(p, col, th)
    local s = Instance.new("UIStroke")
    s.Color = col or C.Mid2
    s.Thickness = th or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p
    return s
end

local function Gradient(p, rot, a, b)
    local g = Instance.new("UIGradient")
    g.Rotation = rot or 90
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   a or C.Dark),
        ColorSequenceKeypoint.new(0.5, C.Mid),
        ColorSequenceKeypoint.new(1,   b or C.Dark2),
    })
    g.Parent = p
    return g
end

local function Shadow(p)
    local s = Instance.new("ImageLabel")
    s.AnchorPoint        = Vector2.new(0.5, 0.5)
    s.BackgroundTransparency = 1
    s.Position           = UDim2.new(0.5, 0, 0.5, 8)
    s.Size               = UDim2.new(1, 50, 1, 50)
    s.ZIndex             = p.ZIndex - 1
    s.Image              = "rbxassetid://6014261993"
    s.ImageColor3        = Color3.new(0, 0, 0)
    s.ImageTransparency  = 0.45
    s.ScaleType          = Enum.ScaleType.Slice
    s.SliceCenter        = Rect.new(49, 49, 450, 450)
    s.Parent             = p
end

local function Shimmer(f)
    local sf = Instance.new("Frame")
    sf.Size                  = UDim2.new(0.4, 0, 1, 0)
    sf.Position              = UDim2.new(-0.5, 0, 0, 0)
    sf.BackgroundColor3      = C.Pure
    sf.BackgroundTransparency = 1
    sf.ZIndex                = f.ZIndex + 5
    sf.ClipsDescendants      = false
    sf.Parent                = f
    local sg = Instance.new("UIGradient")
    sg.Rotation = 15
    sg.Color = ColorSequence.new(C.Pure, C.Pure)
    sg.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0,    1),
        NumberSequenceKeypoint.new(0.45, 0.7),
        NumberSequenceKeypoint.new(0.5,  0.55),
        NumberSequenceKeypoint.new(0.55, 0.7),
        NumberSequenceKeypoint.new(1,    1),
    })
    sg.Parent = sf
    local function run()
        sf.Position = UDim2.new(-0.5, 0, 0, 0)
        QT(sf, 1.8, { Position = UDim2.new(1.2, 0, 0, 0) })
        task.wait(1.8 + math.random(10, 28) / 10)
        if sf.Parent then run() end
    end
    task.spawn(run)
end

