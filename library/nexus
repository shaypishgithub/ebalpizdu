    ToggleBtn.TouchTap:Connect(function()
        guiOpen = not guiOpen
        if guiOpen then
            Main.Visible = true
            QT(Main, 0.35, { Size = Size, BackgroundTransparency = 0 })
            ToggleBtn.Text = "✕  Close"
