            Knob.BackgroundColor3 = val and C.Dark or C.LGrey
            Knob.BorderSizePixel  = 0
            Knob.ZIndex           = 15
            Knob.Parent           = Track
            Corner(Knob, 6)

            local Clk = Instance.new("TextButton")
            Clk.Size             = UDim2.new(1,0,1,0)
            Clk.BackgroundTransparency = 1
            Clk.Text             = ""
            Clk.ZIndex           = 16
            Clk.Parent           = Row

            local function flip()
                val = not val
                QT(Track, 0.2, { BackgroundColor3 = val and C.White or C.Mid })
                QT(Knob,  0.2, {
                    Position       = val and UDim2.new(1,-15,0.5,-6) or UDim2.new(0,3,0.5,-6),
                    BackgroundColor3 = val and C.Dark or C.LGrey,
                })
                if o.Callback then pcall(o.Callback, val) end
            end
            Clk.MouseButton1Click:Connect(flip)
            Clk.TouchTap:Connect(flip)

            return {
                Set = function(_, v) val = v flip() end,
                Get = function(_) return val end,
            }
        end

        -- ── Slider ────────────────────────────────────────────────────
        function T:Slider(o)
            o = o or {}
            local Min = o.Min or 0
            local Max = o.Max or 100
            local val = math.clamp(o.Default or Min, Min, Max)

            local Con = Instance.new("Frame")
            Con.Size             = UDim2.new(1,0,0,48)
            Con.BackgroundColor3 = C.Dark2
            Con.BorderSizePixel  = 0
            Con.ZIndex           = 13
            Con.LayoutOrder      = N()
            Con.Parent           = Page
            Corner(Con, 8)
            Stroke(Con, C.Mid, 1)
            Gradient(Con, 90, C.Dark2, C.Mid)

            local SL = Instance.new("TextLabel")
            SL.Size               = UDim2.new(1,-58,0,18)
            SL.Position           = UDim2.new(0,12,0,5)
            SL.BackgroundTransparency = 1
            SL.Text               = o.Name or "Slider"
            SL.TextColor3         = C.White
            SL.TextSize           = 12
            SL.Font               = Enum.Font.Gotham
            SL.TextXAlignment     = Enum.TextXAlignment.Left
            SL.ZIndex             = 14
            SL.Parent             = Con

            local VL = Instance.new("TextLabel")
            VL.Size               = UDim2.new(0,46,0,18)
            VL.Position           = UDim2.new(1,-58,0,5)
            VL.BackgroundTransparency = 1
            VL.Text               = tostring(val)
            VL.TextColor3         = C.LGrey
            VL.TextSize           = 11
            VL.Font               = Enum.Font.GothamBold
            VL.TextXAlignment     = Enum.TextXAlignment.Right
            VL.ZIndex             = 14
            VL.Parent             = Con

            local Trk = Instance.new("Frame")
            Trk.Size             = UDim2.new(1,-24,0,4)
            Trk.Position         = UDim2.new(0,12,1,-14)
            Trk.BackgroundColor3 = C.Mid
            Trk.BorderSizePixel  = 0
            Trk.ZIndex           = 14
            Trk.Parent           = Con
            Corner(Trk, 2)

            local Fill = Instance.new("Frame")
            Fill.Size             = UDim2.new((val-Min)/(Max-Min),0,1,0)
            Fill.BackgroundColor3 = C.White
            Fill.BorderSizePixel  = 0
            Fill.ZIndex           = 15
            Fill.Parent           = Trk
            Corner(Fill, 2)
            Gradient(Fill, 0, C.Mid2, C.White)

            local Knob2 = Instance.new("Frame")
            Knob2.Size             = UDim2.fromOffset(12,12)
            Knob2.AnchorPoint      = Vector2.new(0.5,0.5)
            Knob2.Position         = UDim2.new((val-Min)/(Max-Min),0,0.5,0)
            Knob2.BackgroundColor3 = C.Pure
            Knob2.BorderSizePixel  = 0
            Knob2.ZIndex           = 16
            Knob2.Parent           = Trk
            Corner(Knob2, 6)

            local function update(x)
                local rel = math.clamp((x - Trk.AbsolutePosition.X) / Trk.AbsoluteSize.X, 0, 1)
                val = math.round(Min + (Max - Min) * rel)
                VL.Text       = tostring(val)
                Fill.Size     = UDim2.new(rel,0,1,0)
                Knob2.Position = UDim2.new(rel,0,0.5,0)
                if o.Callback then pcall(o.Callback, val) end
            end

            local dragging2 = false
            Trk.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    dragging2 = true
                    update(inp.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    dragging2 = false
                end
            end)
            UserInputService.InputChanged:Connect(function(inp)
                if dragging2 and (
                    inp.UserInputType == Enum.UserInputType.MouseMovement or
                    inp.UserInputType == Enum.UserInputType.Touch) then
                    update(inp.Position.X)
                end
            end)

            return {
                Set = function(_, v)
                    v = math.clamp(v, Min, Max)
                    val = v
                    local rel = (v-Min)/(Max-Min)
                    VL.Text       = tostring(v)
                    Fill.Size     = UDim2.new(rel,0,1,0)
                    Knob2.Position = UDim2.new(rel,0,0.5,0)
                end,
                Get = function(_) return val end,
            }
        end

        -- ── Label ─────────────────────────────────────────────────────
        function T:Label(text)
            local L = Instance.new("TextLabel")
            L.Size               = UDim2.new(1,0,0,20)
            L.BackgroundTransparency = 1
            L.Text               = text or ""
            L.TextColor3         = C.Grey
            L.TextSize           = 11
            L.Font               = Enum.Font.Gotham
            L.TextXAlignment     = Enum.TextXAlignment.Left
            L.ZIndex             = 13
            L.LayoutOrder        = N()
            L.Parent             = Page
            local lp = Instance.new("UIPadding")
            lp.PaddingLeft = UDim.new(0,4)
            lp.Parent = L
        end

        -- ── Section ───────────────────────────────────────────────────
        function T:Section(name)
            local S = Instance.new("Frame")
            S.Size               = UDim2.new(1,0,0,22)
            S.BackgroundTransparency = 1
            S.LayoutOrder        = N()
            S.Parent             = Page

            local line = Instance.new("Frame")
            line.Size             = UDim2.new(1,0,0,1)
            line.Position         = UDim2.new(0,0,0.5,0)
            line.BackgroundColor3 = C.Mid
            line.BorderSizePixel  = 0
            line.Parent           = S
            local lg = Instance.new("UIGradient")
            lg.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,   C.Dark),
                ColorSequenceKeypoint.new(0.4, C.Mid2),
                ColorSequenceKeypoint.new(1,   C.Dark),
            })
            lg.Parent = line

            local sLbl = Instance.new("TextLabel")
            sLbl.Size               = UDim2.new(0,0,1,0)
            sLbl.AutomaticSize      = Enum.AutomaticSize.X
            sLbl.AnchorPoint        = Vector2.new(0.5,0)
            sLbl.Position           = UDim2.new(0.5,0,0,0)
            sLbl.BackgroundColor3   = C.Dark2
            sLbl.BorderSizePixel    = 0
            sLbl.Text               = "  " .. name .. "  "
            sLbl.TextColor3         = C.LGrey
            sLbl.TextSize           = 10
            sLbl.Font               = Enum.Font.GothamBold
            sLbl.ZIndex             = 13
            sLbl.Parent             = S
        end

        return T
    end

    -- ── Notify ─────────────────────────────────────────────────────────
    function Win:Notify(o)
        o = o or {}
        local Title2 = o.Title or "Notification"
        local Desc   = o.Description or ""
        local Dur    = o.Duration or 4

        local NH = SG:FindFirstChild("NH")
        if not NH then
            NH = Instance.new("Frame")
            NH.Name               = "NH"
            NH.Size               = UDim2.new(0,270,1,0)
            NH.Position           = UDim2.new(1,-285,0,0)
            NH.BackgroundTransparency = 1
            NH.ZIndex             = 50
            NH.Parent             = SG
            local nl = Instance.new("UIListLayout")
            nl.Padding            = UDim.new(0,8)
            nl.VerticalAlignment  = Enum.VerticalAlignment.Bottom
            nl.Parent             = NH
            local np = Instance.new("UIPadding")
            np.PaddingBottom = UDim.new(0,16)
            np.Parent        = NH
        end

        local N2 = Instance.new("Frame")
        N2.Size               = UDim2.new(1,0,0,0)
        N2.BackgroundColor3   = C.Dark
        N2.BackgroundTransparency = 1
        N2.BorderSizePixel    = 0
        N2.ZIndex             = 51
        N2.ClipsDescendants   = true
        N2.Parent             = NH
        Corner(N2, 10)
        Stroke(N2, C.Mid2, 1)
        Gradient(N2, 135, C.Dark, C.Mid)
        Shimmer(N2)

        local NT = Instance.new("TextLabel")
        NT.Size               = UDim2.new(1,-16,0,18)
        NT.Position           = UDim2.new(0,12,0,8)
        NT.BackgroundTransparency = 1
        NT.Text               = Title2
        NT.TextColor3         = C.White
        NT.TextSize           = 12
        NT.Font               = Enum.Font.GothamBold
        NT.TextXAlignment     = Enum.TextXAlignment.Left
        NT.ZIndex             = 52
        NT.Parent             = N2

        local ND = Instance.new("TextLabel")
        ND.Size               = UDim2.new(1,-16,0,28)
        ND.Position           = UDim2.new(0,12,0,28)
        ND.BackgroundTransparency = 1
        ND.Text               = Desc
        ND.TextColor3         = C.Grey
        ND.TextSize           = 10
        ND.Font               = Enum.Font.Gotham
        ND.TextWrapped        = true
        ND.TextXAlignment     = Enum.TextXAlignment.Left
        ND.ZIndex             = 52
        ND.Parent             = N2

        local PBg = Instance.new("Frame")
        PBg.Size              = UDim2.new(1,-24,0,2)
        PBg.Position          = UDim2.new(0,12,1,-8)
        PBg.BackgroundColor3  = C.Mid
        PBg.BorderSizePixel   = 0
        PBg.ZIndex            = 53
        PBg.Parent            = N2
        Corner(PBg, 1)

        local PFill = Instance.new("Frame")
        PFill.Size            = UDim2.new(1,0,1,0)
        PFill.BackgroundColor3 = C.White
        PFill.BorderSizePixel = 0
        PFill.ZIndex          = 54
        PFill.Parent          = PBg
        Corner(PFill, 1)

        QT(N2, 0.3, { Size = UDim2.new(1,0,0,68), BackgroundTransparency = 0 })
        TweenService:Create(PFill,
            TweenInfo.new(Dur, Enum.EasingStyle.Linear),
            { Size = UDim2.new(0,0,1,0) }):Play()

        task.delay(Dur, function()
            QT(N2, 0.3, { Size = UDim2.new(1,0,0,0), BackgroundTransparency = 1 })
            task.delay(0.35, function() N2:Destroy() end)
        end)
    end

    return Win
end

return NexusUI

