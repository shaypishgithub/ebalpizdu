    tGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   C.Grey),
        ColorSequenceKeypoint.new(0.5, C.White),
        ColorSequenceKeypoint.new(1,   C.Grey),
    })
    tGrad.Parent = tStroke
    Gradient(ToggleFrame, 90, C.Black, C.Dark2)
    Shimmer(ToggleFrame)

    -- Animate the border gradient rotation
