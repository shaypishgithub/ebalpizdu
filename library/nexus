    Main.ClipsDescendants = true
    Main.Parent = ScreenGui

    MakeCorner(Main, 12)
    MakeGradient(Main, 145, COLORS.Black, COLORS.Dark2)
    MakeShadow(Main, 60)

    local mainStroke = MakeStroke(Main, COLORS.Mid2, 1)
    local borderGrad = Instance.new("UIGradient")
    borderGrad.Rotation = 145
    borderGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   COLORS.Grey),
        ColorSequenceKeypoint.new(0.5, COLORS.White),
        ColorSequenceKeypoint.new(1,   COLORS.Mid2),
    })
    borderGrad.Parent = mainStroke

    -- Clip inner content
    local ClipFrame = Instance.new("Frame")
