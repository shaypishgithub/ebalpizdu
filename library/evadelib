    -- ══════════════════════════════════════════════════════════════════════

    -- ── Кнопка ─────────────────────────────────────────────────────────────
    function Window:AddButton(cfg)
        cfg = cfg or {}

        local btn = Instance.new("TextButton")
        btn.Name             = cfg.Name or "Button"
        btn.BackgroundColor3 = Library.CurrentTheme.Accent
        btn.TextColor3       = Library.CurrentTheme.Text
        btn.TextSize         = 13
        btn.Font             = Enum.Font.GothamBold
        btn.Text             = cfg.Name or "Button"
        btn.BorderSizePixel  = 0
        btn.Size             = UDim2.new(1, 0, 0, Library.Config.ButtonHeight)
        btn.Parent           = scrollFrame

        Corner(btn)
        Stroke(btn, Library.CurrentTheme.Accent, 1, 0.4)

        btn.MouseButton1Click:Connect(function()
            Tween(btn, {BackgroundColor3 = Library.CurrentTheme.AccentDark}, 0.1)
            task.wait(0.1)
            Tween(btn, {BackgroundColor3 = Library.CurrentTheme.Accent}, 0.2)
            if cfg.Callback then cfg.Callback() end
        end)

        btn.MouseEnter:Connect(function()
            Tween(btn, {BackgroundColor3 = Color3.fromRGB(120, 160, 255)}, 0.2)
        end)
        btn.MouseLeave:Connect(function()
            Tween(btn, {BackgroundColor3 = Library.CurrentTheme.Accent}, 0.2)
        end)

        return btn
    end

