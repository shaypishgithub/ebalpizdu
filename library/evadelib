        local toggleBg = Instance.new("Frame")
        toggleBg.Name = "ToggleBg"
        toggleBg.BackgroundColor3 = config.Default and Library.CurrentTheme.Success or Library.CurrentTheme.Tertiary
        toggleBg.BorderSizePixel = 0
        toggleBg.Size = UDim2.new(0, 55, 0, 28)
        toggleBg.Position = UDim2.new(1, -55, 0.5, -14)
        toggleBg.Parent = container
        
        Corner(toggleBg, UDim.new(0, 14))
        Stroke(toggleBg, Library.CurrentTheme.Border, 1)
        
        local toggleCircle = Instance.new("Frame")
        toggleCircle.BackgroundColor3 = Library.CurrentTheme.Text
        toggleCircle.BorderSizePixel = 0
        toggleCircle.Size = UDim2.new(0, 24, 0, 24)
        toggleCircle.Position = config.Default and UDim2.new(0, 28, 0.5, -12) or UDim2.new(0, 2, 0.5, -12)
        toggleCircle.Parent = toggleBg
        
        Corner(toggleCircle, UDim.new(0, 12))
        
        local isOn = config.Default or false
        
        local function toggle()
            isOn = not isOn
            if isOn then
                Tween(toggleBg, {BackgroundColor3 = Library.CurrentTheme.Success}, 0.25):Play()
                Tween(toggleCircle, {Position = UDim2.new(0, 28, 0.5, -12)}, 0.25):Play()
            else
