    listLayout.Padding = UDim.new(0, 8)
    listLayout.Parent = scrollFrame
    
    Padding(scrollFrame, UDim.new(0, 12), UDim.new(0, 12), UDim.new(0, 12), UDim.new(0, 12))
    
    listLayout.Changed:Connect(function()
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 24)
    end)
    
    -- ПЕРЕТАСКИВАНИЕ
    local dragging = false
    local dragStart = Vector2.new(0, 0)
    local frameStart = UDim2.new(0, 0, 0, 0)
    
    titleBar.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = Mouse.Position
            frameStart = mainWindow.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = Mouse.Position - dragStart
            mainWindow.Position = UDim2.new(
                frameStart.X.Scale, frameStart.X.Offset + delta.X,
                frameStart.Y.Scale, frameStart.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    -- ОБЪЕКТ ОКНА
    local Window = {
        MainWindow = mainWindow,
        ScrollFrame = scrollFrame,
        ScreenGui = screenGui,
        Name = name,
        IsOpen = false,
    }
    
    function Window:Open()
        mainWindow.Visible = true
        mainWindow.Size = UDim2.new(size.X.Scale, size.X.Offset, 0, 0)
        Tween(mainWindow, {Size = size}, 0.4):Play()
        self.IsOpen = true
    end
    
    function Window:Close()
        Tween(mainWindow, {Size = UDim2.new(size.X.Scale, size.X.Offset, 0, 0)}, 0.3):Play()
        task.wait(0.3)
        mainWindow.Visible = false
        self.IsOpen = false
    end
    
    function Window:Destroy()
        screenGui:Destroy()
        Library.Windows[name] = nil
    end
    
