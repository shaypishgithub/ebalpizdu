    -- ── Слайдер ────────────────────────────────────────────────────────────
    -- ИСПРАВЛЕНО: правильный трекинг мыши/тача с флагом isDragging
    function Window:AddSlider(cfg)
        cfg = cfg or {}
        local min     = cfg.Min     or 0
        local max     = cfg.Max     or 100
        local default = cfg.Default or min

        local container = Instance.new("Frame")
        container.BackgroundTransparency = 1
        container.Size   = UDim2.new(1, 0, 0, 65)
        container.Parent = scrollFrame

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.TextColor3    = Library.CurrentTheme.Text
        lbl.TextSize      = 12
        lbl.Font          = Enum.Font.GothamBold
        lbl.Size          = UDim2.new(1, 0, 0, 20)
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Text          = cfg.Name or "Slider"
        lbl.Parent        = container

        local valueLabel = Instance.new("TextLabel")
        valueLabel.BackgroundTransparency = 1
        valueLabel.TextColor3    = Library.CurrentTheme.Accent
        valueLabel.TextSize      = 11
        valueLabel.Font          = Enum.Font.GothamBold
        valueLabel.Size          = UDim2.new(0, 50, 0, 20)
        valueLabel.Position      = UDim2.new(1, -50, 0, 0)
        valueLabel.TextXAlignment = Enum.TextXAlignment.Right
        valueLabel.Text          = tostring(default)
        valueLabel.Parent        = container

        local sliderBg = Instance.new("Frame")
        sliderBg.BackgroundColor3 = Library.CurrentTheme.Tertiary
        sliderBg.BorderSizePixel  = 0
        sliderBg.Size             = UDim2.new(1, 0, 0, 6)
        sliderBg.Position         = UDim2.new(0, 0, 0, 37)
        sliderBg.Parent           = container

        Corner(sliderBg, UDim.new(0, 3))

        local sliderFill = Instance.new("Frame")
        sliderFill.BackgroundColor3 = Library.CurrentTheme.Accent
        sliderFill.BorderSizePixel  = 0
        sliderFill.Size             = UDim2.new((default - min) / (max - min), 0, 1, 0)
        sliderFill.Parent           = sliderBg

        Corner(sliderFill, UDim.new(0, 3))

        local sliderKnob = Instance.new("Frame")
        sliderKnob.BackgroundColor3 = Library.CurrentTheme.Accent
        sliderKnob.BorderSizePixel  = 0
        sliderKnob.Size             = UDim2.new(0, 16, 0, 16)
        sliderKnob.Position         = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
        sliderKnob.ZIndex           = 2
        sliderKnob.Parent           = sliderBg

        Corner(sliderKnob)
        Stroke(sliderKnob, Library.CurrentTheme.Accent, 1, 0.5)

        local isDraggingSlider = false
        local currentValue     = default

        local function updateSliderFromPos(posX)
            local bgPos  = sliderBg.AbsolutePosition.X
            local bgSize = sliderBg.AbsoluteSize.X
            local rel    = math.clamp(posX - bgPos, 0, bgSize)
            local pct    = rel / bgSize
            currentValue = math.floor(min + pct * (max - min) + 0.5)
            pct = (currentValue - min) / (max - min)

            sliderFill.Size     = UDim2.new(pct, 0, 1, 0)
            sliderKnob.Position = UDim2.new(pct, -8, 0.5, -8)
            valueLabel.Text     = tostring(currentValue)

            if cfg.Callback then cfg.Callback(currentValue) end
        end

        -- Начало перетаскивания
        sliderBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                isDraggingSlider = true
                updateSliderFromPos(input.Position.X)
            end
        end)

        -- Движение (глобально, чтобы не выходить за пределы)
        UserInputService.InputChanged:Connect(function(input)
            if not isDraggingSlider then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch then
                updateSliderFromPos(input.Position.X)
            end
        end)

        -- Конец перетаскивания
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                isDraggingSlider = false
            end
        end)

        return container
    end

    -- ── Дропдаун ───────────────────────────────────────────────────────────
    -- ИСПРАВЛЕНО: динамическая высота контейнера при открытии, z-index
    function Window:AddDropdown(cfg)
        cfg = cfg or {}
        local options  = cfg.Options or {}
        local selected = cfg.Default or (options[1] or "")

        local ITEM_H   = 35
        local LABEL_H  = 20
        local BTN_H    = Library.Config.InputHeight
        local CLOSED_H = LABEL_H + BTN_H + 4

        local container = Instance.new("Frame")
        container.BackgroundTransparency = 1
        container.ClipsDescendants = false
        container.Size   = UDim2.new(1, 0, 0, CLOSED_H)
        container.Parent = scrollFrame

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.TextColor3    = Library.CurrentTheme.Text
        lbl.TextSize      = 12
        lbl.Font          = Enum.Font.GothamBold
        lbl.Size          = UDim2.new(1, 0, 0, LABEL_H)
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Text          = cfg.Name or "Dropdown"
        lbl.Parent        = container

        local dropdownBtn = Instance.new("TextButton")
        dropdownBtn.BackgroundColor3 = Library.CurrentTheme.Secondary
        dropdownBtn.TextColor3       = Library.CurrentTheme.Text
        dropdownBtn.TextSize         = 12
        dropdownBtn.Font             = Enum.Font.Gotham
        dropdownBtn.Text             = selected .. " ▼"
        dropdownBtn.BorderSizePixel  = 0
        dropdownBtn.Size             = UDim2.new(1, 0, 0, BTN_H)
        dropdownBtn.Position         = UDim2.new(0, 0, 0, LABEL_H + 4)
        dropdownBtn.Parent           = container

        Corner(dropdownBtn)
        Stroke(dropdownBtn, Library.CurrentTheme.Border, 1, 0.3)

        local menuOpen  = false
        local listFrame = nil

        dropdownBtn.MouseButton1Click:Connect(function()
            menuOpen = not menuOpen

            if menuOpen then
                dropdownBtn.Text = selected .. " ▲"

                local listH = #options * ITEM_H

                listFrame = Instance.new("Frame")
                listFrame.Name             = "DropdownList"
                listFrame.BackgroundColor3 = Library.CurrentTheme.Secondary
                listFrame.BorderSizePixel  = 0
                listFrame.ZIndex           = 10
                listFrame.Size             = UDim2.new(1, 0, 0, listH)
                listFrame.Position         = UDim2.new(0, 0, 0, LABEL_H + BTN_H + 8)
                listFrame.ClipsDescendants = true
                listFrame.Parent           = container

                Corner(listFrame)
                Stroke(listFrame, Library.CurrentTheme.Border, 1, 0.3)

                local ll = Instance.new("UIListLayout")
                ll.Padding = UDim.new(0, 0)
                ll.Parent  = listFrame

                -- Растягиваем контейнер
                container.Size = UDim2.new(1, 0, 0, CLOSED_H + listH + 8)

                for _, option in ipairs(options) do
                    local optBtn = Instance.new("TextButton")
                    optBtn.BackgroundColor3 = Library.CurrentTheme.Secondary
                    optBtn.TextColor3       = Library.CurrentTheme.Text
                    optBtn.TextSize         = 12
                    optBtn.Font             = Enum.Font.Gotham
                    optBtn.Text             = option
                    optBtn.BorderSizePixel  = 0
                    optBtn.ZIndex           = 11
                    optBtn.Size             = UDim2.new(1, 0, 0, ITEM_H)
                    optBtn.Parent           = listFrame

                    optBtn.MouseButton1Click:Connect(function()
                        selected = option
                        dropdownBtn.Text = selected .. " ▼"
                        listFrame:Destroy()
                        listFrame = nil
                        menuOpen  = false
                        container.Size = UDim2.new(1, 0, 0, CLOSED_H)
                        if cfg.Callback then cfg.Callback(selected) end
                    end)

                    optBtn.MouseEnter:Connect(function()
                        Tween(optBtn, {BackgroundColor3 = Library.CurrentTheme.Accent}, 0.15)
                    end)
                    optBtn.MouseLeave:Connect(function()
                        Tween(optBtn, {BackgroundColor3 = Library.CurrentTheme.Secondary}, 0.15)
                    end)
                end
            else
                dropdownBtn.Text = selected .. " ▼"
                if listFrame then
                    listFrame:Destroy()
                    listFrame = nil
                end
                container.Size = UDim2.new(1, 0, 0, CLOSED_H)
            end
        end)

        return container
    end

    Library.Windows[name] = Window
    return Window
end

