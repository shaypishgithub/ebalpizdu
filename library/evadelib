-- УВЕДОМЛЕНИЯ — ИСПРАВЛЕНО
-- ═══════════════════════════════════════════════════════════════════════════

function Library:Notify(config)
    config = config or {}
    local title    = config.Title    or "Notification"
    local text     = config.Text     or ""
    local duration = config.Duration or 3
    local notifType = config.Type    or "Info"

    local colors = {
        Success = Library.CurrentTheme.Success,
        Warning = Library.CurrentTheme.Warning,
        Error   = Library.CurrentTheme.Error,
        Info    = Library.CurrentTheme.Accent,
    }
    local accentColor = colors[notifType] or colors.Info

    -- Находим или создаём контейнер для уведомлений
    local notifHolder = UserGui:FindFirstChild("NotifHolder_GUI")
    if not notifHolder then
        notifHolder = Instance.new("ScreenGui")
        notifHolder.Name           = "NotifHolder_GUI"
        notifHolder.ResetOnSpawn   = false
        notifHolder.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        notifHolder.IgnoreGuiInset = true
        notifHolder.Parent         = UserGui
    end

    local index = #Library.Notifications + 1
    local W, H  = 300, 80
    local gap   = 10

    local notifFrame = Instance.new("Frame")
    notifFrame.BackgroundColor3 = Library.CurrentTheme.Secondary
    notifFrame.BorderSizePixel  = 0
    notifFrame.Size             = UDim2.new(0, W, 0, H)
    -- Начинаем за правым краем экрана
    notifFrame.Position         = UDim2.new(1, 10, 0, 20 + (index - 1) * (H + gap))
    notifFrame.Parent           = notifHolder

    Corner(notifFrame)
    Stroke(notifFrame, accentColor, 2)

    local colorBar = Instance.new("Frame")
    colorBar.BackgroundColor3 = accentColor
    colorBar.BorderSizePixel  = 0
    colorBar.Size             = UDim2.new(0, 5, 1, 0)
    colorBar.Parent           = notifFrame

    Corner(colorBar, UDim.new(0, 3))

    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.TextColor3    = Library.CurrentTheme.Text
    titleLbl.TextSize      = 14
    titleLbl.Font          = Enum.Font.GothamBold
    titleLbl.Size          = UDim2.new(1, -20, 0, 25)
    titleLbl.Position      = UDim2.new(0, 15, 0, 8)
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Text          = title
    titleLbl.Parent        = notifFrame

    local textLbl = Instance.new("TextLabel")
    textLbl.BackgroundTransparency = 1
    textLbl.TextColor3    = Library.CurrentTheme.TextSecondary
    textLbl.TextSize      = 11
    textLbl.Font          = Enum.Font.Gotham
    textLbl.Size          = UDim2.new(1, -20, 0, H - 38)
    textLbl.Position      = UDim2.new(0, 15, 0, 34)
    textLbl.TextXAlignment = Enum.TextXAlignment.Left
    textLbl.TextWrapped   = true
    textLbl.Text          = text
    textLbl.Parent        = notifFrame

    table.insert(Library.Notifications, notifFrame)

    -- Въезжаем с правой стороны
    local targetX = -(W + 20)
    Tween(notifFrame, {Position = UDim2.new(1, targetX, 0, 20 + (index - 1) * (H + gap))}, 0.35)

    task.wait(duration)

    -- Уезжаем обратно
    Tween(notifFrame, {Position = UDim2.new(1, 10, 0, notifFrame.Position.Y.Offset)}, 0.3)
    task.wait(0.35)

    local idx = table.find(Library.Notifications, notifFrame)
    if idx then table.remove(Library.Notifications, idx) end

    if notifFrame and notifFrame.Parent then
        notifFrame:Destroy()
    end
end

