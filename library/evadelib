function Library:CreateWindow(config)
    config = config or {}
    local name     = config.Name     or "Window"
    local size     = config.Size     or UDim2.new(0, 480, 0, 600)
    local position = config.Position or UDim2.new(0.5, -240, 0.5, -300)

    -- На мобиле — полноэкранный режим
    if IsMobile() then
        size     = UDim2.new(1, -20, 0.9, 0)
        position = UDim2.new(0, 10, 0.05, 0)
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name            = name .. "_GUI"
    screenGui.ResetOnSpawn    = false
    screenGui.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
    screenGui.IgnoreGuiInset  = true
    screenGui.Parent          = UserGui

    local mainWindow = Instance.new("Frame")
    mainWindow.Name              = name
    mainWindow.BackgroundColor3  = Library.CurrentTheme.Primary
    mainWindow.BorderSizePixel   = 0
    mainWindow.Size              = size
    mainWindow.Position          = position
    mainWindow.Visible           = false
    mainWindow.Parent            = screenGui

    Corner(mainWindow, Library.Config.CornerRadius)
    Gradient(mainWindow, Library.CurrentTheme.Primary, Library.CurrentTheme.Secondary, 150)
    Stroke(mainWindow, Library.CurrentTheme.Border, Library.Config.StrokeThickness)

    -- ── ЗАГОЛОВОК ──────────────────────────────────────────────────────────

    local titleBar = Instance.new("Frame")
    titleBar.Name             = "TitleBar"
    titleBar.BackgroundColor3 = Library.CurrentTheme.Secondary
    titleBar.BorderSizePixel  = 0
    titleBar.Size             = UDim2.new(1, 0, 0, Library.Config.TitleBarHeight)
    titleBar.Parent           = mainWindow

    Corner(titleBar, Library.Config.CornerRadius)
    Gradient(titleBar, Library.CurrentTheme.Secondary, Library.CurrentTheme.Tertiary, 180)

    local icon = Instance.new("TextLabel")
    icon.BackgroundTransparency = 1
    icon.TextColor3 = Library.CurrentTheme.Accent
    icon.TextSize   = 20
    icon.Font       = Enum.Font.GothamBold
    icon.Size       = UDim2.new(0, 40, 1, 0)
    icon.Position   = UDim2.new(0, 10, 0, 0)
    icon.Text       = config.Icon or "◈"
    icon.Parent     = titleBar

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3      = Library.CurrentTheme.Text
    titleLabel.TextSize        = 16
    titleLabel.Font            = Enum.Font.GothamBold
    titleLabel.Size            = UDim2.new(1, -140, 1, 0)
    titleLabel.Position        = UDim2.new(0, 50, 0, 0)
    titleLabel.TextXAlignment  = Enum.TextXAlignment.Left
    titleLabel.Text            = name
    titleLabel.Parent          = titleBar

    -- Кнопка минимизации
    local minimizeBtn = Instance.new("TextButton")
    minimizeBtn.Name             = "MinimizeBtn"
    minimizeBtn.BackgroundColor3 = Library.CurrentTheme.Warning
    minimizeBtn.TextColor3       = Library.CurrentTheme.Text
    minimizeBtn.TextSize         = 14
    minimizeBtn.Font             = Enum.Font.GothamBold
    minimizeBtn.Text             = "−"
    minimizeBtn.BorderSizePixel  = 0
    minimizeBtn.Size             = UDim2.new(0, 35, 0, 35)
    minimizeBtn.Position         = UDim2.new(1, -80, 0.5, -17.5)
    minimizeBtn.Parent           = titleBar

    Corner(minimizeBtn, UDim.new(0, 6))
    Stroke(minimizeBtn, Library.CurrentTheme.Warning, 1, 0.5)

    local minimized = false
    minimizeBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            Tween(mainWindow, {Size = UDim2.new(size.X.Scale, size.X.Offset, 0, Library.Config.TitleBarHeight)}, 0.3)
            minimizeBtn.Text = "□"
        else
            Tween(mainWindow, {Size = size}, 0.3)
            minimizeBtn.Text = "−"
        end
    end)

    minimizeBtn.MouseEnter:Connect(function()
        Tween(minimizeBtn, {BackgroundColor3 = Color3.fromRGB(255, 180, 0)}, 0.15)
    end)
    minimizeBtn.MouseLeave:Connect(function()
        Tween(minimizeBtn, {BackgroundColor3 = Library.CurrentTheme.Warning}, 0.15)
    end)

    -- Кнопка закрытия
    local closeBtn = Instance.new("TextButton")
    closeBtn.Name             = "CloseBtn"
    closeBtn.BackgroundColor3 = Library.CurrentTheme.Error
    closeBtn.TextColor3       = Library.CurrentTheme.Text
    closeBtn.TextSize         = 14
    closeBtn.Font             = Enum.Font.GothamBold
    closeBtn.Text             = "✕"
    closeBtn.BorderSizePixel  = 0
    closeBtn.Size             = UDim2.new(0, 35, 0, 35)
    closeBtn.Position         = UDim2.new(1, -40, 0.5, -17.5)
    closeBtn.Parent           = titleBar

    Corner(closeBtn, UDim.new(0, 6))
    Stroke(closeBtn, Library.CurrentTheme.Error, 1, 0.5)

    closeBtn.MouseButton1Click:Connect(function()
        Library:CloseWindow(name)
    end)
    closeBtn.MouseEnter:Connect(function()
        Tween(closeBtn, {BackgroundColor3 = Color3.fromRGB(255, 100, 100)}, 0.15)
    end)
    closeBtn.MouseLeave:Connect(function()
        Tween(closeBtn, {BackgroundColor3 = Library.CurrentTheme.Error}, 0.15)
    end)

    -- ── КОНТЕНТ ────────────────────────────────────────────────────────────

    local contentFrame = Instance.new("Frame")
    contentFrame.Name               = "Content"
    contentFrame.BackgroundTransparency = 1
    contentFrame.BorderSizePixel    = 0
    contentFrame.Size               = UDim2.new(1, 0, 1, -Library.Config.TitleBarHeight)
    contentFrame.Position           = UDim2.new(0, 0, 0, Library.Config.TitleBarHeight)
    contentFrame.ClipsDescendants   = true
    contentFrame.Parent             = mainWindow

    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Name                  = "ScrollFrame"
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.BorderSizePixel       = 0
    scrollFrame.Size                  = UDim2.new(1, 0, 1, 0)
    scrollFrame.ScrollBarThickness    = IsMobile() and 0 or 5
    scrollFrame.ScrollBarImageColor3  = Library.CurrentTheme.Accent
    scrollFrame.CanvasSize            = UDim2.new(0, 0, 0, 0)
    scrollFrame.Parent                = contentFrame

    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 8)
    listLayout.Parent  = scrollFrame

    Padding(scrollFrame, UDim.new(0, 12), UDim.new(0, 12), UDim.new(0, 12), UDim.new(0, 12))

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 24)
    end)

    -- ── ПЕРЕТАСКИВАНИЕ (мышь + тач) ────────────────────────────────────────

    local dragging   = false
    local dragStart  = Vector2.new()
    local frameStart = UDim2.new()

    local function onDragBegan(pos)
        dragging   = true
        dragStart  = pos
        frameStart = mainWindow.Position
    end

    local function onDragMoved(pos)
        if not dragging then return end
        local delta = pos - dragStart
        mainWindow.Position = UDim2.new(
            frameStart.X.Scale, frameStart.X.Offset + delta.X,
            frameStart.Y.Scale, frameStart.Y.Offset + delta.Y
        )
    end

    local function onDragEnded()
        dragging = false
    end

    -- Мышь
    titleBar.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            onDragBegan(Vector2.new(Mouse.X, Mouse.Y))
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            onDragMoved(Vector2.new(Mouse.X, Mouse.Y))
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            onDragEnded()
        end
    end)

    -- Тач
    titleBar.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.UserInputType == Enum.UserInputType.Touch then
            onDragBegan(input.Position)
        end
    end)

    titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            onDragMoved(input.Position)
        end
    end)

    titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            onDragEnded()
        end
    end)

    -- ── ОБЪЕКТ ОКНА ────────────────────────────────────────────────────────

    local Window = {
        MainWindow  = mainWindow,
        ScrollFrame = scrollFrame,
        ScreenGui   = screenGui,
        Name        = name,
        IsOpen      = false,
    }

    function Window:Open()
        mainWindow.Visible = true
        mainWindow.Size = UDim2.new(size.X.Scale, size.X.Offset, 0, 0)
        Tween(mainWindow, {Size = size}, 0.4)
        self.IsOpen = true
    end

    function Window:Close()
        Tween(mainWindow, {Size = UDim2.new(size.X.Scale, size.X.Offset, 0, 0)}, 0.3)
        task.wait(0.3)
        mainWindow.Visible = false
        self.IsOpen = false
    end

    function Window:Destroy()
        screenGui:Destroy()
        Library.Windows[name] = nil
    end

    -- ══════════════════════════════════════════════════════════════════════
