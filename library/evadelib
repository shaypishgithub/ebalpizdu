    -- ── Переключатель ──────────────────────────────────────────────────────
    function Window:AddToggle(cfg)
        cfg = cfg or {}

        local container = Instance.new("Frame")
        container.BackgroundTransparency = 1
        container.Size   = UDim2.new(1, 0, 0, 35)
        container.Parent = scrollFrame

        local label = Instance.new("TextLabel")
        label.BackgroundTransparency = 1
        label.TextColor3    = Library.CurrentTheme.Text
        label.TextSize      = 13
        label.Font          = Enum.Font.Gotham
        label.Size          = UDim2.new(1, -65, 1, 0)
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Text          = cfg.Name or "Toggle"
        label.Parent        = container

        local toggleBg = Instance.new("Frame")
        toggleBg.Name             = "ToggleBg"
        toggleBg.BackgroundColor3 = cfg.Default and Library.CurrentTheme.Success or Library.CurrentTheme.Tertiary
        toggleBg.BorderSizePixel  = 0
        toggleBg.Size             = UDim2.new(0, 55, 0, 28)
        toggleBg.Position         = UDim2.new(1, -55, 0.5, -14)
        toggleBg.Parent           = container

        Corner(toggleBg, UDim.new(0, 14))
        Stroke(toggleBg, Library.CurrentTheme.Border, 1)

        local toggleCircle = Instance.new("Frame")
        toggleCircle.BackgroundColor3 = Library.CurrentTheme.Text
        toggleCircle.BorderSizePixel  = 0
        toggleCircle.Size             = UDim2.new(0, 24, 0, 24)
        toggleCircle.Position         = cfg.Default
            and UDim2.new(0, 29, 0.5, -12)
            or  UDim2.new(0, 2,  0.5, -12)
        toggleCircle.Parent = toggleBg

        Corner(toggleCircle, UDim.new(0, 12))

        local isOn = cfg.Default or false

        local function doToggle()
            isOn = not isOn
            if isOn then
                Tween(toggleBg,     {BackgroundColor3 = Library.CurrentTheme.Success},   0.25)
                Tween(toggleCircle, {Position = UDim2.new(0, 29, 0.5, -12)},            0.25)
            else
                Tween(toggleBg,     {BackgroundColor3 = Library.CurrentTheme.Tertiary},  0.25)
                Tween(toggleCircle, {Position = UDim2.new(0, 2,  0.5, -12)},            0.25)
            end
            if cfg.Callback then cfg.Callback(isOn) end
        end

        toggleBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                doToggle()
            end
        end)

        return container
    end

    -- ── Текстбокс ──────────────────────────────────────────────────────────
    function Window:AddTextBox(cfg)
        cfg = cfg or {}

        local container = Instance.new("Frame")
        container.BackgroundTransparency = 1
        container.Size   = UDim2.new(1, 0, 0, 60)
        container.Parent = scrollFrame

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.TextColor3    = Library.CurrentTheme.Text
        lbl.TextSize      = 12
