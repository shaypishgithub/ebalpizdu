-- УВЕДОМЛЕНИЯ
-- ═══════════════════════════════════════════════════════════════════════════

function Library:Notify(config)
    config = config or {}
    local title = config.Title or "Notification"
    local text = config.Text or ""
    local duration = config.Duration or 3
    local notifType = config.Type or "Info"
    
    local colors = {
        Success = Library.CurrentTheme.Success,
        Warning = Library.CurrentTheme.Warning,
        Error = Library.CurrentTheme.Error,
        Info = Library.CurrentTheme.Accent,
    }
    
    local notificationGui = Instance.new("ScreenGui")
    notificationGui.Name = "Notification"
    notificationGui.ResetOnSpawn = false
    notificationGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    notificationGui.Parent = UserGui
    
    local notifFrame = Instance.new("Frame")
    notifFrame.BackgroundColor3 = Library.CurrentTheme.Secondary
    notifFrame.BorderSizePixel = 0
    notifFrame.Size = UDim2.new(0, 300, 0, 80)
    notifFrame.Position = UDim2.new(1, -320, 0, 20 + (#Library.Notifications * 90))
    notifFrame.Parent = notificationGui
    
    Corner(notifFrame)
    Stroke(notifFrame, colors[notifType] or colors.Info, 2)
    
    local colorBar = Instance.new("Frame")
    colorBar.BackgroundColor3 = colors[notifType] or colors.Info
    colorBar.BorderSizePixel = 0
    colorBar.Size = UDim2.new(0, 5, 1, 0)
    colorBar.Parent = notifFrame
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3 = Library.CurrentTheme.Text
    titleLabel.TextSize = 14
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.Size = UDim2.new(1, -15, 0, 25)
    titleLabel.Position = UDim2.new(0, 15, 0, 5)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Text = title
    titleLabel.Parent = notifFrame
    
    local textLabel = Instance.new("TextLabel")
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = Library.CurrentTheme.TextSecondary
    textLabel.TextSize = 12
    textLabel.Font = Enum.Font.Gotham
    textLabel.Size = UDim2.new(1, -15, 1, -35)
    textLabel.Position = UDim2.new(0, 15, 0, 30)
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.TextWrapped = true
    textLabel.Text = text
    textLabel.Parent = notifFrame
    
    table.insert(Library.Notifications, notifFrame)
    
    Tween(notifFrame, {Position = UDim2.new(1, -320, 0, 20 + (#Library.Notifications * 90))}, 0.3):Play()
    
    task.wait(duration)
    
    Tween(notifFrame, {Position = UDim2.new(1, -320 + 320, 0, 20 + (#Library.Notifications * 90))}, 0.3):Play()
    task.wait(0.3)
    
    table.remove(Library.Notifications, table.find(Library.Notifications, notifFrame))
    notificationGui:Destroy()
end

