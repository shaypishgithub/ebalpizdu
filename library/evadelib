                    optionBtn.Text = option
                    optionBtn.BorderSizePixel = 0
                    optionBtn.Size = UDim2.new(1, 0, 0, 30)
                    optionBtn.Parent = listFrame
                    
                    optionBtn.MouseButton1Click:Connect(function()
                        selected = option
                        dropdownBtn.Text = selected .. " ▼"
                        listFrame:Destroy()
                        menuOpen = false
                        if config.Callback then config.Callback(selected) end
                    end)
                    
                    optionBtn.MouseEnter:Connect(function()
                        Tween(optionBtn, {BackgroundColor3 = Library.CurrentTheme.Accent}, 0.15):Play()
                    end)
                    
                    optionBtn.MouseLeave:Connect(function()
                        Tween(optionBtn, {BackgroundColor3 = Library.CurrentTheme.Secondary}, 0.15):Play()
                    end)
                end
            else
                local list = container:FindFirstChild("DropdownList")
                if list then list:Destroy() end
                dropdownBtn.Text = selected .. " ▼"
            end
        end)
        
        return container
    end
    
    Library.Windows[name] = Window
    return Window
end

