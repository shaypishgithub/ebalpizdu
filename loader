-- NOTIFICATION SYSTEM (improved)
-- ══════════════════════════════════════
local function createNotification(title, subtitle, duration)
    local notif = Instance.new("ScreenGui")
    notif.Parent = playerGui
    notif.ResetOnSpawn = false

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 280, 0, 80)
    frame.Position = UDim2.new(0.5, -140, 0, 40)
    frame.BackgroundTransparency = 1
    frame.Parent = notif

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    bg.BackgroundTransparency = 0.3
    bg.Parent = frame
    bg:SetAttribute("ThemeClass", "Panel")
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 14)
    local stroke = Instance.new("UIStroke", bg)
    stroke.Thickness = 1.5
    stroke.Transparency = 0.4

    -- Title
    local tLabel = Instance.new("TextLabel")
    tLabel.Text = title
    tLabel.Font = Enum.Font.GothamBold
    tLabel.TextSize = 18
    tLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    tLabel.Position = UDim2.new(0, 20, 0, 12)
    tLabel.Size = UDim2.new(1, -40, 0, 24)
    tLabel.BackgroundTransparency = 1
    tLabel.Parent = bg
    tLabel:SetAttribute("ThemeClass", "Title")

    -- Subtitle
    local sLabel = Instance.new("TextLabel")
    sLabel.Text = subtitle
    sLabel.Font = Enum.Font.Gotham
    sLabel.TextSize = 14
    sLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    sLabel.Position = UDim2.new(0, 20, 0, 38)
    sLabel.Size = UDim2.new(1, -40, 0, 20)
    sLabel.BackgroundTransparency = 1
    sLabel.Parent = bg
    sLabel:SetAttribute("ThemeClass", "Subtitle")

    applyTheme() -- apply immediately

    -- Animation
    local ti = TweenInfo.new(0.4, Enum.EasingStyle.Sine)
    TweenService:Create(bg, ti, {BackgroundTransparency = 0.25}):Play()
    TweenService:Create(tLabel, ti, {TextTransparency = 0}):Play()
    TweenService:Create(sLabel, ti, {TextTransparency = 0}):Play()

    task.delay(duration or 3, function()
        TweenService:Create(bg, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        TweenService:Create(tLabel, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(sLabel, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        task.delay(0.5, function() notif:Destroy() end)
    end)
end

