-- ══════════════════════════════════════
-- ANIMATED GRADIENT SYSTEM (Shimmer effect)
-- ══════════════════════════════════════
local gradientObjects = {}

local function applyAnimatedGradient(frame, rotation)
    local grad = Instance.new("UIGradient")
    grad.Rotation = rotation or 35
    grad.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 0.85),
        NumberSequenceKeypoint.new(0.45, 0.1),
        NumberSequenceKeypoint.new(0.55, 0.1),
        NumberSequenceKeypoint.new(1, 0.85)
    }
    grad.Parent = frame
    table.insert(gradientObjects, grad)
    return grad
end

-- Global shimmer updater (single connection = optimal performance)
RunService.Heartbeat:Connect(function()
    local t = tick() * 1.2
    local offset = (t % 2) - 1
    for _, grad in ipairs(gradientObjects) do
        if grad and grad.Parent then
            grad.Offset = Vector2.new(offset, 0)
        end
    end
end)

local function updateAllGradients()
    local theme = getTheme()
    for _, grad in ipairs(gradientObjects) do
        if grad and grad.Parent then
            grad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, theme.Accent),
                ColorSequenceKeypoint.new(1, theme.Text)
            }
        end
    end
end

-- ══════════════════════════════════════
-- LIVE THEME APPLIER
-- ══════════════════════════════════════
local function applyTheme()
    local theme = getTheme()
    for _, obj in ipairs(screenGui:GetDescendants()) do
        local class = obj:GetAttribute("ThemeClass")
        if class == "MainBG" then
            obj.BackgroundColor3 = theme.PrimaryBG
        elseif class == "Panel" then
            obj.BackgroundColor3 = theme.SecondaryBG
        elseif class == "Button" then
            obj.BackgroundColor3 = theme.SecondaryBG
            obj.TextColor3 = theme.Text
        elseif class == "Header" then
            obj.BackgroundColor3 = theme.SecondaryBG
        elseif class == "Title" then
            obj.TextColor3 = theme.Text
        elseif class == "Subtitle" then
            obj.TextColor3 = theme.TextSecondary
        elseif obj:IsA("UIStroke") then
            obj.Color = theme.Stroke
        end
    end
    updateAllGradients()
end

