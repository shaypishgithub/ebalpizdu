-- ══════════════════════════════════════
local currentData = {}
local currentView = "Home"

local function clearContent()
    for _, child in ipairs(content:GetChildren()) do
        if not child:IsA("UIListLayout") then child:Destroy() end
    end
end

local function refreshList(query)
    clearContent()
    local filtered = {}
    for _, hack in ipairs(currentData) do
        if not query or string.find(string.lower(hack[1] or ""), string.lower(query)) then
            table.insert(filtered, hack)
        end
    end

    for _, hack in ipairs(filtered) do
        if type(hack) == "table" and hack[1] and hack[2] then
            createButton(hack[1], content, function()
                pcall(hack[2])
            end)
        end
    end
    content.CanvasSize = UDim2.new(0, 0, 0, contentLayout.AbsoluteContentSize.Y)
end

local function loadCategory(catName)
    currentView = "Category"
    currentData = HubData[catName] or {}
    searchBox.Visible = true
    clearContent()
    refreshList(searchBox.Text)
end

local function loadAllScripts()
    currentView = "Category"
    currentData = {}
    for _, data in pairs(HubData) do
        if type(data) == "table" then
            for _, v in ipairs(data) do table.insert(currentData, v) end
        end
    end
    searchBox.Visible = true
    refreshList(searchBox.Text)
end

-- Search real-time (debounced by nature of small data)
searchBox.TextChanged:Connect(function()
    if currentView == "Category" then
        refreshList(searchBox.Text)
    end
end)

