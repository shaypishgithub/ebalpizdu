-- UIListLayout (auto-resizes parent canvas if ScrollingFrame)
function UI.list(parent, padding)
    local l = Instance.new("UIListLayout")
    l.Padding              = UDim.new(0, padding or 8)
    l.SortOrder            = Enum.SortOrder.LayoutOrder
    l.FillDirection        = Enum.FillDirection.Vertical
    l.HorizontalAlignment  = Enum.HorizontalAlignment.Center
    l.Parent               = parent
    l:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if parent:IsA("ScrollingFrame") then
            parent.CanvasSize = UDim2.new(0, 0, 0, l.AbsoluteContentSize.Y + 14)
        end
    end)
    return l
end

-- UIPadding
function UI.pad(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 8)
    p.PaddingRight  = UDim.new(0, right  or 8)
    p.PaddingBottom = UDim.new(0, bottom or 8)
    p.PaddingLeft   = UDim.new(0, left   or 8)
    p.Parent        = parent
    return p
end

-- ═══════════════════════════════════════════════════════════════════
--  ⑥  NOTIFICATION  SYSTEM
--
--  Queue-aware slide-in toasts, one per slot (max 4 simultaneous).
--  Usage: notify(title, body, kind, duration)
--         kind = "info" | "success" | "warn" | "error"
-- ═══════════════════════════════════════════════════════════════════
local Notif = {}
Notif._active  = 0
Notif._queue   = {}
Notif._MAX     = 4
Notif._H       = 64
Notif._W       = 280
Notif._GAP     = 8
Notif._MARGIN  = 18

local NOTIF_ICONS = {
    info    = "rbxassetid://7733960981",
    success = "rbxassetid://7072717762",
    warn    = "rbxassetid://7733968497",
    error   = "rbxassetid://7733968497",
}
local NOTIF_COLORS = {
    info    = function() return ThemeManager.get("Accent")   end,
    success = function() return ThemeManager.get("Success")  end,
    warn    = function() return ThemeManager.get("Warning")  end,
    error   = function() return ThemeManager.get("Error")    end,
}

function Notif.push(title, body, kind, dur)
    kind = kind or "info"
    dur  = dur  or 3.5
    if Notif._active >= Notif._MAX then
        table.insert(Notif._queue, {title, body, kind, dur})
        return
    end
    Notif._active = Notif._active + 1
    local slot = Notif._active

    local ng = Instance.new("ScreenGui")
    ng.Name = "MH2_Toast"
    ng.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
    ng.ResetOnSpawn    = false
    protectGui(ng)

    local W, H = Notif._W, Notif._H
    local yBase = -(Notif._MARGIN + (slot-1)*(H + Notif._GAP) + H)

    local frame = UI.frame({
        size  = UDim2.new(0, W, 0, H),
        pos   = UDim2.new(1, W+20, 1, yBase),   -- start off-screen right
        bg    = ThemeManager.get("Surface"),
        alpha = 0.04,
        z     = 10,
        parent= ng,
    })
    UI.corner(frame, 12)
    UI.stroke(frame, 1.5, NOTIF_COLORS[kind](), 0.15)

    -- Left accent bar
    local bar = UI.frame({
        size  = UDim2.new(0, 3, 1, -16),
        pos   = UDim2.new(0, 8, 0, 8),
        bg    = NOTIF_COLORS[kind](),
        alpha = 0,
        z     = 11,
        parent= frame,
    })
    UI.corner(bar, 3)

    -- Icon
    local ico = Instance.new("ImageLabel")
    ico.Size                   = UDim2.new(0, 26, 0, 26)
    ico.Position               = UDim2.new(0, 18, 0.5, -13)
    ico.BackgroundTransparency = 1
    ico.Image                  = NOTIF_ICONS[kind] or NOTIF_ICONS.info
    ico.ZIndex                 = 11
    ico.Parent                 = frame

    -- Title / body
    UI.label({text=title, size=13, font=Enum.Font.GothamBold,
        sz=UDim2.new(1,-68,0,18), pos=UDim2.new(0,52,0,10), z=11, parent=frame})
    UI.label({text=body, size=11, font=Enum.Font.Gotham, muted=true,
        sz=UDim2.new(1,-68,0,16), pos=UDim2.new(0,52,0,32), z=11, parent=frame})

    -- Progress drain bar
    local pbBg = UI.frame({
        size   = UDim2.new(1,0,0,2),
        pos    = UDim2.new(0,0,1,-2),
        bg     = ThemeManager.get("Border"),
        alpha  = 0.5,
        z      = 12,
        parent = frame,
    })
    local pbFill = UI.frame({
        size   = UDim2.new(1,0,1,0),
        bg     = NOTIF_COLORS[kind](),
        alpha  = 0,
        z      = 13,
        parent = pbBg,
    })
    UI.corner(pbBg, 2)

    -- Slide in
    local targetPos = UDim2.new(1, -(W + Notif._MARGIN), 1, yBase)
    tween(frame, {Position = targetPos}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    tween(pbFill, {Size = UDim2.new(0,0,1,0)}, dur, Enum.EasingStyle.Linear)

    task.delay(dur, function()
        tween(frame, {Position = UDim2.new(1, W+20, 1, yBase)},
            0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        task.wait(0.38)
        ng:Destroy()
        Notif._active = Notif._active - 1
        if #Notif._queue > 0 then
            Notif.push(table.unpack(table.remove(Notif._queue, 1)))
        end
    end)
end

-- Convenience alias used throughout the script
local function notify(t, b, k, d) Notif.push(t, b, k, d) end

