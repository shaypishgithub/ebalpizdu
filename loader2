local activeSideBtn = nil
local SBH = isMob and 35 or 29

local function makeSideBtn(label, cb)
	local btn = Instance.new("TextButton")
	btn.Size               = UDim2.new(1,0,0,SBH)
	btn.BackgroundColor3   = T.cardHov
	btn.BackgroundTransparency = 1
	btn.BorderSizePixel    = 0
	btn.Text               = ""
	btn.ZIndex             = 13
	btn.Parent             = sideScroll
	local sbCC = Instance.new("UICorner"); sbCC.CornerRadius = UDim.new(0,6); sbCC.Parent = btn

	local actBar = Instance.new("Frame")
	actBar.Size             = UDim2.new(0,3,.55,0)
	actBar.Position         = UDim2.new(0,0,.225,0)
	actBar.BackgroundColor3 = T.acc1
	actBar.BorderSizePixel  = 0
	actBar.Visible          = false
	actBar.ZIndex           = 14
	actBar.Parent           = btn
	local abCC = Instance.new("UICorner"); abCC.CornerRadius = UDim.new(0,2); abCC.Parent = actBar

	local lbl = Instance.new("TextLabel")
	lbl.Size               = UDim2.new(1,-4,1,0)
	lbl.Position           = UDim2.new(0,2,0,0)
	lbl.BackgroundTransparency = 1
	lbl.Text               = label
	lbl.TextColor3         = T.txtMut
	lbl.TextSize           = isMob and 10 or 10
	lbl.Font               = Enum.Font.GothamMedium
	lbl.TextXAlignment     = Enum.TextXAlignment.Center
	lbl.TextWrapped        = true
	lbl.ZIndex             = 14
	lbl.Parent             = btn

	local function activate()
		actBar.Visible = true
		tw(btn, {BackgroundTransparency=.58}, .15)
		tw(lbl, {TextColor3=T.acc1}, .15)
	end
	local function deactivate()
		actBar.Visible = false
		tw(btn, {BackgroundTransparency=1}, .15)
		tw(lbl, {TextColor3=T.txtMut}, .15)
	end

	btn.MouseEnter:Connect(function()
		if activeSideBtn ~= btn then
			tw(btn, {BackgroundTransparency=.82}, .1)
			tw(lbl, {TextColor3=T.txt}, .1)
		end
	end)
	btn.MouseLeave:Connect(function()
		if activeSideBtn ~= btn then
			tw(btn, {BackgroundTransparency=1}, .1)
			tw(lbl, {TextColor3=T.txtMut}, .1)
		end
	end)

	btn.MouseButton1Click:Connect(function()
		if activeSideBtn and activeSideBtn ~= btn then
			if activeSideBtn._deact then activeSideBtn._deact() end
		end
		activeSideBtn = btn
		activate()
		tw(btn, {Size=UDim2.new(.94,0,0,SBH-2)}, .1, Enum.EasingStyle.Back)
		task.delay(.12, function()
			if btn and btn.Parent then tw(btn, {Size=UDim2.new(1,0,0,SBH)}, .2, Enum.EasingStyle.Back) end
		end)
		searchBox.Text = ""
		cb()
	end)

	btn._deact    = deactivate
	btn._activate = activate
	return btn
end

