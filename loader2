--  NOTIFICATION SYSTEM
-- ════════════════════════════════════════════════════════════════
local NotifCount = 0

local function Notify(title, msg, ntype, dur)
    if NotifCount >= 4 then return end
    NotifCount = NotifCount + 1
    dur   = dur   or 3.5
    ntype = ntype or "info"
    local accent = ({
        info = T("Accent"), success = T("Success"),
        error = T("Error"), warning = T("Warning"),
    })[ntype] or T("Accent")
    local slot = NotifCount

    local card = Instance.new("Frame")
    card.Name = "Notif"; card.Size = UDim2.new(0,280,0,58)
    card.Position = UDim2.new(1,12,1,-(64*slot))
    card.BackgroundColor3 = T("Surface"); card.BorderSizePixel = 0
    card.ZIndex = 300; card.Parent = ScreenGui
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,10); c.Parent = card end
    do local s = Instance.new("UIStroke"); s.Color = accent; s.Thickness = 1; s.Transparency = 0.2; s.Parent = card end

    local strip = Instance.new("Frame")
    strip.Size = UDim2.new(0,3,0.6,0); strip.Position = UDim2.new(0,6,0.2,0)
    strip.BackgroundColor3 = accent; strip.BorderSizePixel = 0; strip.ZIndex = 301; strip.Parent = card
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,2); c.Parent = strip end

    local tl = Instance.new("TextLabel")
    tl.Text = title; tl.TextColor3 = T("Text"); tl.TextSize = 13; tl.Font = Enum.Font.GothamBold
    tl.BackgroundTransparency = 1; tl.Size = UDim2.new(1,-22,0,20); tl.Position = UDim2.new(0,17,0,7)
    tl.TextXAlignment = Enum.TextXAlignment.Left; tl.ZIndex = 301; tl.Parent = card

    local ml = Instance.new("TextLabel")
    ml.Text = msg; ml.TextColor3 = T("TextMuted"); ml.TextSize = 11; ml.Font = Enum.Font.Gotham
    ml.BackgroundTransparency = 1; ml.Size = UDim2.new(1,-22,0,24); ml.Position = UDim2.new(0,17,0,27)
    ml.TextXAlignment = Enum.TextXAlignment.Left; ml.TextWrapped = true; ml.ZIndex = 301; ml.Parent = card

    local pb = Instance.new("Frame")
    pb.Size = UDim2.new(1,-12,0,2); pb.Position = UDim2.new(0,6,1,-3)
    pb.BackgroundColor3 = accent; pb.BorderSizePixel = 0; pb.ZIndex = 301; pb.Parent = card
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,1); c.Parent = pb end

    Tw(card, {Position = UDim2.new(1,-290,1,-(64*slot))}, 0.38, Enum.EasingStyle.Back)
    Tw(pb,   {Size = UDim2.new(0,0,0,2)}, dur, Enum.EasingStyle.Linear)

    task.delay(dur, function()
        Tw(card, {Position = UDim2.new(1,12,1,-(64*slot))}, 0.25)
        task.wait(0.28)
        pcall(function() card:Destroy() end)
        NotifCount = math.max(0, NotifCount-1)
    end)
end

