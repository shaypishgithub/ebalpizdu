local ContentRenderer = {}

-- Load all scripts from one HubData category
function ContentRenderer.loadCategory(key)
    clearScripts()
    local data = HubData[key]
    if not data or #data == 0 then
        showEmptyState("⚠  No scripts for: " .. tostring(key))
        return
    end
    for _, entry in ipairs(data) do
        if type(entry) == "table"
            and type(entry[1]) == "string"
            and type(entry[2]) == "function"
        then
            makeScriptBtn(entry[1], entry[2])
        end
    end
end

-- Dump every script from every category, tagged with category name
function ContentRenderer.loadAll()
    clearScripts()
    local count = 0
    for catName, hacks in pairs(HubData) do
        if type(hacks) == "table" then
            for _, entry in ipairs(hacks) do
                if type(entry) == "table"
                    and type(entry[1]) == "string"
                    and type(entry[2]) == "function"
                then
                    makeScriptBtn(entry[1], entry[2], catName:sub(1, 8))
                    count += 1
                end
            end
        end
    end
    if count == 0 then showEmptyState("No scripts loaded.") end
end

-- Real-time search across all HubData
function ContentRenderer.search(query)
    clearScripts()
    query = string.lower(query)
    if #query == 0 then
        showEmptyState("Type to search across all scripts...")
        return
    end
    local found = 0
    for catName, hacks in pairs(HubData) do
        if type(hacks) == "table" then
            for _, entry in ipairs(hacks) do
                if type(entry) == "table" and type(entry[1]) == "string" then
                    if string.find(string.lower(entry[1]), query, 1, true) then
                        makeScriptBtn(entry[1], entry[2], catName:sub(1, 8))
                        found += 1
                    end
                end
            end
        end
    end
    if found == 0 then
        showEmptyState('No results for "' .. query .. '"')
    end
end

