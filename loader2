-- ─── Tween helper ────────────────────────────────────────────────────────
local function tw(obj, props, t, style, dir)
	local ti = TweenInfo.new(t or .25, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out)
	local tw2 = TS:Create(obj, ti, props); tw2:Play(); return tw2
end

-- ─── Safe remote loader ──────────────────────────────────────────────────
local function safeLoad(url)
	local ok, r = pcall(function() return loadstring(game:HttpGet(url, true))() end)
	if ok and r then return r end
	return {}
end

