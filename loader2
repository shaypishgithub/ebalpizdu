local UI = {}

-- Frame
function UI.frame(p)
    local f = Instance.new("Frame")
    f.BackgroundColor3       = p.bg    or ThemeManager.get("Surface")
    f.BackgroundTransparency = p.alpha or ThemeManager.get("SurfaceAlpha")
    f.BorderSizePixel        = 0
    f.Size                   = p.size  or UDim2.new(1,0,1,0)
    f.Position               = p.pos   or UDim2.new(0,0,0,0)
    f.ZIndex                 = p.z     or 2
    f.Name                   = p.name  or "Frame"
    if p.clip ~= nil then f.ClipsDescendants = p.clip end
    if p.parent then f.Parent = p.parent end
    return f
end

-- UICorner
function UI.corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = parent
    return c
end

-- UIStroke
function UI.stroke(parent, thickness, color, alpha)
    local s = Instance.new("UIStroke")
    s.Thickness    = thickness or 1.5
    s.Color        = color or ThemeManager.get("Border")
    s.Transparency = alpha or 0.3
    s.Parent       = parent
    ThemeManager.onChanged(function()
        if s and s.Parent then s.Color = ThemeManager.get("Border") end
    end)
    return s
end

-- TextLabel
function UI.label(p)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text             = p.text   or ""
    l.TextColor3       = p.color  or ThemeManager.get(p.muted and "TextMuted" or "Text")
    l.TextSize         = p.size   or 14
    l.Font             = p.font   or Enum.Font.GothamBold
    l.TextTransparency = p.alpha  or 0
    l.TextXAlignment   = p.xalign or Enum.TextXAlignment.Left
    l.TextYAlignment   = p.yalign or Enum.TextYAlignment.Center
    l.TextWrapped      = p.wrap   or false
    l.RichText         = p.rich   or false
    l.Size             = p.sz     or UDim2.new(1,0,0,24)
    l.Position         = p.pos    or UDim2.new(0,0,0,0)
    l.ZIndex           = p.z      or 2
    l.Name             = p.name   or "Label"
    if p.parent then l.Parent = p.parent end
    ThemeManager.onChanged(function()
        if l and l.Parent then
            l.TextColor3 = ThemeManager.get(p.muted and "TextMuted" or "Text")
        end
    end)
    return l
end

-- TextButton  (full hover + press micro-animation)
function UI.button(p)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3       = p.bg    or ThemeManager.get("Elevated")
    btn.BackgroundTransparency = p.alpha or ThemeManager.get("ButtonAlpha")
    btn.BorderSizePixel        = 0
    btn.Text                   = p.text  or "Button"
    btn.TextColor3             = p.color or ThemeManager.get("Text")
    btn.TextSize               = p.tsize or 13
    btn.Font                   = p.font  or Enum.Font.GothamBold
    btn.TextTransparency       = 0
    btn.AutoButtonColor        = false
    btn.Size                   = p.size  or UDim2.new(1, -16, 0, 36)
    btn.Position               = p.pos   or UDim2.new(0, 8, 0, 0)
    btn.ZIndex                 = p.z     or 3
    btn.Name                   = p.name  or "Btn"
    if p.parent then btn.Parent = p.parent end

    UI.corner(btn, p.radius or 8)
    local stk = UI.stroke(btn, 1, ThemeManager.get("Border"), 0.55)

    local baseAlpha = p.alpha or ThemeManager.get("ButtonAlpha")
    local baseSize  = p.size  or UDim2.new(1, -16, 0, 36)

    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundTransparency = math.max(0, baseAlpha - 0.12)}, 0.14)
        tween(stk, {Transparency = 0.1, Color = ThemeManager.get("Accent")}, 0.14)
        tween(btn, {TextColor3 = ThemeManager.get("Accent")}, 0.14)
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundTransparency = baseAlpha}, 0.2)
        tween(stk, {Transparency = 0.55, Color = ThemeManager.get("Border")}, 0.2)
        tween(btn, {TextColor3 = ThemeManager.get("Text")}, 0.2)
    end)
    btn.MouseButton1Down:Connect(function()
        tween(btn, {Size = UDim2.new(baseSize.X.Scale, baseSize.X.Offset + 4,
                                     baseSize.Y.Scale, baseSize.Y.Offset - 4)}, 0.07,
              Enum.EasingStyle.Sine)
    end)
    btn.MouseButton1Up:Connect(function()
        tween(btn, {Size = baseSize}, 0.14, Enum.EasingStyle.Back)
    end)

    if p.callback then
        btn.MouseButton1Click:Connect(function() pcall(p.callback) end)
    end

    ThemeManager.onChanged(function()
        if btn and btn.Parent then
            btn.BackgroundColor3 = ThemeManager.get("Elevated")
            btn.TextColor3       = ThemeManager.get("Text")
            stk.Color            = ThemeManager.get("Border")
        end
    end)
    return btn
end

