--  LOADING SCREEN
-- ════════════════════════════════════════════════════════════════
local function ShowLoading(onDone)
    local ov = Instance.new("Frame")
    ov.Size = UDim2.new(1,0,1,0); ov.BackgroundColor3 = T("BG")
    ov.BackgroundTransparency = 1; ov.BorderSizePixel = 0; ov.ZIndex = 500; ov.Parent = ScreenGui

    local ovg = Instance.new("UIGradient"); ovg.Rotation = 135; ovg.Parent = ov
    local bgConn = RunService.Heartbeat:Connect(function()
        if not (ovg and ovg.Parent) then return end
        ovg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, T("BG")),
            ColorSequenceKeypoint.new(1, T("Surface"):Lerp(T("BG"),0.5)),
        })
        ovg.Offset = Vector2.new(math.sin(tick()*0.3)*0.06, 0)
    end)

    -- Logo card
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0,280,0,110); card.AnchorPoint = Vector2.new(0.5,0.5)
    card.Position = UDim2.new(0.5,0,0.4,0); card.BackgroundColor3 = T("Surface")
    card.BackgroundTransparency = 1; card.BorderSizePixel = 0; card.ZIndex = 501; card.Parent = ov
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,14); c.Parent = card end
    do local s = Instance.new("UIStroke"); s.Color = T("Accent"); s.Thickness = 1; s.Transparency = 0.3; s.Parent = card end

    -- Shimmer on card
    local cg = Instance.new("UIGradient"); cg.Rotation = 45; cg.Parent = card
    local shimConn = RunService.Heartbeat:Connect(function()
        if not (cg and cg.Parent) then return end
        local p = (tick()*0.6) % 1
        local lo = math.clamp(p, 0.01, 0.88)
        local hi = math.clamp(p+0.12, 0.12, 0.99)
        cg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, T("Surface")),
            ColorSequenceKeypoint.new(lo, T("Surface")),
            ColorSequenceKeypoint.new(math.clamp((lo+hi)/2,0.01,0.99), T("Surface"):Lerp(Color3.new(1,1,1),0.06)),
            ColorSequenceKeypoint.new(hi, T("Surface")),
            ColorSequenceKeypoint.new(1, T("Surface")),
        })
    end)

    -- Title
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Text = "MEGAHACK"; titleLbl.Font = Enum.Font.GothamBlack; titleLbl.TextSize = 38
    titleLbl.BackgroundTransparency = 1; titleLbl.TextColor3 = T("Text"); titleLbl.TextTransparency = 1
    titleLbl.Size = UDim2.new(1,-20,0,52); titleLbl.Position = UDim2.new(0,10,0,10)
    titleLbl.TextXAlignment = Enum.TextXAlignment.Center; titleLbl.ZIndex = 502; titleLbl.Parent = card
    do
        local g = Instance.new("UIGradient"); g.Rotation = 0
        g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,T("Accent")),ColorSequenceKeypoint.new(1,T("Accent2"))})
        g.Parent = titleLbl
    end

    local subLbl = Instance.new("TextLabel")
    subLbl.Text = "V 2.0  ·  FULLY REWRITTEN"; subLbl.Font = Enum.Font.GothamMedium; subLbl.TextSize = 11
    subLbl.BackgroundTransparency = 1; subLbl.TextColor3 = T("TextMuted"); subLbl.TextTransparency = 1
    subLbl.Size = UDim2.new(1,-20,0,20); subLbl.Position = UDim2.new(0,10,0,64)
    subLbl.TextXAlignment = Enum.TextXAlignment.Center; subLbl.ZIndex = 502; subLbl.Parent = card

    local byLbl = Instance.new("TextLabel")
    byLbl.Text = "by shaypish"; byLbl.Font = Enum.Font.Gotham; byLbl.TextSize = 10
    byLbl.BackgroundTransparency = 1; byLbl.TextColor3 = T("Accent"); byLbl.TextTransparency = 1
    byLbl.Size = UDim2.new(1,-20,0,16); byLbl.Position = UDim2.new(0,10,0,86)
    byLbl.TextXAlignment = Enum.TextXAlignment.Center; byLbl.ZIndex = 502; byLbl.Parent = card

    -- Progress bar bg
    local barBg = Instance.new("Frame")
    barBg.Size = UDim2.new(0,300,0,5); barBg.AnchorPoint = Vector2.new(0.5,0.5)
    barBg.Position = UDim2.new(0.5,0,0.64,0); barBg.BackgroundColor3 = T("Surface")
    barBg.BorderSizePixel = 0; barBg.ZIndex = 501; barBg.Parent = ov
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,3); c.Parent = barBg end
    do local s = Instance.new("UIStroke"); s.Color = T("Border"); s.Thickness = 1; s.Transparency = 0.4; s.Parent = barBg end

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0,0,1,0); fill.BackgroundColor3 = T("Accent")
    fill.BorderSizePixel = 0; fill.ZIndex = 502; fill.Parent = barBg
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,3); c.Parent = fill end
    do
        local fg = Instance.new("UIGradient"); fg.Rotation = 0
        fg.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,T("Accent")),ColorSequenceKeypoint.new(1,T("Accent2"))})
        fg.Parent = fill
        RunService.Heartbeat:Connect(function()
            if fg and fg.Parent then fg.Offset = Vector2.new(math.sin(tick()*1.6)*0.3,0) end
        end)
    end

    -- Status text
    local statusLbl = Instance.new("TextLabel")
    statusLbl.Text = "Loading..."; statusLbl.Font = Enum.Font.Gotham; statusLbl.TextSize = 11
    statusLbl.BackgroundTransparency = 1; statusLbl.TextColor3 = T("TextMuted"); statusLbl.TextTransparency = 1
    statusLbl.Size = UDim2.new(0,300,0,18); statusLbl.AnchorPoint = Vector2.new(0.5,0.5)
    statusLbl.Position = UDim2.new(0.5,0,0.70,0); statusLbl.TextXAlignment = Enum.TextXAlignment.Center
    statusLbl.ZIndex = 501; statusLbl.Parent = ov

    -- Fade in
    Tw(ov,       {BackgroundTransparency = 0}, 0.4)
    task.wait(0.25)
    Tw(card,     {BackgroundTransparency = 0, Size = UDim2.new(0,280,0,110)}, 0.5, Enum.EasingStyle.Back)
    task.wait(0.2)
    Tw(titleLbl, {TextTransparency = 0}, 0.4)
    task.wait(0.1)
    Tw(subLbl,   {TextTransparency = 0}, 0.3)
    Tw(byLbl,    {TextTransparency = 0}, 0.3)
    task.wait(0.1)
    Tw(statusLbl,{TextTransparency = 0}, 0.3)

    -- Steps
    local steps = {
        {0.15,"Connecting services..."},
        {0.30,"Fetching script data..."},
        {0.50,"Building interface..."},
        {0.68,"Applying theme..."},
        {0.85,"Registering categories..."},
        {1.00,"All systems ready!"},
    }
    for _, s in ipairs(steps) do
        task.wait(0.22)
        Tw(fill, {Size = UDim2.new(s[1],0,1,0)}, 0.3, Enum.EasingStyle.Quart)
        statusLbl.Text = s[2]
    end

    task.wait(0.5)
    bgConn:Disconnect()
    shimConn:Disconnect()
    Tw(ov, {Position = UDim2.new(0,0,-1.02,0)}, 0.55, Enum.EasingStyle.Quart)
    task.wait(0.6)
    pcall(function() ov:Destroy() end)
    if onDone then onDone() end
end

