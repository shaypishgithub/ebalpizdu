--  [6] CATEGORY DATA — Load remote script tables
-- ════════════════════════════════════════════════════════
local HubData    = {}   -- filled during boot
local TotalScripts = 0

local function loadAllData(onProgress)
    local keys  = {}
    for k in pairs(Config.Sources) do table.insert(keys, k) end
    local done  = 0
    local total = #keys

    for _, key in ipairs(keys) do
        HubData[key] = Utils.safeLoad(Config.Sources[key])
        if type(HubData[key]) == "table" then
            TotalScripts = TotalScripts + #HubData[key]
        end
        done = done + 1
        if onProgress then onProgress(done / total) end
        task.wait()   -- yield between loads to stay responsive
    end
end

-- ════════════════════════════════════════════════════════
--  [7] SEARCH ENGINE — Real-time script filtering
-- ════════════════════════════════════════════════════════
local SearchEngine = {}

--- Build a flat index of all scripts for fast searching
---@return table  list of {name, category, func}
function SearchEngine.buildIndex()
    local index = {}
    for cat, scripts in pairs(HubData) do
        if type(scripts) == "table" then
            for _, entry in ipairs(scripts) do
                if type(entry) == "table" and type(entry[1]) == "string" and type(entry[2]) == "function" then
                    table.insert(index, {
                        name     = entry[1],
                        category = cat,
                        func     = entry[2],
                        nameLower = string.lower(entry[1]),
                        catLower  = string.lower(cat),
                    })
                end
            end
        end
    end
    return index
end

local _index = nil   -- lazily built

--- Search scripts by query string (real-time)
---@param query string
---@return table  list of matching {name, category, func}
function SearchEngine.query(query)
    if not _index then _index = SearchEngine.buildIndex() end
    if query == "" then return _index end
    local q   = string.lower(query)
    local out = {}
    for _, entry in ipairs(_index) do
        if string.find(entry.nameLower, q, 1, true)
        or string.find(entry.catLower,  q, 1, true) then
            table.insert(out, entry)
        end
    end
    return out
end

