        local key, label = ti[1], ti[2]
        local btn = Instance.new("TextButton"); btn.Size = UDim2.new(1 / 3, -3, 1, 0)
        btn.BackgroundColor3 = key == selType and T.Accent or T.BgBtn
        btn.BackgroundTransparency = key == selType and 0.2 or 0.4
