--  PAGE: CATEGORY  — builds script cards from HubData[key]
-- ════════════════════════════════════════════════════════════════════════
local function pageCategory(key, displayName)
	clearContent()

	-- Show loading placeholder while scripts may still be fetching
	emptyMsg("⌛  Loading "..displayName.."...")

	task.spawn(function()
		-- If data is still nil, wait up to 10s
		local waited = 0
		while (not HubData[key]) and waited < 10 do
			task.wait(.3)
			waited += .3
		end

		clearContent()

		local data = HubData[key]
		if not data or #data == 0 then
			emptyMsg("⚠  No scripts found for: "..displayName)
			return
		end

		local count = 0
		for _, entry in ipairs(data) do
			if type(entry) == "table"
				and type(entry[1]) == "string"
				and type(entry[2]) == "function"
			then
				makeCard(entry[1], entry[2])
				count += 1
			end
		end

		if count == 0 then
			emptyMsg("⚠  Scripts loaded but none were valid for: "..displayName)
		end
	end)
end

-- ════════════════════════════════════════════════════════════════════════
--  PAGE: ALL SCRIPTS
-- ════════════════════════════════════════════════════════════════════════
local function pageAll()
	clearContent()
	local count = 0
	for catName, hacks in pairs(HubData) do
		if type(hacks) == "table" then
			for _, entry in ipairs(hacks) do
				if type(entry) == "table"
					and type(entry[1]) == "string"
					and type(entry[2]) == "function"
				then
					makeCard(entry[1], entry[2], catName:sub(1,7))
					count += 1
				end
			end
		end
	end
	if count == 0 then
		emptyMsg("⌛  Scripts still loading — try again in a moment")
	end
end

-- ════════════════════════════════════════════════════════════════════════
--  PAGE: SEARCH
-- ════════════════════════════════════════════════════════════════════════
local function pageSearch(query)
	clearContent()
	local q = query:lower()
	if #q == 0 then emptyMsg("Type to search across all categories..."); return end
	local found = 0
	for catName, hacks in pairs(HubData) do
		if type(hacks) == "table" then
			for _, entry in ipairs(hacks) do
				if type(entry) == "table" and type(entry[1]) == "string" then
					if entry[1]:lower():find(q, 1, true) then
						makeCard(entry[1], entry[2], catName:sub(1,7))
						found += 1
					end
				end
			end
		end
	end
	if found == 0 then emptyMsg('No results for "'..query..'"') end
end

