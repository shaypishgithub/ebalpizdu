local function showCategory(key, displayName)
    clearContent()
    sectionHeader(displayName)

    local data = HubData[key]
    if not data or #data == 0 then
        infoCard({"⚠  No scripts loaded for: " .. displayName})
        return
    end
    for _, hack in ipairs(data) do
        if type(hack) == "table" and type(hack[1]) == "string" and type(hack[2]) == "function" then
            scriptBtn(hack[1], hack[2])
        end
    end
end

