local function showSearch()
    clearContent()
    sectionHeader("Search Scripts")

    local searchRow = New("Frame", {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Theme.bg1,
        BackgroundTransparency = 0.05,
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = contentScroll,
    })
    Corner(8, searchRow)
    local searchStroke = Stroke(1, Theme.border, 0.5, searchRow)

    New("TextLabel", {
        Text = "⌕",
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        TextColor3 = Theme.textMuted,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 28, 1, 0),
        Position = UDim2.new(0, 8, 0, 0),
        ZIndex = 5,
        Parent = searchRow,
    })

    local box = New("TextBox", {
        Size = UDim2.new(1, -40, 1, -8),
        Position = UDim2.new(0, 34, 0, 4),
        BackgroundTransparency = 1,
        Text = "",
        PlaceholderText = "Search scripts…",
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = Theme.textPrimary,
        PlaceholderColor3 = Theme.textMuted,
        ZIndex = 5,
        Parent = searchRow,
    })

    box.Focused:Connect(function() tween(searchStroke, {Color = Theme.accent, Transparency = 0.2}) end)
    box.FocusLost:Connect(function()
        tween(searchStroke, {Color = Theme.border, Transparency = 0.5})
        -- rebuild results
        for _, c in ipairs(contentScroll:GetChildren()) do
            if c:GetAttribute("SearchResult") then c:Destroy() end
        end
        local q = string.lower(box.Text)
        if #q < 1 then return end
        local found = 0
        for catName, hacks in pairs(HubData) do
            if type(hacks) == "table" then
                for _, hack in ipairs(hacks) do
                    if type(hack) == "table" and type(hack[1]) == "string" then
                        if string.find(string.lower(hack[1]), q) or string.find(string.lower(catName), q) then
                            local b = scriptBtn("[" .. catName .. "]  " .. hack[1], hack[2])
                            b:SetAttribute("SearchResult", true)
                            found = found + 1
                        end
                    end
                end
            end
        end
        if found == 0 then
            local lbl = New("TextLabel", {
                Text = "No results for "" .. box.Text .. """,
                Font = Enum.Font.Gotham,
                TextSize = 12,
                TextColor3 = Theme.textMuted,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 30),
                ZIndex = 4,
                Parent = contentScroll,
            })
            lbl:SetAttribute("SearchResult", true)
        end
    end)
end

