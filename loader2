    local function applyColor()
        settings.colors[selType] = getC()
        updateGuiColors()
        saveColorSettings()
        createNotification("COLOR SAVED", selType:gsub("Color", "") .. " color applied!", 2)
    end
    applyBtn.MouseButton1Click:Connect(applyColor)

    -- ── Type selector buttons ──────────────────
