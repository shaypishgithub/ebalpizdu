    do local s = Instance.new("UIStroke"); s.Color = T("Border"); s.Thickness = 1; s.Transparency = 0.5; s.Parent = card end

    local nl = Instance.new("TextLabel")
    nl.Text = name; nl.Font = Enum.Font.GothamMedium; nl.TextSize = IsMobile and 11 or 12
    nl.BackgroundTransparency = 1; nl.TextColor3 = T("Text")
    nl.TextTruncate = Enum.TextTruncate.AtEnd
    nl.Size = UDim2.new(1,-80,1,0); nl.Position = UDim2.new(0,10,0,0)
    nl.TextXAlignment = Enum.TextXAlignment.Left; nl.ZIndex = 13; nl.Parent = card

    if tag then
        local tb = Instance.new("Frame")
        tb.Size = UDim2.new(0,52,0,16); tb.Position = UDim2.new(1,-72,0.5,-8)
        tb.BackgroundColor3 = T("BG"); tb.BorderSizePixel = 0; tb.ZIndex = 13; tb.Parent = card
        do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,8); c.Parent = tb end
        do local s = Instance.new("UIStroke"); s.Color = T("Accent2"); s.Thickness = 1; s.Transparency = 0.4; s.Parent = tb end
        local tbl = Instance.new("TextLabel")
        tbl.Text = tag:sub(1,7); tbl.Font = Enum.Font.GothamBold; tbl.TextSize = 9
        tbl.BackgroundTransparency = 1; tbl.TextColor3 = T("Accent2")
        tbl.Size = UDim2.new(1,0,1,0); tbl.TextXAlignment = Enum.TextXAlignment.Center
        tbl.ZIndex = 14; tbl.Parent = tb
    end

    -- RUN button
    local RW, RH = IsMobile and 44 or 38, IsMobile and 24 or 20
    local runBtn = Instance.new("TextButton")
    runBtn.Size = UDim2.new(0,RW,0,RH)
    runBtn.Position = UDim2.new(1,-(RW+6),0.5,-(RH/2))
    runBtn.BackgroundColor3 = T("Accent"); runBtn.BackgroundTransparency = 0.12
    runBtn.BorderSizePixel = 0; runBtn.Text = "RUN"; runBtn.TextColor3 = Color3.new(1,1,1)
    runBtn.TextSize = 10; runBtn.Font = Enum.Font.GothamBold; runBtn.ZIndex = 13; runBtn.Parent = card
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,6); c.Parent = runBtn end
    do
        local g = Instance.new("UIGradient"); g.Rotation = 45
        g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,T("Accent")),ColorSequenceKeypoint.new(1,T("Accent2"))})
        g.Parent = runBtn
    end

    card.MouseEnter:Connect(function() Tw(card, {BackgroundColor3 = T("SurfaceHov")}, 0.12) end)
    card.MouseLeave:Connect(function() Tw(card, {BackgroundColor3 = T("Surface")}, 0.12) end)
    runBtn.MouseEnter:Connect(function() Tw(runBtn, {BackgroundTransparency = 0}, 0.1) end)
    runBtn.MouseLeave:Connect(function() Tw(runBtn, {BackgroundTransparency = 0.12}, 0.1) end)

    runBtn.MouseButton1Click:Connect(function()
        if not fn then return end
        local ok, err = pcall(fn)
        if ok then
            Notify("Executed", name, "success", 2.5)
            Tw(card, {BackgroundColor3 = T("Success"):Lerp(T("Surface"),0.7)}, 0.1)
            task.delay(0.2, function() Tw(card, {BackgroundColor3 = T("Surface")}, 0.4) end)
        else
            Notify("Error", tostring(err):sub(1,65), "error", 5)
            Tw(card, {BackgroundColor3 = T("Error"):Lerp(T("Surface"),0.7)}, 0.1)
            task.delay(0.2, function() Tw(card, {BackgroundColor3 = T("Surface")}, 0.4) end)
        end
    end)
    return card
end

