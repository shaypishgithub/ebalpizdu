local activeSideBtn = nil

local function makeSideBtn(label, onClickCb)
    local ROW_H = isMobile and 38 or 33

    local btn = Instance.new("TextButton")
    btn.Size                 = UDim2.new(1, 0, 0, ROW_H)
    btn.BackgroundColor3     = C("surfaceHover")
    btn.BackgroundTransparency = 1
    btn.BorderSizePixel      = 0
    btn.Text                 = ""
    btn.ZIndex               = 13
    btn.Parent               = sideScroll
    Factory.corner(btn, 6)

    -- Colored left-edge "active" indicator
    local activeBar = Factory.frame({
        bg       = C("accent1"),
        size     = UDim2.new(0, 3, 0.55, 0),
        position = UDim2.new(0, 0, 0.225, 0),
        corner   = 2,
        zIndex   = 14,
        parent   = btn,
    })
    activeBar.Visible = false

    local lbl = Factory.label({
        text     = label,
        color    = C("textMuted"),
        size     = isMobile and 10 or 11,
        font     = Enum.Font.GothamMedium,
        alignX   = Enum.TextXAlignment.Center,
        sizeUDim = UDim2.new(1, -4, 1, 0),
        position = UDim2.new(0, 2, 0, 0),
        zIndex   = 14,
        parent   = btn,
    })

    -- Make this button look "selected"
    local function activate()
        activeBar.Visible = true
        Anim.tween(btn, {BackgroundTransparency = 0.62}, 0.18)
        Anim.tween(lbl, {TextColor3 = C("accent1")}, 0.18)
    end

    -- Make this button look "idle"
    local function deactivate()
        activeBar.Visible = false
        Anim.tween(btn, {BackgroundTransparency = 1}, 0.18)
        Anim.tween(lbl, {TextColor3 = C("textMuted")}, 0.18)
    end

    btn.MouseEnter:Connect(function()
        if activeSideBtn ~= btn then
            Anim.tween(btn, {BackgroundTransparency = 0.82}, 0.12)
            Anim.tween(lbl, {TextColor3 = C("text")}, 0.12)
        end
    end)

    btn.MouseLeave:Connect(function()
        if activeSideBtn ~= btn then
            Anim.tween(btn, {BackgroundTransparency = 1}, 0.12)
            Anim.tween(lbl, {TextColor3 = C("textMuted")}, 0.12)
        end
    end)

    btn.MouseButton1Click:Connect(function()
        -- Deactivate previous
        if activeSideBtn and activeSideBtn ~= btn then
            -- Access the deactivate closure stored on the button
            if activeSideBtn._deactivate then activeSideBtn._deactivate() end
        end
        activeSideBtn = btn
        activate()

        -- Press spring
        Anim.spring(btn, {Size = UDim2.new(0.95, 0, 0, ROW_H - 2)}, 0.12)
        task.delay(0.12, function()
            Anim.spring(btn, {Size = UDim2.new(1, 0, 0, ROW_H)}, 0.22)
        end)

        onClickCb()
    end)

    btn._deactivate = deactivate
    return btn
end

