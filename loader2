--  [8d] SETTINGS PAGE
-- ════════════════════════════════════════════════════════
local function showSettings()
    clearContent()
    local scroll = UI.contentScroll
    local theme  = ThemeManager.get()

    -- ── Theme selector ───────────────────────────────────
    makeSectionHeader("Theme", scroll)
    for themeKey, themeData in pairs(Config.Themes) do
        local isActive = (themeKey == State.themeName)
        makeButton(
            (isActive and "✓ " or "  ") .. themeData.name,
            scroll,
            function()
                State.themeName = themeKey
                ThemeManager.set(themeKey)
                createNotification("Theme", themeData.name .. " applied", 2, "info")
                showSettings()
            end,
            isActive
        )
    end

    -- ── Gradient toggle ──────────────────────────────────
    makeSectionHeader("Effects", scroll)
    makeButton(
        "Animated Gradient: " .. (State.gradientEnabled and "ON" or "OFF"),
        scroll,
        function()
            State.gradientEnabled = not State.gradientEnabled
            if State.gradientEnabled then
                ThemeManager.animateGradient(
                    UI.mainStroke:FindFirstChildWhichIsA("UIGradient") or Utils.create("UIGradient", {Rotation=45}, UI.mainStroke),
                    ThemeManager.get().gradKey
                )
            else
                ThemeManager.stopGradients()
            end
            createNotification("Effects", "Gradient " .. (State.gradientEnabled and "enabled" or "disabled"), 2, "info")
            showSettings()
        end
    )

    makeButton(
        "Lock GUI Dragging: " .. (State.locked and "ON" or "OFF"),
        scroll,
        function()
            State.locked = not State.locked
            createNotification("Settings", "Drag lock " .. (State.locked and "enabled" or "disabled"), 2, "info")
            showSettings()
        end
    )

    -- ── Server tools ─────────────────────────────────────
    makeSectionHeader("Server", scroll)

    makeButton("Rejoin", scroll, function()
        local ok, err = pcall(function()
            Services.TeleportService:Teleport(game.PlaceId, Player)
        end)
        if not ok then createNotification("Error", "Rejoin failed: " .. tostring(err), 5, "error") end
    end)

    makeButton("Server Hop", scroll, function()
        local ok, err = pcall(function()
            local json = game:HttpGet(
                "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
            )
            local servers = Services.HttpService:JSONDecode(json)
            if servers.data and #servers.data > 0 then
                local picked = servers.data[math.random(1, #servers.data)]
                Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, picked.id, Player)
            else
                createNotification("Error", "No public servers found", 4, "warn")
            end
        end)
        if not ok then createNotification("Error", tostring(err), 5, "error") end
    end)

    makeButton("Copy Server ID", scroll, function()
        local ok, err = pcall(function() setclipboard(game.JobId) end)
        if ok then createNotification("Copied", "Server ID copied!", 2.5, "success")
        else createNotification("Error", tostring(err), 5, "error") end
    end)

    -- ── Coordinates ──────────────────────────────────────
    makeSectionHeader("Coordinates", scroll)

    makeButton("Save Current Position", scroll, function()
        local char = Player.Character or Player.CharacterAdded:Wait()
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then
            createNotification("Error", "No HumanoidRootPart", 4, "error")
            return
        end
        local p = root.Position
        local str = string.format("X=%.2f Y=%.2f Z=%.2f", p.X, p.Y, p.Z)
        if isfolder and not isfolder("MegaHack") then makefolder("MegaHack") end
        if writefile then writefile("MegaHack/coords.txt", str) end
        createNotification("Saved", str, 4, "success")
    end)

    makeButton("Teleport to Saved Position", scroll, function()
        if not (isfile and isfile("MegaHack/coords.txt")) then
            createNotification("Error", "No saved position found", 4, "warn")
            return
        end
        local txt = readfile("MegaHack/coords.txt")
        local x, y, z = txt:match("X=([%d%.%-]+) Y=([%d%.%-]+) Z=([%d%.%-]+)")
        if x and y and z then
            local char = Player.Character or Player.CharacterAdded:Wait()
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = CFrame.new(tonumber(x), tonumber(y), tonumber(z))
                createNotification("Teleported", txt, 3, "success")
            end
        else
            createNotification("Error", "Invalid saved format", 4, "error")
        end
    end)

    -- ── Security ─────────────────────────────────────────
    makeSectionHeader("Security", scroll)

    makeButton("Enable Anti-Ban / Anti-Kick", scroll, function()
        local ok, err = pcall(function()
            local mt = getrawmetatable(game)
            if not mt then error("No metatable") end
            local oldNamecall = mt.__namecall
            setreadonly(mt, false)
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                if method == "Kick" or method == "kick" then
                    createNotification("Blocked", "Kick attempt blocked!", 3, "warn")
                    return nil
                end
                if method == "Ban" or method == "ban" then
                    createNotification("Blocked", "Ban attempt blocked!", 3, "warn")
                    return nil
                end
                return oldNamecall(self, ...)
            end)
            setreadonly(mt, true)
        end)
        if ok then createNotification("Protection", "Anti-Ban/Kick active", 3, "success")
        else    createNotification("Error", tostring(err), 5, "error") end
    end)

    makeButton("Check Executor Functions", scroll, function()
        local check = {
            "getrawmetatable", "setreadonly", "hookfunction", "newcclosure",
            "loadstring", "getgc", "gethui", "setclipboard",
            "writefile", "readfile", "makefolder", "isfolder",
        }
        local avail, unavail = 0, 0
        for _, fn in ipairs(check) do
            if _G[fn] ~= nil then avail = avail + 1 else unavail = unavail + 1 end
        end
        createNotification("Functions", avail .. " available / " .. unavail .. " missing", 5, "info")
    end)

    -- ── GUI controls ─────────────────────────────────────
    makeSectionHeader("GUI", scroll)

    makeButton("Close GUI", scroll, function()
        UI.screenGui:Destroy()
    end, false)
end

