--  Sidebar — build + navigation
-- ════════════════════════════════════════════════════════
function UI.buildSidebar()
    local theme   = ThemeManager.get()
    local sidebar = UI.sidebar

    for _, child in ipairs(sidebar:GetChildren()) do
        if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
            child:Destroy()
        end
    end
    UI.sideButtons = {}

    for _, name in ipairs(Config.CategoryOrder) do
        -- Section separator labels (start with ──)
        if name:sub(1, 2) == "──" then
            Utils.create("TextLabel", {
                Text                 = name,
                Font                 = Enum.Font.GothamBold,
                TextSize             = 9,
                TextColor3           = theme.textMuted,
                BackgroundTransparency = 1,
                Size                 = UDim2.new(1, -8, 0, 18),
                TextXAlignment       = Enum.TextXAlignment.Left,
                ZIndex               = Config.UI.zIndex + 1,
            }, sidebar)
        else
            local isActive = (name == State.activeCategory)
            local btn = Utils.create("TextButton", {
                Text                   = name,
                Font                   = Enum.Font.GothamBold,
                TextSize               = 11,
                TextColor3             = isActive and theme.accent or theme.textMuted,
                BackgroundColor3       = isActive and theme.bgTertiary or theme.bgSecondary,
                BackgroundTransparency = isActive and 0 or 0.5,
                BorderSizePixel        = 0,
                Size                   = UDim2.new(1, -8, 0, IsMobile and 36 or 28),
                AutoButtonColor        = false,
                ZIndex                 = Config.UI.zIndex + 1,
            }, sidebar)
            Utils.corner(btn, 6)

            -- Active indicator bar
            local indicator = Utils.create("Frame", {
                Size             = UDim2.new(0, 3, 0.7, 0),
                Position         = UDim2.new(0, 0, 0.15, 0),
                BackgroundColor3 = isActive and theme.accent or Color3.new(0,0,0),
                BackgroundTransparency = isActive and 0 or 1,
                BorderSizePixel  = 0,
                ZIndex           = Config.UI.zIndex + 2,
            }, btn)
            Utils.corner(indicator, 2)

            -- Hover effect
            btn.MouseEnter:Connect(function()
                if State.activeCategory ~= name then
                    Utils.tweenPlay(btn, Utils.tweenInfo(Config.Anim.hoverDuration), {
                        BackgroundTransparency = 0.25,
                        TextColor3             = theme.text,
                    })
                end
            end)
            btn.MouseLeave:Connect(function()
                if State.activeCategory ~= name then
                    Utils.tweenPlay(btn, Utils.tweenInfo(Config.Anim.hoverDuration), {
                        BackgroundTransparency = 0.5,
                        TextColor3             = theme.textMuted,
                    })
                end
            end)

            btn.MouseButton1Click:Connect(function()
                -- Click scale bounce
                Utils.tweenPlay(btn, Utils.tweenInfo(0.08), {Size = UDim2.new(1, -12, 0, IsMobile and 33 or 25)})
                task.delay(0.09, function()
                    Utils.tweenPlay(btn, Utils.tweenInfo(0.12, Enum.EasingStyle.Back), {
                        Size = UDim2.new(1, -8, 0, IsMobile and 36 or 28)
                    })
                end)

                State.activeCategory = name
                UI.refreshSidebar()
                UI.navigate(name)
            end)

            UI.sideButtons[name] = {btn = btn, indicator = indicator}
        end
    end
end

function UI.refreshSidebar()
    local theme = ThemeManager.get()
    for name, data in pairs(UI.sideButtons) do
        local isActive = (name == State.activeCategory)
        data.btn.TextColor3             = isActive and theme.accent or theme.textMuted
        data.btn.BackgroundColor3       = isActive and theme.bgTertiary or theme.bgSecondary
        data.btn.BackgroundTransparency = isActive and 0 or 0.5
        data.indicator.BackgroundColor3 = isActive and theme.accent or Color3.new(0,0,0)
        data.indicator.BackgroundTransparency = isActive and 0 or 1
    end
end

