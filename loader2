-- ════════════════════════════════════════════════════════
local function showSearch()
    clearContent()
    local scroll  = UI.contentScroll
    local theme   = ThemeManager.get()
    local results = {}

    -- Search bar
    local searchBox = Utils.create("TextBox", {
        Text                   = "",
        PlaceholderText        = "🔍  Search scripts…",
        Font                   = Enum.Font.Gotham,
        TextSize               = 12,
        TextColor3             = theme.text,
        PlaceholderColor3      = theme.textMuted,
        BackgroundColor3       = theme.bgTertiary,
        BackgroundTransparency = 0.1,
        BorderSizePixel        = 0,
        Size                   = UDim2.new(1, 0, 0, IsMobile and 40 or 32),
        ZIndex                 = Config.UI.zIndex + 2,
        ClearTextOnFocus       = false,
    }, scroll)
    Utils.corner(searchBox, 8)
    Utils.padding(searchBox, 0, 0, 0, 0, 10)
    local sbStroke = Utils.stroke(searchBox, theme.accent, 1, 0.5)

    searchBox.Focused:Connect(function()
        Utils.tweenPlay(sbStroke, Utils.tweenInfo(0.2), {Transparency = 0, Thickness = 1.5})
    end)
    searchBox.FocusLost:Connect(function()
        Utils.tweenPlay(sbStroke, Utils.tweenInfo(0.2), {Transparency = 0.5, Thickness = 1})
    end)

    -- Results container
    local resultsFrame = Utils.create("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 0),  -- grows with layout
        AutomaticSize          = Enum.AutomaticSize.Y,
        ZIndex                 = Config.UI.zIndex + 1,
    }, scroll)
    local rLayout = Utils.listLayout(resultsFrame, 5)
    Utils.autoCanvasSize(scroll, rLayout)

    local countLabel = makeLabel("Type to search…", resultsFrame, UDim2.new(1,0,0,20), 11)
    countLabel.TextColor3 = theme.textMuted

    local function renderResults(list)
        for _, c in ipairs(resultsFrame:GetChildren()) do
            if c ~= rLayout and c ~= countLabel then c:Destroy() end
        end

        if #list == 0 then
            countLabel.Text = "No results found"
            return
        end
        countLabel.Text = #list .. " result" .. (#list == 1 and "" or "s") .. " found"

        for i, entry in ipairs(list) do
            if i > 80 then break end   -- cap render
            makeButton(
                "[" .. entry.category .. "]  " .. entry.name,
                resultsFrame,
                function()
                    local ok, err = pcall(entry.func)
                    if not ok then
                        createNotification("Script Error", tostring(err), 5, "error")
                    else
                        createNotification("Executed", entry.name, 2.5, "success")
                    end
                end
            )
        end
    end

    -- Real-time search on text change
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q = searchBox.Text
        if #q < 1 then
            countLabel.Text = "Type to search…"
            for _, c in ipairs(resultsFrame:GetChildren()) do
                if c ~= rLayout and c ~= countLabel then c:Destroy() end
            end
            return
        end
        task.defer(function()
            if searchBox.Text ~= q then return end  -- debounce
            renderResults(SearchEngine.query(q))
        end)
    end)
end

