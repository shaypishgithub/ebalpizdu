                    obj.Color = Color3.fromHSV(hue, 1, 1)
                end)
                table.insert(rgbConnections, connection)
            else
                obj.Color = settings.colors.strokeColor
                obj.Transparency = 0.5
            end
        end
    end

    for _, obj in pairs(reopenButton:GetDescendants()) do
        if obj:IsA("UIStroke") then
            if settings.rgbStroke then
                local connection
                connection = RunService.Heartbeat:Connect(function(t)
                    if not obj:IsDescendantOf(reopenButton) then
                        connection:Disconnect()
                        return
                    end
                    local hue = (tick() % 5) / 5
                    obj.Color = Color3.fromHSV(hue, 1, 1)
                end)
                table.insert(rgbConnections, connection)
            else
                obj.Color = settings.colors.strokeColor
                obj.Transparency = 0.5
            end
        end
    end

    updateAllTextColors()
end

