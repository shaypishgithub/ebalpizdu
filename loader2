    fpsLbl.TextXAlignment = Enum.TextXAlignment.Left; fpsLbl.ZIndex = 13; fpsLbl.Parent = fc
    local fN, fL = 0, tick()
    local fConn = RunService.Heartbeat:Connect(function()
        fN = fN + 1
        if tick()-fL >= 1 then
            if fpsLbl and fpsLbl.Parent then fpsLbl.Text = "FPS: "..fN
            else return end
            fN, fL = 0, tick()
        end
    end)
    fc.Destroying:Connect(function() fConn:Disconnect() end)
end

local function RenderSettings()
    ClearScripts()
    local function Section(name)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1,0,0,22); f.BackgroundTransparency = 1
        f.BorderSizePixel = 0; f.ZIndex = 12; f.Parent = ScriptScroll
        local l = Instance.new("TextLabel")
        l.Text = name:upper(); l.Font = Enum.Font.GothamBold; l.TextSize = 9
        l.BackgroundTransparency = 1; l.TextColor3 = T("Accent2")
        l.Size = UDim2.new(1,-8,1,0); l.Position = UDim2.new(0,8,0,0)
        l.TextXAlignment = Enum.TextXAlignment.Left; l.ZIndex = 13; l.Parent = f
        local line = Instance.new("Frame")
        line.Size = UDim2.new(1,-8,0,1); line.Position = UDim2.new(0,4,1,-1)
        line.BackgroundColor3 = T("Border"); line.BorderSizePixel = 0
        line.BackgroundTransparency = 0.5; line.ZIndex = 13; line.Parent = f
    end
    local function ActionBtn(txt, cb)
        local BH = IsMobile and 36 or 30
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1,0,0,BH); b.BackgroundColor3 = T("Surface")
        b.BackgroundTransparency = 0; b.BorderSizePixel = 0
        b.Text = txt; b.TextColor3 = T("Text"); b.TextSize = IsMobile and 12 or 11
        b.Font = Enum.Font.GothamMedium; b.ZIndex = 12; b.Parent = ScriptScroll
        do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,7); c.Parent = b end
        do local s = Instance.new("UIStroke"); s.Color = T("Border"); s.Thickness = 1; s.Transparency = 0.5; s.Parent = b end
        b.MouseEnter:Connect(function() Tw(b,{BackgroundColor3=T("SurfaceHov")},0.1) end)
        b.MouseLeave:Connect(function() Tw(b,{BackgroundColor3=T("Surface")},0.1) end)
        b.MouseButton1Click:Connect(cb)
        return b
    end

    Section("Themes")
    for name, _ in pairs(Themes) do
        ActionBtn("◈  "..name, function()
            SetTheme(name)
            Notify("Theme", name.." applied!", "success", 2.5)
        end)
    end

    Section("Server")
    ActionBtn("↺  Rejoin", function()
        local ok, e = pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
        if not ok then Notify("Rejoin Failed", e:sub(1,50), "error") end
    end)
    ActionBtn("⤢  Server Hop", function()
        local ok, e = pcall(function()
            local r = HttpService:JSONDecode(game:HttpGet(
                "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
            if r.data and #r.data > 0 then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, r.data[math.random(1,#r.data)].id, LocalPlayer)
            else Notify("Server Hop","No servers found.","warning") end
        end)
        if not ok then Notify("Server Hop Failed", tostring(e):sub(1,50), "error") end
    end)
    ActionBtn("⊞  Copy Server ID", function()
        local ok = pcall(function() setclipboard(game.JobId) end)
        Notify("Clipboard", ok and "Server ID copied!" or "setclipboard not supported", ok and "success" or "warning", 2.5)
    end)

    Section("Security")
    ActionBtn("⚑  Enable Anti-Kick / Anti-Ban", function()
        local ok = pcall(function()
            local mt = getrawmetatable(game); local old = mt.__namecall
            setreadonly(mt, false)
            mt.__namecall = newcclosure(function(self, ...)
                local m = getnamecallmethod()
                if m=="Kick" or m=="Ban" then
                    Notify("Blocked","Kick/Ban attempt stopped.","warning"); return nil
                end
                return old(self, ...)
            end)
            setreadonly(mt, true)
        end)
        Notify("Security", ok and "Anti-Kick/Ban enabled!" or "Executor unsupported.", ok and "success" or "warning")
    end)

    Section("GUI")
    ActionBtn("✕  Close GUI", function()
        pcall(function() ScreenGui:Destroy() end)
    end)
end

