--  MODULE 6 · NOTIFICATION SYSTEM
--  ─────────────────────────────────────────────────────────────────────────
--  Up to 5 stacked toasts slide in from the right.
--  Types: "info" | "success" | "error" | "warning"
-- ═══════════════════════════════════════════════════════════════════════════
local activeNotifs = 0
local MAX_NOTIFS   = 5

local function notify(title, message, notifType, duration)
    if activeNotifs >= MAX_NOTIFS then return end
    activeNotifs += 1
    duration    = duration    or 3.5
    notifType   = notifType   or "info"

    local accentMap = {
        info    = C("accent1"),
        success = C("success"),
        error   = C("error"),
        warning = C("warning"),
    }
    local accent = accentMap[notifType] or C("accent1")
    local slot   = activeNotifs

    -- Card
    local card = Factory.frame({
        name         = "Notif_" .. tostring(slot),
        bg           = C("surface"),
        size         = UDim2.new(0, 288, 0, 62),
        position     = UDim2.new(1, 12, 1, -(68 * slot)),
        anchor       = Vector2.new(0, 1),
        corner       = 10,
        zIndex       = 200,
        parent       = screenGui,
    })
    Factory.stroke(card, accent, 1, 0.25)

    -- Left accent bar
    Factory.frame({
        bg       = accent,
        size     = UDim2.new(0, 3, 0.6, 0),
        position = UDim2.new(0, 6, 0.2, 0),
        corner   = 2,
        zIndex   = 201,
        parent   = card,
    })

    Factory.label({
        text     = title,
        color    = C("text"),
        size     = 13,
        font     = Enum.Font.GothamBold,
        sizeUDim = UDim2.new(1, -28, 0, 22),
        position = UDim2.new(0, 18, 0, 8),
        zIndex   = 201,
        parent   = card,
    })

    Factory.label({
        text     = message,
        color    = C("textMuted"),
        size     = 11,
        font     = Enum.Font.Gotham,
        sizeUDim = UDim2.new(1, -28, 0, 24),
        position = UDim2.new(0, 18, 0, 30),
        zIndex   = 201,
        wrap     = true,
        parent   = card,
    })

    -- Progress drain bar
    local drain = Factory.frame({
        bg     = accent,
        size   = UDim2.new(1, -14, 0, 2),
        position = UDim2.new(0, 7, 1, -4),
        corner = 1,
        zIndex = 201,
        parent = card,
    })

    -- Slide in
    Anim.spring(card, {Position = UDim2.new(1, -298, 1, -(68 * slot))}, 0.45)
    -- Drain bar
    Anim.tween(drain, {Size = UDim2.new(0, 0, 0, 2)}, duration, Enum.EasingStyle.Linear)

    task.delay(duration, function()
        Anim.tween(card, {Position = UDim2.new(1, 12, 1, -(68 * slot))}, 0.3)
        task.wait(0.35)
        if card and card.Parent then card:Destroy() end
        activeNotifs = math.max(0, activeNotifs - 1)
    end)
end

