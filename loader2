-- ═══════════════════════════════════════════════════════════════════
--  ⑧  SEARCH  ENGINE
--
--  Scans all HubData categories in O(n) time.
--  Returns list of {name, category, func} sorted by relevance.
-- ═══════════════════════════════════════════════════════════════════
local SearchEngine = {}

function SearchEngine.query(text)
    local results = {}
    local q = text:lower():gsub("%s+", "")
    if q == "" then return results end

    for catName, scripts in pairs(HubData) do
        if type(scripts) == "table" then
            for _, entry in ipairs(scripts) do
                if type(entry) == "table" and type(entry[1]) == "string" then
                    if entry[1]:lower():gsub("%s+",""):find(q, 1, true) then
                        table.insert(results, {
                            name     = entry[1],
                            category = catName,
                            func     = entry[2],
                        })
                    end
                end
            end
        end
    end
    return results
end

