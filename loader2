--  MODULE 5 · LOADING SCREEN
--  ─────────────────────────────────────────────────────────────────────────
--  Sequence: fade-in → logo reveal → shimmer bar → progress steps → slide-out
-- ═══════════════════════════════════════════════════════════════════════════
local LoadingScreen = {}

function LoadingScreen.show(onComplete)

    -- Full-screen overlay
    local overlay = Factory.frame({
        name         = "LoadingOverlay",
        bg           = C("bg"),
        size         = UDim2.new(1, 0, 1, 0),
        zIndex       = 100,
        parent       = screenGui,
        clip         = true,
    })

    -- Animated diagonal background shimmer
    local bgGrad = Instance.new("UIGradient")
    bgGrad.Rotation = 135
    bgGrad.Parent   = overlay
    GradientAnimator.shimmer(bgGrad, C("bg"), C("bgSecondary"), 0.35)

    -- ── Logo card ────────────────────────────────────────────────────────
    local logoCard = Factory.frame({
        bg           = C("surface"),
        size         = UDim2.new(0, 300, 0, 100),
        position     = UDim2.new(0.5, 0, 0.38, 0),
        anchor       = Vector2.new(0.5, 0.5),
        corner       = 16,
        zIndex       = 101,
        parent       = overlay,
    })
    Factory.stroke(logoCard, C("accent1"), 1, 0.35)
    local logoCardGrad = Instance.new("UIGradient")
    logoCardGrad.Rotation = 135
    logoCardGrad.Parent   = logoCard
    GradientAnimator.shimmer(logoCardGrad, C("surface"), C("bgSecondary"), 0.6)

    local logoText = Factory.label({
        text     = "MEGAHACK",
        color    = C("text"),
        size     = 36,
        font     = Enum.Font.GothamBlack,
        alignX   = Enum.TextXAlignment.Center,
        sizeUDim = UDim2.new(1, -20, 0, 52),
        position = UDim2.new(0, 10, 0, 8),
        zIndex   = 102,
        parent   = logoCard,
    })
    -- Gradient colors on logo text label itself
    local logoGrad = Factory.gradient(logoText, C("accent1"), C("accent2"), 0)
    GradientAnimator.offsetSweep(logoGrad, 0.7)

    Factory.label({
        text     = "V 2.0  ·  ULTRA EDITION",
        color    = C("textMuted"),
        size     = 11,
        font     = Enum.Font.GothamMedium,
        alignX   = Enum.TextXAlignment.Center,
        sizeUDim = UDim2.new(1, -20, 0, 20),
        position = UDim2.new(0, 10, 0, 64),
        zIndex   = 102,
        parent   = logoCard,
    })

    -- ── Progress bar ─────────────────────────────────────────────────────
    local barBg = Factory.frame({
        bg       = C("surface"),
        size     = UDim2.new(0, 320, 0, 6),
        position = UDim2.new(0.5, 0, 0.60, 0),
        anchor   = Vector2.new(0.5, 0.5),
        corner   = 3,
        zIndex   = 101,
        parent   = overlay,
    })
    Factory.stroke(barBg, C("border"), 1, 0.4)

    local barFill = Factory.frame({
        bg     = C("accent1"),
        size   = UDim2.new(0, 0, 1, 0),
        corner = 3,
        zIndex = 102,
        parent = barBg,
    })
    -- Shimmer on bar fill
    local barGrad = Instance.new("UIGradient")
    barGrad.Rotation = 0
    barGrad.Parent   = barFill
    GradientAnimator.shimmer(barGrad, C("accent1"), C("accent2"), 2.5)

    -- ── Status text ───────────────────────────────────────────────────────
    local statusLabel = Factory.label({
        text     = "Initializing systems...",
        color    = C("textMuted"),
        size     = 11,
        font     = Enum.Font.Gotham,
        alignX   = Enum.TextXAlignment.Center,
        sizeUDim = UDim2.new(0, 320, 0, 20),
        position = UDim2.new(0.5, 0, 0.66, 0),
        anchor   = Vector2.new(0.5, 0.5),
        zIndex   = 101,
        parent   = overlay,
    })

    -- ── Bouncing dots ────────────────────────────────────────────────────
    local dotsRow = Factory.frame({
        bg           = Color3.new(0,0,0),
        transparency = 1,
        size         = UDim2.new(0, 50, 0, 10),
        position     = UDim2.new(0.5, 0, 0.74, 0),
        anchor       = Vector2.new(0.5, 0.5),
        zIndex       = 101,
        parent       = overlay,
    })
    Factory.listLayout(dotsRow, Enum.FillDirection.Horizontal, 9, Enum.HorizontalAlignment.Center)
    for i = 1, 3 do
        local dot = Factory.frame({
            bg     = C("accent1"),
            size   = UDim2.new(0, 8, 0, 8),
            corner = 4,
            zIndex = 102,
            parent = dotsRow,
        })
        -- Each dot pulses with an offset delay
        task.spawn(function()
            while dot and dot.Parent do
                task.wait(0.35 * i - 0.35)
                if not (dot and dot.Parent) then break end
                Anim.tween(dot, {BackgroundTransparency = 0}, 0.25)
                task.wait(0.25)
                if not (dot and dot.Parent) then break end
                Anim.tween(dot, {BackgroundTransparency = 0.75}, 0.25)
                task.wait(0.55)
            end
        end)
    end

    -- ── Intro animation ───────────────────────────────────────────────────
    overlay.BackgroundTransparency = 1
    logoCard.BackgroundTransparency = 1
    logoText.TextTransparency = 1
    statusLabel.TextTransparency = 1

    Anim.tween(overlay,  {BackgroundTransparency = 0}, 0.5)
    task.wait(0.35)
    Anim.spring(logoCard,  {BackgroundTransparency = 0, Size = UDim2.new(0, 300, 0, 100)}, 0.55)
    task.wait(0.2)
    Anim.tween(logoText,   {TextTransparency = 0}, 0.45)
    task.wait(0.15)
    Anim.tween(statusLabel,{TextTransparency = 0}, 0.3)

    -- ── Progress steps ───────────────────────────────────────────────────
    local steps = {
        { 0.18, "Loading services..."      },
        { 0.35, "Fetching script modules..." },
        { 0.52, "Building UI components..."  },
        { 0.68, "Applying theme system..."   },
        { 0.83, "Registering categories..."  },
        { 1.00, "Ready!"                     },
    }
    for _, step in ipairs(steps) do
        task.wait(0.28)
        Anim.tween(barFill, {Size = UDim2.new(step[1], 0, 1, 0)}, 0.38, Enum.EasingStyle.Quart)
        if statusLabel and statusLabel.Parent then
            statusLabel.Text = step[2]
        end
    end

    task.wait(0.5)

    -- ── Outro: slide-up fade ──────────────────────────────────────────────
    Anim.tween(overlay, {Position = UDim2.new(0, 0, -1, 0)}, 0.65, Enum.EasingStyle.Quart)
    task.wait(0.7)
    overlay:Destroy()

    if onComplete then onComplete() end
end

