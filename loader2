        btn.MouseButton1Click:Connect(function()
            selType = key
            local c2 = settings.colors[selType]
            h, s, v = Color3.toHSV(c2); updateUI()
            for k, b2 in pairs(typeButtons) do
                TweenService:Create(b2, TweenInfo.new(0.15), {
                    BackgroundColor3    = k == selType and T.Accent  or T.BgBtn,
                    BackgroundTransparency = k == selType and 0.2 or 0.4,
                    TextColor3          = k == selType and T.TextMain or T.TextSub,
                }):Play()
            end
        end)
    end

    -- ── Drag state ─────────────────────────────
    local drag = { sv = false, hue = false, r = false, g = false, b = false }

    -- SV square mouse down
    bF.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            drag.sv = true
            local ap = sqF.AbsolutePosition; local as = sqF.AbsoluteSize
