    sectionHeader("Accent Color")
    colorPickerPanel()

    spacer(4)
    sectionHeader("Color Presets")
    presetColorRow("Preset", {
        {name="Cyan",    color=Color3.fromRGB(0, 200, 255)},
        {name="Purple",  color=Color3.fromRGB(180, 80, 255)},
        {name="Green",   color=Color3.fromRGB(0, 220, 120)},
        {name="Pink",    color=Color3.fromRGB(255, 80, 180)},
        {name="Orange",  color=Color3.fromRGB(255, 150, 0)},
        {name="Red",     color=Color3.fromRGB(255, 60, 60)},
        {name="Gold",    color=Color3.fromRGB(220, 180, 0)},
        {name="White",   color=Color3.fromRGB(220, 220, 255)},
    })

    spacer(8)
    sectionHeader("Interface")
    toggleBtn("RGB Accent  (rainbow mode)", false, function(on)
        if on then
            RunService.Heartbeat:Connect(function()
                local h = (tick() % 5) / 5
                updateAccent(h, 1, 1)
                applyAccentToAll()
            end)
        end
    end)

    spacer(4)
    sectionHeader("Server")
    actionBtn("◈  Rejoin Server", Theme.bg3, function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
    actionBtn("◈  Server Hop (random)", Theme.bg3, function()
        local data = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        local list = data.data
        if #list > 0 then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, list[math.random(1, #list)].id, player)
        else
            notify("ERROR", "No servers found", 3, Theme.error)
        end
    end)
    actionBtn("◈  Copy Server ID", Theme.bg3, function()
        setclipboard(game.JobId)
        notify("COPIED", "Server ID in clipboard", 2, Theme.success)
    end)

    spacer(4)
    sectionHeader("Security")
    actionBtn("◈  Enable Anti-Ban / Anti-Kick", Theme.accentDim, function()
        local mt = getrawmetatable(game)
        if not mt then notify("WARN", "getrawmetatable unavailable", 3, Theme.warn); return end
        local old = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local m = getnamecallmethod()
            if m == "Kick" or m == "kick" or m == "Ban" or m == "ban" then
                notify("BLOCKED", m .. " attempt intercepted", 3, Theme.success)
                return nil
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
        notify("PROTECTION", "Anti-ban/kick active", 3, Theme.success)
    end)

    spacer(4)
    sectionHeader("Coordinates")
    actionBtn("◈  Save Current Position", Theme.bg3, function()
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then notify("ERROR", "No HRP", 3, Theme.error); return end
        local p = root.Position
        local txt = string.format("X:%.2f Y:%.2f Z:%.2f", p.X, p.Y, p.Z)
        if makefolder and not isfolder("MegaHack") then makefolder("MegaHack") end
        if writefile then writefile("MegaHack/coords.txt", txt) end
        notify("SAVED", txt, 3, Theme.success)
    end)
    actionBtn("◈  Teleport to Saved Position", Theme.bg3, function()
        if not (isfile and isfile("MegaHack/coords.txt")) then
            notify("ERROR", "No saved coords", 3, Theme.error); return
        end
        local txt = readfile("MegaHack/coords.txt")
        local x, y, z = txt:match("X:([%d%.%-]+) Y:([%d%.%-]+) Z:([%d%.%-]+)")
        if not x then notify("ERROR", "Bad format", 3, Theme.error); return end
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = CFrame.new(tonumber(x), tonumber(y), tonumber(z))
            notify("TELEPORT", txt, 3, Theme.success)
        end
    end)

    spacer(4)
    sectionHeader("Danger Zone")
    actionBtn("✕  Close GUI", Color3.fromRGB(180, 40, 40), function()
        screenGui:Destroy()
    end)
end

