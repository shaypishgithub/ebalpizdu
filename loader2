--  COLOR PICKER  (HSV sliders)
-- ══════════════════════════════════════
local function colorPickerPanel()
    local panel = New("Frame", {
        Size = UDim2.new(1, 0, 0, 120),
        BackgroundColor3 = Theme.bg1,
        BackgroundTransparency = 0.05,
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = contentScroll,
    })
    Corner(10, panel)
    Stroke(1, Theme.border, 0.5, panel)

    New("TextLabel", {
        Text = "ACCENT COLOR",
        Font = Enum.Font.GothamBold,
        TextSize = 9,
        TextColor3 = Theme.accent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -16, 0, 20),
        Position = UDim2.new(0, 10, 0, 6),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 5,
        Parent = panel,
    })

    -- Preview swatch
    local preview = New("Frame", {
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -34, 0, 8),
        BackgroundColor3 = Theme.accent,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = panel,
    })
    Corner(6, preview)
    Stroke(1, Theme.textMuted, 0.5, preview)

    local sliderData = {
        {label="HUE",   y=30,  val=Theme.accentHue},
        {label="SAT",   y=60,  val=Theme.accentSat},
        {label="BRITE", y=90,  val=Theme.accentVal},
    }

    for i, s in ipairs(sliderData) do
        New("TextLabel", {
            Text = s.label,
            Font = Enum.Font.GothamBold,
            TextSize = 9,
            TextColor3 = Theme.textMuted,
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 36, 0, 18),
            Position = UDim2.new(0, 10, 0, s.y),
            ZIndex = 5,
            Parent = panel,
        })

        local track = New("Frame", {
            Size = UDim2.new(1, -80, 0, 8),
            Position = UDim2.new(0, 48, 0, s.y+5),
            BackgroundColor3 = Theme.bg3,
            BorderSizePixel = 0,
            ZIndex = 5,
            Parent = panel,
        })
        Corner(4, track)

        if i == 1 then
            local hueColors = {}
            for hi = 0, 6 do
                hueColors[hi+1] = ColorSequenceKeypoint.new(hi/6, Color3.fromHSV(hi/6, 1, 1))
            end
            Gradient(ColorSequence.new(hueColors), 0, track)
        else
            Gradient(ColorSequence.new(Theme.bg3, Theme.accent), 0, track)
        end

        local knob = New("Frame", {
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(s.val, -7, 0.5, -7),
            BackgroundColor3 = Theme.textPrimary,
            BorderSizePixel = 0,
            ZIndex = 6,
            Parent = track,
        })
        Corner(7, knob)
        Stroke(1.5, Theme.bg0, 0, knob)

        -- drag logic
        local dragging = false
        knob.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
            end
        end)
        track.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                local rel = (inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                s.val = math.clamp(rel, 0, 1)
                knob.Position = UDim2.new(s.val, -7, 0.5, -7)
                local h, sat, v = sliderData[1].val, sliderData[2].val, sliderData[3].val
                updateAccent(h, sat, v)
                preview.BackgroundColor3 = Theme.accent
                applyAccentToAll()
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local rel = (inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                s.val = math.clamp(rel, 0, 1)
                knob.Position = UDim2.new(s.val, -7, 0.5, -7)
                local h, sat, v = sliderData[1].val, sliderData[2].val, sliderData[3].val
                updateAccent(h, sat, v)
                preview.BackgroundColor3 = Theme.accent
                applyAccentToAll()
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
    end

    return panel
end

