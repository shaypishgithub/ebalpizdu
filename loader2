        Factory.label({
            text     = title,
            color    = C("accent2"),
            size     = 10,
            font     = Enum.Font.GothamBold,
            sizeUDim = UDim2.new(1, 0, 1, 0),
            position = UDim2.new(0, 8, 0, 0),
            zIndex   = 12,
            parent   = row,
        })
        -- Divider line
        Factory.frame({
            bg       = C("border"),
            size     = UDim2.new(1, -8, 0, 1),
            position = UDim2.new(0, 4, 1, -1),
            zIndex   = 12,
            parent   = row,
        })
    end

    -- Helper: action button
    local function actBtn(label, cb)
        local BTN_H = isMobile and 36 or 30
        local b = Instance.new("TextButton")
        b.Size               = UDim2.new(1, 0, 0, BTN_H)
        b.BackgroundColor3   = C("surface")
        b.BackgroundTransparency = 0
        b.BorderSizePixel    = 0
        b.Text               = label
        b.TextColor3         = C("text")
        b.TextSize           = isMobile and 12 or 11
        b.Font               = Enum.Font.GothamMedium
        b.ZIndex             = 11
        b.Parent             = scriptScroll
        Factory.corner(b, 7)
        Factory.stroke(b, C("border"), 1, 0.5)

        b.MouseEnter:Connect(function()
            Anim.tween(b, {BackgroundColor3 = C("surfaceHover")}, 0.12)
        end)
        b.MouseLeave:Connect(function()
            Anim.tween(b, {BackgroundColor3 = C("surface")}, 0.12)
        end)
        b.MouseButton1Click:Connect(function()
            Anim.spring(b, {Size = UDim2.new(0.97, 0, 0, BTN_H - 2)}, 0.1)
            task.delay(0.14, function()
                Anim.spring(b, {Size = UDim2.new(1, 0, 0, BTN_H)}, 0.2)
            end)
            cb()
        end)
        return b
    end

    -- Themes
    sep("THEMES")
    for key, theme in pairs(ThemeManager.themes) do
        actBtn("◈  " .. theme.name, function()
            ThemeManager.setTheme(key)
            notify("Theme", theme.name .. " applied!", "success", 2.5)
        end)
    end

    -- Server tools
    sep("SERVER")
    actBtn("↺  Rejoin", function()
        local ok, e = pcall(function() TeleportService:Teleport(game.PlaceId, player) end)
        if not ok then notify("Rejoin Failed", e:sub(1,50), "error") end
    end)
    actBtn("⤢  Server Hop", function()
        local ok, e = pcall(function()
            local r = HttpService:JSONDecode(
                game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100")
            )
            if r.data and #r.data > 0 then
                TeleportService:TeleportToPlaceInstance(
                    game.PlaceId, r.data[math.random(1, #r.data)].id, player
                )
            else
                notify("Server Hop", "No servers found.", "warning")
            end
        end)
        if not ok then notify("Server Hop Failed", tostring(e):sub(1,50), "error") end
    end)
    actBtn("⊞  Copy Server ID", function()
        pcall(function() setclipboard(game.JobId) end)
        notify("Copied", "Server ID in clipboard!", "success", 2)
    end)

    -- Security
    sep("SECURITY")
    actBtn("⚑  Anti-Kick / Anti-Ban", function()
        local ok = pcall(function()
            local mt  = getrawmetatable(game)
            local old = mt.__namecall
            setreadonly(mt, false)
            mt.__namecall = newcclosure(function(self, ...)
                local m = getnamecallmethod()
                if m == "Kick" or m == "Ban" then
                    notify("Blocked", "Kick/Ban attempt stopped.", "warning")
                    return nil
                end
                return old(self, ...)
            end)
            setreadonly(mt, true)
        end)
        notify("Anti-Protection", ok and "Enabled!" or "Executor unsupported.", ok and "success" or "warning")
    end)

    -- GUI controls
    sep("GUI")
    actBtn("✕  Close GUI", function()
        screenGui:Destroy()
    end)
end

