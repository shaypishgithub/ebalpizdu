-- Retrieve a colour key from the current palette
function ThemeManager.get(key)
    return ThemeManager.Palettes[ThemeManager.active][key]
end

-- Switch theme and notify all registered elements
function ThemeManager.setTheme(name)
    if ThemeManager.Palettes[name] then
        ThemeManager.active = name
        for _, fn in ipairs(ThemeManager._listeners) do pcall(fn) end
    end
end

-- Register a callback to run on any theme change
function ThemeManager.onChanged(fn)
    table.insert(ThemeManager._listeners, fn)
end

-- ═══════════════════════════════════════════════════════════════════
--  ②  GRADIENT  ENGINE
--
--  Attaches animated UIGradient instances to any GuiObject.
--  GradientEngine.attach()  – scrolling / shimmering gradient
--  GradientEngine.static()  – fixed directional gradient
-- ═══════════════════════════════════════════════════════════════════
local GradientEngine = {}
GradientEngine._conns = {}

-- Attach an animated flowing gradient (scrolls across the element)
-- @param target  GuiObject
-- @param speed   number   – seconds per full cycle
-- @param axis    "X"|"Y"
function GradientEngine.attach(target, speed, axis)
    speed = speed or 3
    axis  = axis  or "X"

    local grad    = Instance.new("UIGradient")
    grad.Rotation = (axis == "Y") and 90 or 0
    grad.Parent   = target

    local function refreshColors()
        local ca = ThemeManager.get("GradientA")
        local cb = ThemeManager.get("GradientB")
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   ca),
            ColorSequenceKeypoint.new(0.5, cb),
            ColorSequenceKeypoint.new(1,   ca),
        })
    end
    refreshColors()
    ThemeManager.onChanged(refreshColors)

    -- Scroll offset sinusoidally
    local t    = 0
    local conn = RunService.Heartbeat:Connect(function(dt)
        if not target or not target.Parent then return end
        t     = (t + dt / speed) % 1
        local s = math.sin(t * math.pi * 2) * 0.45
        grad.Offset = (axis == "X") and Vector2.new(s, 0) or Vector2.new(0, s)
    end)
    table.insert(GradientEngine._conns, conn)
    return grad
end

-- Static directional gradient
function GradientEngine.static(target, rotation)
    local grad = Instance.new("UIGradient")
    grad.Rotation = rotation or 90
    local function refreshColors()
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, ThemeManager.get("GradientA")),
            ColorSequenceKeypoint.new(1, ThemeManager.get("GradientB")),
        })
    end
    refreshColors()
    ThemeManager.onChanged(refreshColors)
    grad.Parent = target
    return grad
end

-- ═══════════════════════════════════════════════════════════════════
--  ③  TWEEN  HELPERS
-- ═══════════════════════════════════════════════════════════════════
local function tween(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(
            t     or 0.25,
            style or Enum.EasingStyle.Quint,
            dir   or Enum.EasingDirection.Out
        ),
        props
    ):Play()
end

