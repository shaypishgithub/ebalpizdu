local function createButton(text, parent, callback, isCategoryButton)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, -10, 0, isCategoryButton and 32 or 38)
    button.BackgroundColor3 = isCategoryButton and colors.surface or colors.primary
    button.BackgroundTransparency = isCategoryButton and 0.4 or 0.3
    button.BorderSizePixel = 0
    button.Text = text
    button.TextColor3 = colors.text
    button.TextSize = isCategoryButton and 13 or 15
    button.Font = isCategoryButton and Enum.Font.GothamSemibold or Enum.Font.GothamBold
    button.AutoButtonColor = false
    button.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = button

    -- Gradient for non-category buttons
    if not isCategoryButton then
        local gradient = Instance.new("UIGradient")
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, colors.primary),
            ColorSequenceKeypoint.new(1, colors.secondary)
        })
        gradient.Rotation = 90
        gradient.Parent = button
    end

    -- Hover effect
    button.MouseEnter:Connect(function()
        if not isCategoryButton then
            TweenService:Create(button, TweenInfo.new(0.2), {BackgroundTransparency = 0.1}):Play()
        else
            TweenService:Create(button, TweenInfo.new(0.2), {BackgroundTransparency = 0.2, BackgroundColor3 = colors.primary}):Play()
        end
        TweenService:Create(button, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
    end)

    button.MouseLeave:Connect(function()
        if not isCategoryButton then
