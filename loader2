local function MakeSideBtn(label, clickFn)
    local BH = IsMobile and 36 or 30
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,0,BH); btn.BackgroundColor3 = T("SurfaceHov")
    btn.BackgroundTransparency = 1; btn.BorderSizePixel = 0
    btn.Text = ""; btn.ZIndex = 13; btn.Parent = SideScroll
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,6); c.Parent = btn end

    local aBar = Instance.new("Frame")
    aBar.Size = UDim2.new(0,2,0.6,0); aBar.Position = UDim2.new(0,1,0.2,0)
    aBar.BackgroundColor3 = T("Accent"); aBar.BorderSizePixel = 0; aBar.ZIndex = 14
    aBar.Visible = false; aBar.Parent = btn
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,1); c.Parent = aBar end

    local lbl = Instance.new("TextLabel")
    lbl.Text = label; lbl.Font = Enum.Font.GothamMedium; lbl.TextSize = IsMobile and 10 or 11
    lbl.BackgroundTransparency = 1; lbl.TextColor3 = T("TextMuted")
    lbl.Size = UDim2.new(1,-6,1,0); lbl.Position = UDim2.new(0,6,0,0)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextTruncate = Enum.TextTruncate.AtEnd; lbl.ZIndex = 14; lbl.Parent = btn

    local function Activate()
        aBar.Visible = true
        Tw(btn, {BackgroundTransparency = 0.6}, 0.15)
        Tw(lbl, {TextColor3 = T("Accent")}, 0.15)
    end
    local function Deactivate()
        aBar.Visible = false
        Tw(btn, {BackgroundTransparency = 1}, 0.15)
        Tw(lbl, {TextColor3 = T("TextMuted")}, 0.15)
    end
    btn._activate   = Activate
    btn._deactivate = Deactivate

    btn.MouseEnter:Connect(function()
        if ActiveSideBtn ~= btn then Tw(btn, {BackgroundTransparency = 0.82}, 0.1) end
    end)
    btn.MouseLeave:Connect(function()
        if ActiveSideBtn ~= btn then Tw(btn, {BackgroundTransparency = 1}, 0.1) end
    end)
    btn.MouseButton1Click:Connect(function()
        if ActiveSideBtn and ActiveSideBtn ~= btn then
            if ActiveSideBtn._deactivate then ActiveSideBtn._deactivate() end
        end
        ActiveSideBtn = btn
        Activate()
        clickFn()
    end)
    return btn
end

