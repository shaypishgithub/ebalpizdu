--  NOTIFICATION STACK
-- ════════════════════════════════════════════════════════════════════════
local notifCount = 0

local function notify(title, body, ntype, dur)
	if notifCount >= 6 then return end
	notifCount += 1
	dur   = dur  or 3.5
	ntype = ntype or "info"

	local colorMap = { info=T.acc1, success=T.ok, error=T.err, warning=T.warn }
	local acc  = colorMap[ntype] or T.acc1
	local slot = notifCount

	local card = Instance.new("Frame")
	card.Size               = UDim2.new(0,280,0,58)
	card.Position           = UDim2.new(1, 12, 1, -(65*slot))
	card.BackgroundColor3   = T.card
	card.BorderSizePixel    = 0
	card.ZIndex             = 200
	card.Parent             = root
	local ncc = Instance.new("UICorner"); ncc.CornerRadius = UDim.new(0,10); ncc.Parent = card
	local nsk = Instance.new("UIStroke"); nsk.Color = acc; nsk.Thickness = 1; nsk.Transparency = .2; nsk.Parent = card

	local bar = Instance.new("Frame")
	bar.Size             = UDim2.new(0,3,.6,0)
	bar.Position         = UDim2.new(0,6,.2,0)
	bar.BackgroundColor3 = acc
	bar.BorderSizePixel  = 0
	bar.ZIndex           = 201
	bar.Parent           = card
	local bcc2 = Instance.new("UICorner"); bcc2.CornerRadius = UDim.new(0,2); bcc2.Parent = bar

	local ttl = Instance.new("TextLabel")
	ttl.Size               = UDim2.new(1,-22,0,22)
	ttl.Position           = UDim2.new(0,16,0,5)
	ttl.BackgroundTransparency = 1
	ttl.Text               = title
	ttl.TextColor3         = T.txt
	ttl.TextSize           = 13
	ttl.Font               = Enum.Font.GothamBold
	ttl.TextXAlignment     = Enum.TextXAlignment.Left
	ttl.ZIndex             = 201
	ttl.Parent             = card

	local msg = Instance.new("TextLabel")
	msg.Size               = UDim2.new(1,-22,0,22)
	msg.Position           = UDim2.new(0,16,0,28)
	msg.BackgroundTransparency = 1
	msg.Text               = body
	msg.TextColor3         = T.txtMut
	msg.TextSize           = 10
	msg.Font               = Enum.Font.Gotham
	msg.TextXAlignment     = Enum.TextXAlignment.Left
	msg.TextWrapped        = true
	msg.ZIndex             = 201
	msg.Parent             = card

	local drain = Instance.new("Frame")
	drain.Size             = UDim2.new(1,-14,0,2)
	drain.Position         = UDim2.new(0,7,1,-3)
	drain.BackgroundColor3 = acc
	drain.BorderSizePixel  = 0
	drain.ZIndex           = 201
	drain.Parent           = card
	local dcc2 = Instance.new("UICorner"); dcc2.CornerRadius = UDim.new(0,1); dcc2.Parent = drain

	tw(card,  {Position = UDim2.new(1,-290, 1, -(65*slot))}, .4, Enum.EasingStyle.Back)
	tw(drain, {Size = UDim2.new(0,0,0,2)}, dur, Enum.EasingStyle.Linear)

	task.delay(dur, function()
		tw(card, {Position = UDim2.new(1, 12, 1, -(65*slot))}, .28)
		task.wait(.3)
		if card and card.Parent then card:Destroy() end
		notifCount = math.max(0, notifCount - 1)
	end)
end

