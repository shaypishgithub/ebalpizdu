local function RenderCategory(key)
    ClearScripts()
    local data = HubData[key]
    if not data or type(data) ~= "table" or #data == 0 then
        ShowEmpty("No scripts for: "..tostring(key).."\n(Network error or empty category)")
        return
    end
    for _, entry in ipairs(data) do
        if type(entry)=="table" and type(entry[1])=="string" and type(entry[2])=="function" then
            MakeScriptCard(entry[1], entry[2])
        end
    end
end

local function RenderAll()
    ClearScripts()
    local count = 0
    for catName, hacks in pairs(HubData) do
        if type(hacks) == "table" then
            for _, entry in ipairs(hacks) do
                if type(entry)=="table" and type(entry[1])=="string" and type(entry[2])=="function" then
                    MakeScriptCard(entry[1], entry[2], catName:sub(1,7))
                    count = count + 1
                end
            end
        end
    end
    if count == 0 then ShowEmpty("No scripts loaded.") end
end

local function RenderSearch(q)
    ClearScripts()
    q = q:lower()
    if #q == 0 then ShowEmpty("Type to search across all scripts...") return end
    local found = 0
    for catName, hacks in pairs(HubData) do
        if type(hacks) == "table" then
            for _, entry in ipairs(hacks) do
                if type(entry)=="table" and type(entry[1])=="string" then
                    if entry[1]:lower():find(q, 1, true) then
                        MakeScriptCard(entry[1], entry[2], catName:sub(1,7))
                        found = found + 1
                    end
                end
            end
        end
    end
    if found == 0 then ShowEmpty('No results for "'..q..'"') end
end

