ThemeManager._listeners = {}

-- Register a callback called whenever the theme is switched
function ThemeManager.onThemeChanged(callback)
    table.insert(ThemeManager._listeners, callback)
end

-- Apply a theme by key and notify all listeners
function ThemeManager.setTheme(key)
    if not ThemeManager.themes[key] then return end
    ThemeManager.current = ThemeManager.themes[key]
    for _, cb in ipairs(ThemeManager._listeners) do
        pcall(cb, ThemeManager.current)
    end
end

-- Shorthand — get current theme color by key
local function C(key) return ThemeManager.current[key] end

