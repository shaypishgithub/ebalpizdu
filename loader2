    applyBtn.Size = UDim2.new(1, -16, 0, 28); applyBtn.Position = UDim2.new(0, 8, 0, applyY)
    applyBtn.BackgroundColor3 = T.Accent; applyBtn.BackgroundTransparency = 0.2; applyBtn.BorderSizePixel = 0
