--  MODULE 4 · GRADIENT ANIMATOR
--  ─────────────────────────────────────────────────────────────────────────
--  Three independent effects usable on any UIGradient:
--    • hueFlow   — full hue rotation over time
--    • offsetSweep — horizontal shimmer pass
--    • shimmer   — branded two-color shimmer with a bright highlight band
-- ═══════════════════════════════════════════════════════════════════════════
local GradientAnimator = {}
GradientAnimator._active = {}

-- Hue cycle (full rainbow drift)
function GradientAnimator.hueFlow(gradient, speed)
    speed = speed or 0.5
    local conn = RunService.Heartbeat:Connect(function()
        if not gradient or not gradient.Parent then return end
        local h1 = (tick() * speed) % 1
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromHSV(h1,               0.85, 1)),
            ColorSequenceKeypoint.new(0.5, Color3.fromHSV((h1 + 0.22) % 1, 0.75, 1)),
            ColorSequenceKeypoint.new(1,   Color3.fromHSV((h1 + 0.42) % 1, 0.85, 1)),
        })
    end)
    table.insert(GradientAnimator._active, conn)
    return conn
end

-- Offset sweep (the gradient slides left↔right)
function GradientAnimator.offsetSweep(gradient, speed)
    speed = speed or 0.9
    local conn = RunService.Heartbeat:Connect(function()
        if not gradient or not gradient.Parent then return end
        gradient.Offset = Vector2.new(math.sin(tick() * speed) * 0.45, 0)
    end)
    table.insert(GradientAnimator._active, conn)
    return conn
end

-- Shimmer — a bright band sweeps across the gradient
function GradientAnimator.shimmer(gradient, colorA, colorB, speed)
    speed = speed or 1.4
    local conn = RunService.Heartbeat:Connect(function()
        if not gradient or not gradient.Parent then return end
        local t   = (tick() * speed) % 1
        local pos = math.abs(math.sin(t * math.pi))    -- 0→1→0
        local mid = math.clamp(pos, 0.05, 0.95)
        local lo  = math.clamp(mid - 0.12, 0.01, 0.93)
        local hi  = math.clamp(mid + 0.12, 0.07, 0.99)
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,  colorA),
            ColorSequenceKeypoint.new(lo, colorA),
            ColorSequenceKeypoint.new(mid,Color3.new(1, 1, 1):Lerp(colorB, 0.25)),
            ColorSequenceKeypoint.new(hi, colorB),
            ColorSequenceKeypoint.new(1,  colorB),
        })
    end)
    table.insert(GradientAnimator._active, conn)
    return conn
end

function GradientAnimator.stopAll()
    for _, c in ipairs(GradientAnimator._active) do
        if c then c:Disconnect() end
    end
    GradientAnimator._active = {}
end

