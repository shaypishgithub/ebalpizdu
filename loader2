--  [3] UTILS — Shared helpers
-- ════════════════════════════════════════════════════════
local Utils = {}

--- Quick TweenService wrapper
---@param obj Instance
---@param info TweenInfo
---@param goals table
function Utils.tween(obj, info, goals)
    return Services.TweenService:Create(obj, info, goals)
end

--- Shorthand tween + Play
function Utils.tweenPlay(obj, info, goals)
    local t = Utils.tween(obj, info, goals)
    t:Play()
    return t
end

--- Build a TweenInfo with sensible defaults
function Utils.tweenInfo(duration, style, dir, rep, rev, delay)
    return TweenInfo.new(
        duration or 0.3,
        style    or Enum.EasingStyle.Quint,
        dir      or Enum.EasingDirection.Out,
        rep      or 0,
        rev      or false,
        delay    or 0
    )
end

--- Create an Instance with properties set atomically
---@param className string
---@param props table
---@param parent Instance?
function Utils.create(className, props, parent)
    local inst = Instance.new(className)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    if parent then inst.Parent = parent end
    return inst
end

--- Add a UICorner to an instance
function Utils.corner(inst, radius)
    return Utils.create("UICorner", {CornerRadius = UDim.new(0, radius or 8)}, inst)
end

--- Add a UIStroke to an instance
function Utils.stroke(inst, color, thickness, transparency)
    return Utils.create("UIStroke", {
        Color        = color or Color3.new(),
        Thickness    = thickness or 1,
        Transparency = transparency or 0,
    }, inst)
end

--- Add UIPadding
function Utils.padding(inst, all, top, right, bottom, left)
    local p = all or 0
    return Utils.create("UIPadding", {
        PaddingTop    = UDim.new(0, top    or p),
        PaddingRight  = UDim.new(0, right  or p),
        PaddingBottom = UDim.new(0, bottom or p),
        PaddingLeft   = UDim.new(0, left   or p),
    }, inst)
end

--- Add UIListLayout
function Utils.listLayout(inst, padding, sortOrder, dir)
    return Utils.create("UIListLayout", {
        Padding         = UDim.new(0, padding or 6),
        SortOrder       = sortOrder or Enum.SortOrder.LayoutOrder,
        FillDirection   = dir or Enum.FillDirection.Vertical,
    }, inst)
end

--- Auto-resize a ScrollingFrame to its list content
function Utils.autoCanvasSize(scroll, layout)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
    end)
end

--- Safe loadstring from URL
function Utils.safeLoad(url)
    local ok, res = pcall(function()
        return loadstring(game:HttpGet(url, true))()
    end)
    if ok and res then return res end
    warn("[MH2] load failed: " .. tostring(url))
    return {}
end

--- Parent GUI into a protected container
function Utils.hideGui(gui)
    local ok = pcall(function()
        if get_hidden_gui then
            gui.Parent = get_hidden_gui()
        elseif gethui then
            gui.Parent = gethui()
        elseif syn and syn.protect_gui then
            syn.protect_gui(gui)
            gui.Parent = Services.CoreGui
        else
            gui.Parent = Services.CoreGui
        end
    end)
    if not ok then gui.Parent = Services.CoreGui end
end

--- Lerp two Color3 values
function Utils.lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

