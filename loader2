--  Navigation router
-- ════════════════════════════════════════════════════════
local pageMap = {
    Home     = showHome,
    Search   = showSearch,
    Settings = showSettings,
}

function UI.navigate(name)
    -- Fade content out, swap, fade in
    local scroll = UI.contentScroll
    Utils.tweenPlay(scroll, Utils.tweenInfo(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        BackgroundTransparency = 1
    })
    task.delay(0.13, function()
        if pageMap[name] then
            pageMap[name]()
        else
            showCategory(name)
        end
        Utils.tweenPlay(scroll, Utils.tweenInfo(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 1   -- keep transparent (content uses own BG)
        })
    end)
end

