		tL.BackgroundTransparency = 1
		tL.Text               = tag:sub(1,7)
		tL.TextColor3         = T.acc2
		tL.TextSize           = 9
		tL.Font               = Enum.Font.GothamBold
		tL.TextXAlignment     = Enum.TextXAlignment.Center
		tL.ZIndex             = 13
		tL.Parent             = tf
	end

	-- RUN button
	local RBW = isMob and 46 or 40
	local RBH = isMob and 24 or 20
	local runBtn = Instance.new("TextButton")
	runBtn.Size               = UDim2.new(0,RBW,0,RBH)
	runBtn.Position           = UDim2.new(1,-RBW-8,.5,-RBH/2)
	runBtn.BackgroundColor3   = T.acc1
	runBtn.BackgroundTransparency = .08
	runBtn.BorderSizePixel    = 0
	runBtn.Text               = "▶ RUN"
	runBtn.TextColor3         = Color3.new(1,1,1)
	runBtn.TextSize           = 9
	runBtn.Font               = Enum.Font.GothamBold
	runBtn.ZIndex             = 12
	runBtn.Parent             = card
	local rbCC = Instance.new("UICorner"); rbCC.CornerRadius = UDim.new(0,6); rbCC.Parent = runBtn
	local rbG  = Instance.new("UIGradient")
	rbG.Rotation = 45
	rbG.Color    = ColorSequence.new({
		ColorSequenceKeypoint.new(0, T.acc1),
		ColorSequenceKeypoint.new(1, T.acc2),
	})
	rbG.Parent = runBtn

	runBtn.MouseEnter:Connect(function() tw(runBtn, {BackgroundTransparency=0}, .1) end)
	runBtn.MouseLeave:Connect(function() tw(runBtn, {BackgroundTransparency=.08}, .1) end)

	-- Invisible tap overlay so whole card is tappable on mobile
	local tapOv = Instance.new("TextButton")
	tapOv.Size               = UDim2.new(1,0,1,0)
	tapOv.BackgroundTransparency = 1
	tapOv.BorderSizePixel    = 0
	tapOv.Text               = ""
	tapOv.ZIndex             = 11
	tapOv.Parent             = card
	tapOv.MouseEnter:Connect(function() tw(card, {BackgroundColor3=T.cardHov}, .1) end)
	tapOv.MouseLeave:Connect(function() tw(card, {BackgroundColor3=T.card},    .1) end)

	local function execScript()
		tw(runBtn, {Size=UDim2.new(0,RBW-4,0,RBH-2)}, .1, Enum.EasingStyle.Back)
		task.delay(.12, function()
			if runBtn and runBtn.Parent then
				tw(runBtn, {Size=UDim2.new(0,RBW,0,RBH)}, .2, Enum.EasingStyle.Back)
			end
		end)
		local ok, err = pcall(callback)
		if ok then
			notify("✓ Executed", name, "success", 2.5)
			tw(card, {BackgroundColor3=T.ok:Lerp(T.card,.68)}, .12)
			task.delay(.22, function()
				if card and card.Parent then tw(card, {BackgroundColor3=T.card}, .42) end
			end)
		else
			notify("✗ Error", tostring(err):sub(1,65), "error", 5)
			tw(card, {BackgroundColor3=T.err:Lerp(T.card,.65)}, .12)
			task.delay(.22, function()
				if card and card.Parent then tw(card, {BackgroundColor3=T.card}, .42) end
			end)
		end
	end

	runBtn.MouseButton1Click:Connect(execScript)
	tapOv.MouseButton1Click:Connect(execScript)

	return card
end

