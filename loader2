local function createModernButton(text, parent, callback, isCategory)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, -10, 0, isCategory and 38 or 42)
    button.BackgroundColor3 = isCategory and colors.primary or colors.accent
    button.BackgroundTransparency = isCategory and 0.2 or 0.1
    button.BorderSizePixel = 0
    button.Text = text
    button.TextColor3 = colors.text
    button.TextSize = isCategory and 13 or 15
    button.Font = isCategory and Enum.Font.GothamBold or Enum.Font.Gotham
    button.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = button

    if not isCategory then
        local gradient = Instance.new("UIGradient")
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 170, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 130, 255))
        })
        gradient.Rotation = 90
        gradient.Parent = button
    end

    local buttonStroke = Instance.new("UIStroke")
    buttonStroke.Thickness = 1
    buttonStroke.Color = isCategory and colors.stroke or Color3.fromRGB(255, 255, 255)
    buttonStroke.Transparency = isCategory and 0.3 or 0.8
    buttonStroke.Parent = button

    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundTransparency = isCategory and 0.1 or 0}):Play()
        TweenService:Create(button, TweenInfo.new(0.2), {Size = UDim2.new(1, -8, 0, isCategory and 40 or 44)}):Play()
    end)

    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundTransparency = isCategory and 0.2 or 0.1}):Play()
        TweenService:Create(button, TweenInfo.new(0.2), {Size = UDim2.new(1, -10, 0, isCategory and 38 or 42)}):Play()
    end)

    button.MouseButton1Click:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {BackgroundTransparency = isCategory and 0.3 or 0.2}):Play()
        task.wait(0.1)
        TweenService:Create(button, TweenInfo.new(0.1), {BackgroundTransparency = isCategory and 0.2 or 0.1}):Play()
        callback()
    end)

    return button
end

