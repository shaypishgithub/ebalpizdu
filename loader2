            v = 1 - math.clamp((inp.Position.Y - ap.Y) / as.Y, 0, 1); updateUI()
        end
    end)
    -- Hue slider mouse down
    hueF.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            drag.hue = true
            local ap = hueF.AbsolutePosition; local as = hueF.AbsoluteSize
            h = math.clamp((inp.Position.X - ap.X) / as.X, 0, 0.9999); updateUI()
        end
    end)
    -- R slider
    rSl.bg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag.r = true
            local ap = rSl.bg.AbsolutePosition; local as = rSl.bg.AbsoluteSize
            local val = math.clamp((inp.Position.X - ap.X) / as.X, 0, 1)
            local c = getC(); h, s, v = Color3.toHSV(Color3.new(val, c.G, c.B)); updateUI()
        end
    end)
    -- G slider
    gSl.bg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag.g = true
            local ap = gSl.bg.AbsolutePosition; local as = gSl.bg.AbsoluteSize
            local val = math.clamp((inp.Position.X - ap.X) / as.X, 0, 1)
            local c = getC(); h, s, v = Color3.toHSV(Color3.new(c.R, val, c.B)); updateUI()
        end
    end)
    -- B slider
    bSl.bg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag.b = true
            local ap = bSl.bg.AbsolutePosition; local as = bSl.bg.AbsoluteSize
            local val = math.clamp((inp.Position.X - ap.X) / as.X, 0, 1)
            local c = getC(); h, s, v = Color3.toHSV(Color3.new(c.R, c.G, val)); updateUI()
        end
    end)

    -- Global mouse move
    local c1 = UserInputService.InputChanged:Connect(function(inp)
        if not cont.Parent then return end
        local pos = inp.Position
        if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
            if drag.sv then
                local ap = sqF.AbsolutePosition; local as = sqF.AbsoluteSize
                s = math.clamp((pos.X - ap.X) / as.X, 0, 1)
                v = 1 - math.clamp((pos.Y - ap.Y) / as.Y, 0, 1); updateUI()
            elseif drag.hue then
                local ap = hueF.AbsolutePosition; local as = hueF.AbsoluteSize
                h = math.clamp((pos.X - ap.X) / as.X, 0, 0.9999); updateUI()
            elseif drag.r then
                local ap = rSl.bg.AbsolutePosition; local as = rSl.bg.AbsoluteSize
                local val = math.clamp((pos.X - ap.X) / as.X, 0, 1)
                local c = getC(); h, s, v = Color3.toHSV(Color3.new(val, c.G, c.B)); updateUI()
            elseif drag.g then
                local ap = gSl.bg.AbsolutePosition; local as = gSl.bg.AbsoluteSize
                local val = math.clamp((pos.X - ap.X) / as.X, 0, 1)
                local c = getC(); h, s, v = Color3.toHSV(Color3.new(c.R, val, c.B)); updateUI()
            elseif drag.b then
                local ap = bSl.bg.AbsolutePosition; local as = bSl.bg.AbsoluteSize
                local val = math.clamp((pos.X - ap.X) / as.X, 0, 1)
                local c = getC(); h, s, v = Color3.toHSV(Color3.new(c.R, c.G, val)); updateUI()
            end
        end
    end)
    table.insert(colorPickerConnections, c1)

    -- Global mouse up → apply
    local c2 = UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            local was = drag.sv or drag.hue or drag.r or drag.g or drag.b
            drag.sv = false; drag.hue = false; drag.r = false; drag.g = false; drag.b = false
            if was then applyColor() end
        end
    end)
    table.insert(colorPickerConnections, c2)

    -- Hex input → Enter to apply
    hexBox.FocusLost:Connect(function(entered)
        local hex = hexBox.Text:gsub("[^%x]", "")
        if #hex == 6 then
            local r2 = tonumber(hex:sub(1, 2), 16)
            local g2 = tonumber(hex:sub(3, 4), 16)
            local b2 = tonumber(hex:sub(5, 6), 16)
            if r2 and g2 and b2 then
                h, s, v = Color3.toHSV(Color3.fromRGB(r2, g2, b2)); updateUI()
                if entered then applyColor() end
            end
        end
    end)

    updateUI()
    return cont
end

