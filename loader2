local function showCategory(categoryName)
    clearContent()
    local scroll = UI.contentScroll
    local theme  = ThemeManager.get()
    local data   = HubData[categoryName]

    makeSectionHeader(categoryName, scroll)

    if not data or #data == 0 then
        makeLabel("⚠  No scripts loaded for: " .. categoryName, scroll, UDim2.new(1,0,0,28), 12, theme.danger)
        return
    end

    for _, hack in ipairs(data) do
        if type(hack) == "table" and type(hack[1]) == "string" and type(hack[2]) == "function" then
            makeButton(hack[1], scroll, function()
                local ok, err = pcall(hack[2])
                if not ok then
                    createNotification("Error", tostring(err), 5, "error")
                else
                    createNotification("Executed", hack[1], 2.5, "success")
                end
            end)
        end
    end
end

