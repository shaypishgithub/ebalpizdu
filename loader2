--  [4] THEME MANAGER — Live theming + gradient animation
-- ════════════════════════════════════════════════════════
local ThemeManager = {}
ThemeManager._current   = "dark"
ThemeManager._listeners = {}   -- {fn} called on theme change
ThemeManager._gradConns = {}   -- RunService connections for gradient anim

--- Get the current theme table
function ThemeManager.get()
    return Config.Themes[ThemeManager._current]
end

--- Register a callback that fires when theme changes
---@param fn function  receives (newTheme: table)
function ThemeManager.onChange(fn)
    table.insert(ThemeManager._listeners, fn)
end

--- Switch to a named theme
---@param name string
function ThemeManager.set(name)
    if not Config.Themes[name] then return end
    ThemeManager._current = name
    local theme = ThemeManager.get()
    for _, fn in ipairs(ThemeManager._listeners) do
        pcall(fn, theme)
    end
end

--- Animate a UIGradient with flowing colour cycle
---@param gradient UIGradient
---@param themeKey string   key in Config.GradientThemes
---@return RBXScriptConnection  (store to disconnect later)
function ThemeManager.animateGradient(gradient, themeKey)
    local stops = Config.GradientThemes[themeKey] or Config.GradientThemes.neon
    local n     = #stops
    local t     = 0
    local spd   = Config.Anim.gradientSpeed

    local conn = Services.RunService.Heartbeat:Connect(function(dt)
        if not gradient or not gradient.Parent then return end
        t = (t + dt / spd) % 1

        -- Smooth colour sequence across 3 key-colour stops
        local pos1  = (t * n) % n
        local idx   = math.floor(pos1) + 1
        local frac  = pos1 - math.floor(pos1)
        local c1    = stops[idx]
        local c2    = stops[(idx % n) + 1]
        local mid   = Utils.lerpColor(c1, c2, frac)

        local pos2  = ((t + 0.5) * n) % n
        local idx2  = math.floor(pos2) + 1
        local frac2 = pos2 - math.floor(pos2)
        local c3    = stops[idx2]
        local c4    = stops[(idx2 % n) + 1]
        local end_  = Utils.lerpColor(c3, c4, frac2)

        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   c1),
            ColorSequenceKeypoint.new(0.5, mid),
            ColorSequenceKeypoint.new(1,   end_),
        })
        gradient.Rotation = t * 360
    end)

    table.insert(ThemeManager._gradConns, conn)
    return conn
end

--- Stop all gradient animations
function ThemeManager.stopGradients()
    for _, c in ipairs(ThemeManager._gradConns) do c:Disconnect() end
    ThemeManager._gradConns = {}
end

