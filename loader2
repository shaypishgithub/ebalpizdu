--  MODULE 2 · ANIMATION UTILITIES
-- ═══════════════════════════════════════════════════════════════════════════
local Anim = {}

function Anim.tween(inst, props, dur, style, dir)
    local t = TweenService:Create(
        inst,
        TweenInfo.new(dur or 0.25, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props
    )
    t:Play()
    return t
end

-- Springy overshoot — good for button press feedback
function Anim.spring(inst, props, dur)
    return Anim.tween(inst, props, dur or 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

-- ═══════════════════════════════════════════════════════════════════════════
--  MODULE 3 · UI FACTORY
--  ─────────────────────────────────────────────────────────────────────────
--  Consistent, centrally-styled element constructors.
--  All sizing / color choices come from the active theme.
-- ═══════════════════════════════════════════════════════════════════════════
local Factory = {}

function Factory.corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

function Factory.stroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color        = color        or Color3.fromRGB(60, 60, 90)
    s.Thickness    = thickness    or 1
    s.Transparency = transparency or 0
    s.Parent = parent
    return s
end

function Factory.padding(parent, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 6)
    p.PaddingBottom = UDim.new(0, bottom or 6)
    p.PaddingLeft   = UDim.new(0, left   or 8)
    p.PaddingRight  = UDim.new(0, right  or 8)
    p.Parent = parent
    return p
end

function Factory.listLayout(parent, dir, spacing, align)
    local l = Instance.new("UIListLayout")
    l.FillDirection       = dir     or Enum.FillDirection.Vertical
    l.Padding             = UDim.new(0, spacing or 6)
    l.SortOrder           = Enum.SortOrder.LayoutOrder
    l.HorizontalAlignment = align   or Enum.HorizontalAlignment.Left
    l.Parent = parent
    return l
end

function Factory.gradient(parent, colorA, colorB, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, colorA),
        ColorSequenceKeypoint.new(1, colorB),
    })
    g.Rotation = rotation or 90
    g.Parent = parent
    return g
end

-- Frame builder — accepts a props table
function Factory.frame(p)
    local f = Instance.new("Frame")
    f.BackgroundColor3     = p.bg            or Color3.fromRGB(20, 20, 30)
    f.BackgroundTransparency = p.transparency or 0
    f.BorderSizePixel      = 0
    f.Size                 = p.size          or UDim2.new(1, 0, 0, 40)
    f.Position             = p.position      or UDim2.new(0, 0, 0, 0)
    f.AnchorPoint          = p.anchor        or Vector2.new(0, 0)
    f.ZIndex               = p.zIndex        or 2
    f.Name                 = p.name          or "Frame"
    f.ClipsDescendants     = p.clip          or false
    f.Parent               = p.parent
    if p.corner  then Factory.corner(f, p.corner) end
    if p.stroke  then Factory.stroke(f, p.strokeColor, p.strokeWidth) end
    return f
end

-- TextLabel builder
function Factory.label(p)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text           = p.text     or ""
    l.TextColor3     = p.color    or Color3.fromRGB(235, 235, 248)
    l.TextSize       = p.size     or 14
    l.Font           = p.font     or Enum.Font.GothamMedium
    l.TextXAlignment = p.alignX   or Enum.TextXAlignment.Left
    l.TextYAlignment = p.alignY   or Enum.TextYAlignment.Center
    l.TextWrapped    = p.wrap     or false
    l.RichText       = p.rich     or false
    l.Size           = p.sizeUDim or UDim2.new(1, 0, 0, 20)
    l.Position       = p.position or UDim2.new(0, 0, 0, 0)
    l.ZIndex         = p.zIndex   or 2
    l.Name           = p.name     or "Label"
    l.Parent         = p.parent
    return l
end

