--  NOTIFICATION SYSTEM (redesigned)
-- ══════════════════════════════════════
local notifQueue = {}
local notifActive = false

local function processNotifQueue()
    if notifActive or #notifQueue == 0 then return end
    notifActive = true
    local item = table.remove(notifQueue, 1)

    local ng = New("ScreenGui", {Name="MH_Notif", Parent=playerGui, ResetOnSpawn=false})

    local W, H = 280, 64
    local frame = New("Frame", {
        Size = UDim2.new(0, W, 0, H),
        Position = UDim2.new(1, -(W+16), 1, -(H+16)),
        BackgroundColor3 = Theme.bg1,
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        Parent = ng,
    })
    Corner(10, frame)

    -- left accent bar
    local bar = New("Frame", {
        Size = UDim2.new(0, 3, 1, -12),
        Position = UDim2.new(0, 6, 0, 6),
        BackgroundColor3 = item.color or Theme.accent,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Corner(3, bar)

    -- glow stroke
    local st = Stroke(1, item.color or Theme.accent, 0.4, frame)

    -- title
    local title = New("TextLabel", {
        Text = item.title,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = Theme.textPrimary,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -24, 0, 20),
        Position = UDim2.new(0, 16, 0, 8),
        Parent = frame,
    })

    -- subtitle
    New("TextLabel", {
        Text = item.sub,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Theme.textSecondary,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -24, 0, 18),
        Position = UDim2.new(0, 16, 0, 28),
        Parent = frame,
    })

    -- slide-in
    frame.Position = UDim2.new(1, 16, 1, -(H+16))
    tween(frame, {Position = UDim2.new(1, -(W+16), 1, -(H+16))}, 0.35)

    task.delay(item.dur or 3, function()
        tween(frame, {Position = UDim2.new(1, 16, 1, -(H+16))}, 0.3)
        task.delay(0.35, function()
            ng:Destroy()
            notifActive = false
            processNotifQueue()
        end)
    end)
end

local function notify(title, sub, dur, color)
    table.insert(notifQueue, {title=title, sub=sub, dur=dur, color=color})
    processNotifQueue()
end

