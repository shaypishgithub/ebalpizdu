--  LOADING SCREEN
-- ════════════════════════════════════════════════════════════════════════
local function showLoading(onDone)
	local ov = Instance.new("Frame")
	ov.Size             = UDim2.new(1,0,1,0)
	ov.BackgroundColor3 = T.bg
	ov.BorderSizePixel  = 0
	ov.ZIndex           = 500
	ov.Parent           = root
	ov.BackgroundTransparency = 1

	-- Slow background gradient animation
	local ovG = Instance.new("UIGradient")
	ovG.Rotation = 135
	ovG.Parent   = ov
	local ovConn = RS.Heartbeat:Connect(function()
		if not ovG or not ovG.Parent then return end
		local t = tick()*.12
		ovG.Color  = ColorSequence.new({
			ColorSequenceKeypoint.new(0, T.bg),
			ColorSequenceKeypoint.new(1, T.panel),
		})
		ovG.Offset = Vector2.new(math.sin(t)*.06, math.cos(t*.8)*.06)
	end)

	-- Logo card
	local logo = Instance.new("Frame")
	logo.Size               = UDim2.new(0,300,0,108)
	logo.Position           = UDim2.new(.5,0,.38,0)
	logo.AnchorPoint        = Vector2.new(.5,.5)
	logo.BackgroundColor3   = T.card
	logo.BackgroundTransparency = 1
	logo.BorderSizePixel    = 0
	logo.ZIndex             = 501
	logo.Parent             = ov
	local lcc = Instance.new("UICorner"); lcc.CornerRadius = UDim.new(0,16); lcc.Parent = logo
	local lsk = Instance.new("UIStroke"); lsk.Color = T.acc1; lsk.Thickness = 1; lsk.Transparency = .3; lsk.Parent = logo

	-- Shimmer on card
	local lgG = Instance.new("UIGradient"); lgG.Rotation = 135; lgG.Parent = logo
	local lgConn = RS.Heartbeat:Connect(function()
		if not lgG or not lgG.Parent then return end
		local p = math.abs(math.sin(tick()*.5*math.pi)) * .8 + .1
		lgG.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0,  T.card),
			ColorSequenceKeypoint.new(math.clamp(p-.08,.02,.88), T.card),
			ColorSequenceKeypoint.new(math.clamp(p,   .05,.95), T.cardHov),
			ColorSequenceKeypoint.new(math.clamp(p+.08,.12,.98), T.card),
			ColorSequenceKeypoint.new(1,  T.card),
		})
	end)

	-- Logo title
	local ltxt = Instance.new("TextLabel")
	ltxt.Size               = UDim2.new(1,-20,0,54)
	ltxt.Position           = UDim2.new(0,10,0,10)
	ltxt.BackgroundTransparency = 1
	ltxt.Text               = "MEGAHACK"
	ltxt.TextColor3         = T.txt
	ltxt.TextSize           = 38
	ltxt.Font               = Enum.Font.GothamBlack
	ltxt.TextXAlignment     = Enum.TextXAlignment.Center
	ltxt.TextTransparency   = 1
	ltxt.ZIndex             = 502
	ltxt.Parent             = logo
	local ltG = Instance.new("UIGradient"); ltG.Rotation = 0
	ltG.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, T.acc1),
		ColorSequenceKeypoint.new(1, T.acc2),
	})
	ltG.Parent = ltxt
	local ltConn = RS.Heartbeat:Connect(function()
		if not ltG or not ltG.Parent then return end
		ltG.Offset = Vector2.new(math.sin(tick()*.65)*.3, 0)
	end)

	local lsub = Instance.new("TextLabel")
	lsub.Size               = UDim2.new(1,-20,0,20)
	lsub.Position           = UDim2.new(0,10,0,66)
	lsub.BackgroundTransparency = 1
	lsub.Text               = "V 2.0  ·  ULTRA EDITION"
	lsub.TextColor3         = T.txtMut
	lsub.TextSize           = 11
	lsub.Font               = Enum.Font.GothamMedium
	lsub.TextXAlignment     = Enum.TextXAlignment.Center
	lsub.TextTransparency   = 1
	lsub.ZIndex             = 502
	lsub.Parent             = logo

	-- Progress bar track
	local track = Instance.new("Frame")
	track.Size             = UDim2.new(0,310,0,5)
	track.Position         = UDim2.new(.5,0,.60,0)
	track.AnchorPoint      = Vector2.new(.5,.5)
	track.BackgroundColor3 = T.card
	track.BorderSizePixel  = 0
	track.ZIndex           = 501
	track.Parent           = ov
	local tcc = Instance.new("UICorner"); tcc.CornerRadius = UDim.new(0,3); tcc.Parent = track
	local tsk = Instance.new("UIStroke"); tsk.Color = T.border; tsk.Thickness = 1; tsk.Transparency = .4; tsk.Parent = track

	local fill = Instance.new("Frame")
	fill.Size             = UDim2.new(0,0,1,0)
	fill.BackgroundColor3 = T.acc1
	fill.BorderSizePixel  = 0
	fill.ZIndex           = 502
	fill.Parent           = track
	local fcc = Instance.new("UICorner"); fcc.CornerRadius = UDim.new(0,3); fcc.Parent = fill
	local fillG = Instance.new("UIGradient"); fillG.Rotation = 0; fillG.Parent = fill
	local fgConn = RS.Heartbeat:Connect(function()
		if not fillG or not fillG.Parent then return end
		local p = math.abs(math.sin(tick()*2.5*math.pi))*.8+.1
		fillG.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, T.acc1),
			ColorSequenceKeypoint.new(math.clamp(p-.07,.02,.88), T.acc1),
			ColorSequenceKeypoint.new(math.clamp(p,   .05,.95), T.acc2),
			ColorSequenceKeypoint.new(math.clamp(p+.07,.12,.98), T.acc1),
			ColorSequenceKeypoint.new(1, T.acc1),
		})
	end)

	-- Status label
	local stat = Instance.new("TextLabel")
	stat.Size               = UDim2.new(0,310,0,20)
	stat.Position           = UDim2.new(.5,0,.66,0)
	stat.AnchorPoint        = Vector2.new(.5,.5)
	stat.BackgroundTransparency = 1
	stat.Text               = "Starting..."
	stat.TextColor3         = T.txtMut
	stat.TextSize           = 11
	stat.Font               = Enum.Font.Gotham
	stat.TextXAlignment     = Enum.TextXAlignment.Center
	stat.ZIndex             = 501
	stat.Parent             = ov

	-- Bouncing dots
	local dotsF = Instance.new("Frame")
	dotsF.Size               = UDim2.new(0,50,0,10)
	dotsF.Position           = UDim2.new(.5,0,.74,0)
	dotsF.AnchorPoint        = Vector2.new(.5,.5)
	dotsF.BackgroundTransparency = 1
	dotsF.ZIndex             = 501
	dotsF.Parent             = ov
	local dLL = Instance.new("UIListLayout")
	dLL.FillDirection        = Enum.FillDirection.Horizontal
	dLL.Padding              = UDim.new(0,8)
	dLL.HorizontalAlignment  = Enum.HorizontalAlignment.Center
	dLL.Parent               = dotsF
	for i = 1, 3 do
		local dot = Instance.new("Frame")
		dot.Size             = UDim2.new(0,8,0,8)
		dot.BackgroundColor3 = T.acc1
		dot.BackgroundTransparency = .8
		dot.BorderSizePixel  = 0
		dot.ZIndex           = 502
		dot.Parent           = dotsF
		local dc = Instance.new("UICorner"); dc.CornerRadius = UDim.new(1,0); dc.Parent = dot
		task.spawn(function()
			while dot and dot.Parent do
				task.wait(.38*(i-1))
				if not (dot and dot.Parent) then break end
				tw(dot, {BackgroundTransparency=0}, .2)
				task.wait(.2)
				if not (dot and dot.Parent) then break end
				tw(dot, {BackgroundTransparency=.8}, .2)
				task.wait(.58)
			end
		end)
	end

	-- Animate in
	tw(ov,   {BackgroundTransparency=0}, .45)
	task.wait(.28)
	tw(logo, {BackgroundTransparency=0}, .45, Enum.EasingStyle.Back)
	task.wait(.18)
	tw(ltxt, {TextTransparency=0}, .38)
	task.wait(.1)
	tw(lsub, {TextTransparency=0}, .28)

	-- Progress steps — actual HubData load happens at step 3
	local steps = {
		{.10, "Initializing..."},
		{.22, "Loading core modules..."},
		{.38, "Fetching scripts (batch 1)..."},  -- HubData starts loading here
		{.55, "Fetching scripts (batch 2)..."},
		{.68, "Fetching game scripts..."},
		{.80, "Building UI..."},
		{.92, "Applying theme..."},
		{1.0,  "Ready!"},
	}

	local dataLoaded = false
	for i, step in ipairs(steps) do
		if i == 3 and not dataLoaded then
			dataLoaded = true
			task.spawn(loadHubData)
		end
		task.wait(.28)
		tw(fill, {Size=UDim2.new(step[1],0,1,0)}, .32, Enum.EasingStyle.Quart)
		if stat and stat.Parent then stat.Text = step[2] end
	end

	task.wait(.5)

	-- Cleanup connections
	ovConn:Disconnect()
	lgConn:Disconnect()
	ltConn:Disconnect()
	fgConn:Disconnect()

	-- Slide-up exit
	tw(ov, {Position=UDim2.new(0,0,-1,0)}, .55, Enum.EasingStyle.Quart)
	task.wait(.6)
	if ov and ov.Parent then ov:Destroy() end

	if onDone then onDone() end
end

