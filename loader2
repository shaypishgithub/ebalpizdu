    -- ── Update helpers ─────────────────────────
    local function hexStr(c)
        return string.format("%02X%02X%02X",
            math.floor(c.R * 255 + .5), math.floor(c.G * 255 + .5), math.floor(c.B * 255 + .5))
    end

    local function updateUI()
        local c = getC()
        sqF.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
