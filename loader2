-- Settings page
function ContentRenderer.settings()
    clearScripts()

    -- Helper: section separator
    local function sep(title)
        local row = Factory.frame({
            bg           = Color3.new(0,0,0),
            transparency = 1,
            size         = UDim2.new(1, 0, 0, 22),
            zIndex       = 11,
            parent       = scriptScroll,
