-- Script button (content area)
local function scriptBtn(label, callback)
    local btn = New("TextButton", {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Theme.bg3,
        BackgroundTransparency = 0.4,
        Text = "",
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = contentScroll,
    })
    Corner(8, btn)
    local stroke = Stroke(1, Theme.border, 0.5, btn)

    New("TextLabel", {
        Text = "▶  " .. label,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = Theme.textPrimary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -12, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 5,
        Parent = btn,
    })

    -- right run indicator
    local runDot = New("Frame", {
        Size = UDim2.new(0, 6, 0, 6),
        Position = UDim2.new(1, -14, 0.5, -3),
        BackgroundColor3 = Theme.textMuted,
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = btn,
    })
    Corner(3, runDot)

    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundTransparency = 0.15})
        tween(stroke, {Color = Theme.accent, Transparency = 0.3})
        tween(runDot, {BackgroundColor3 = Theme.accent, BackgroundTransparency = 0})
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundTransparency = 0.4})
        tween(stroke, {Color = Theme.border, Transparency = 0.5})
        tween(runDot, {BackgroundColor3 = Theme.textMuted, BackgroundTransparency = 0.4})
    end)
    btn.MouseButton1Click:Connect(function()
        tween(btn, {BackgroundTransparency = 0.05}, 0.1)
        tween(runDot, {BackgroundColor3 = Theme.success}, 0.1)
        task.delay(0.15, function()
            tween(btn, {BackgroundTransparency = 0.4}, 0.15)
            task.delay(1, function()
                tween(runDot, {BackgroundColor3 = Theme.textMuted, BackgroundTransparency = 0.4})
            end)
        end)
        local ok, err = pcall(callback)
        if not ok then notify("ERROR", tostring(err):sub(1,60), 5, Theme.error) end
    end)
    return btn
end

