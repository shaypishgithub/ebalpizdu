--  [5] LOADING SCREEN — Animated boot sequence
-- ════════════════════════════════════════════════════════
local LoadingScreen = {}

---@param onComplete function  called when animation finishes
function LoadingScreen.show(onComplete)
    local theme = ThemeManager.get()

    -- Root ScreenGui
    local gui = Utils.create("ScreenGui", {
        Name            = "MH2_Loading",
        ZIndexBehavior  = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset  = true,
        ResetOnSpawn    = false,
    })
    Utils.hideGui(gui)

    -- Full-screen backdrop
    local bg = Utils.create("Frame", {
        Size                  = UDim2.new(1, 0, 1, 0),
        BackgroundColor3      = theme.bg,
        BackgroundTransparency= 0,
        BorderSizePixel       = 0,
        ZIndex                = 1,
    }, gui)

    -- Animated gradient overlay
    local gradFrame = Utils.create("Frame", {
        Size                  = UDim2.new(1, 0, 1, 0),
        BackgroundColor3      = Color3.new(1, 1, 1),
        BackgroundTransparency= 0.88,
        BorderSizePixel       = 0,
        ZIndex                = 2,
    }, bg)
    local grad = Utils.create("UIGradient", {Rotation = 45}, gradFrame)
    ThemeManager.animateGradient(grad, theme.gradKey)

    -- Centre card
    local cardW, cardH = 300, 200
    local card = Utils.create("Frame", {
        Size                  = UDim2.new(0, cardW, 0, cardH),
        Position              = UDim2.new(0.5, -cardW/2, 0.5, -cardH/2),
        BackgroundColor3      = theme.bgSecondary,
        BackgroundTransparency= 0.15,
        BorderSizePixel       = 0,
        ZIndex                = 3,
    }, bg)
    Utils.corner(card, 20)
    local cardStroke = Utils.stroke(card, theme.accent, 1.5, 0.4)

    -- Animated stroke gradient
    local cg = Utils.create("UIGradient", {Rotation = 45}, cardStroke)
    ThemeManager.animateGradient(cg, theme.gradKey)

    -- Logo / title
    local logoLabel = Utils.create("TextLabel", {
        Text                 = "MEGAHACK",
        Font                 = Enum.Font.GothamBlack,
        TextSize             = 32,
        TextColor3           = theme.text,
        TextTransparency     = 0,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 40),
        Position             = UDim2.new(0, 0, 0, 24),
        ZIndex               = 4,
    }, card)

    -- Subtitle
    local subLabel = Utils.create("TextLabel", {
        Text                 = "V2  ·  LOADING",
        Font                 = Enum.Font.GothamBold,
        TextSize             = 12,
        TextColor3           = theme.textMuted,
        TextTransparency     = 0,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 20),
        Position             = UDim2.new(0, 0, 0, 62),
        ZIndex               = 4,
    }, card)

    -- Progress bar track
    local barTrack = Utils.create("Frame", {
        Size                  = UDim2.new(0.82, 0, 0, 6),
        Position              = UDim2.new(0.09, 0, 0, 110),
        BackgroundColor3      = theme.bgTertiary,
        BackgroundTransparency= 0,
        BorderSizePixel       = 0,
        ZIndex                = 4,
    }, card)
    Utils.corner(barTrack, 3)

    -- Progress bar fill
    local barFill = Utils.create("Frame", {
        Size                  = UDim2.new(0, 0, 1, 0),
        BackgroundColor3      = theme.accent,
        BackgroundTransparency= 0,
        BorderSizePixel       = 0,
        ZIndex                = 5,
    }, barTrack)
    Utils.corner(barFill, 3)
    -- Animated shimmer on the fill
    local fillGrad = Utils.create("UIGradient", {
        Color    = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.new(1,1,1)),
            ColorSequenceKeypoint.new(0.5, theme.accent),
            ColorSequenceKeypoint.new(1,   Color3.new(1,1,1)),
        }),
        Rotation = 0,
    }, barFill)
    ThemeManager.animateGradient(fillGrad, theme.gradKey)

    -- Status text
    local statusLabel = Utils.create("TextLabel", {
        Text                 = "Initializing…",
        Font                 = Enum.Font.Gotham,
        TextSize             = 11,
        TextColor3           = theme.textMuted,
        TextTransparency     = 0,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, 0, 0, 16),
        Position             = UDim2.new(0, 0, 0, 128),
        ZIndex               = 4,
    }, card)

    -- Dot spinner row
    local dotsFrame = Utils.create("Frame", {
        Size                  = UDim2.new(0, 60, 0, 12),
        Position              = UDim2.new(0.5, -30, 0, 158),
        BackgroundTransparency= 1,
        ZIndex                = 4,
    }, card)
    local dotInstances = {}
    for i = 1, 5 do
        local dot = Utils.create("Frame", {
            Size                  = UDim2.new(0, 8, 0, 8),
            Position              = UDim2.new(0, (i-1)*13, 0, 2),
            BackgroundColor3      = theme.accent,
            BackgroundTransparency= 0.5,
            BorderSizePixel       = 0,
            ZIndex                = 5,
        }, dotsFrame)
        Utils.corner(dot, 4)
        dotInstances[i] = dot
    end

    -- Animate dots in a wave
    local dotConn
    local dotIdx = 0
    dotConn = Services.RunService.Heartbeat:Connect(function(dt)
        dotIdx = (dotIdx + dt * 5)
        for i, d in ipairs(dotInstances) do
            local phase = math.sin((dotIdx - i * 0.8)) * 0.5 + 0.5
            d.BackgroundTransparency = 1 - phase * 0.9
        end
    end)

    -- Animate the entrance
    card.Size     = UDim2.new(0, cardW * 0.7, 0, cardH * 0.7)
    card.Position = UDim2.new(0.5, -(cardW*0.7)/2, 0.5, -(cardH*0.7)/2)
    card.BackgroundTransparency = 1

    Utils.tweenPlay(card, Utils.tweenInfo(0.55, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size     = UDim2.new(0, cardW, 0, cardH),
        Position = UDim2.new(0.5, -cardW/2, 0.5, -cardH/2),
        BackgroundTransparency = 0.15,
    })

    -- Animate progress bar filling, then call onComplete
    local statuses = {
        "Loading themes…",
        "Fetching scripts…",
        "Building UI…",
        "Applying animations…",
        "Almost ready…",
        "Done!",
    }
    local step     = 1
    local totalSteps = #statuses
    local stepTime = Config.Anim.loadingSpeed / totalSteps

    local function nextStep()
        if step > totalSteps then return end
        statusLabel.Text = statuses[step]
        Utils.tweenPlay(barFill,
            Utils.tweenInfo(stepTime * 0.85, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Size = UDim2.new(step / totalSteps, 0, 1, 0)}
        )
        step = step + 1
        if step <= totalSteps then
            task.delay(stepTime, nextStep)
        else
            task.delay(stepTime + 0.3, function()
                dotConn:Disconnect()
                -- Fade out the entire screen
                Utils.tweenPlay(bg, Utils.tweenInfo(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    BackgroundTransparency = 1
                })
                Utils.tweenPlay(card, Utils.tweenInfo(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                    Size     = UDim2.new(0, cardW * 0.6, 0, cardH * 0.6),
                    Position = UDim2.new(0.5, -(cardW*0.6)/2, 0.5, -(cardH*0.6)/2),
                    BackgroundTransparency = 1,
                })
                task.delay(0.5, function()
                    gui:Destroy()
                    if onComplete then onComplete() end
                end)
            end)
        end
    end

    task.delay(0.35, nextStep)
end

