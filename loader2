--  Helper: apply theme to a standard script button
local function styleButton(btn, isCategory)
    local theme = ThemeManager.get()
    btn.BackgroundColor3      = theme.bgTertiary
    btn.BackgroundTransparency = 0.1
    btn.TextColor3            = theme.text
    btn.Font                  = isCategory and Enum.Font.GothamBold or Enum.Font.Gotham
    btn.TextSize               = isCategory and 12 or 13
    btn.TextTransparency       = 0

    -- Ensure clean stroke
    local existingStroke = btn:FindFirstChildWhichIsA("UIStroke")
    if existingStroke then
        existingStroke.Color = theme.stroke
        existingStroke.Transparency = 0.4
    end
end

--  Notification system (toast)
local NotifQueue = {}
local NotifActive = 0

local function createNotification(title, subtitle, duration, kind)
    -- kind: "info"|"success"|"warn"|"error"
    local theme  = ThemeManager.get()
    kind = kind or "info"

    local accentMap = {
        info    = theme.accent,
        success = theme.success,
        warn    = theme.warning,
        error   = theme.danger,
    }
    local accent = accentMap[kind] or theme.accent

    NotifActive = NotifActive + 1
    local slot  = NotifActive

    local notifGui = Utils.create("ScreenGui", {
        Name           = "MH2_Notif_" .. slot,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn   = false,
    })
    Utils.hideGui(notifGui)

    local W, H = 240, 60
    local frame = Utils.create("Frame", {
        Size                  = UDim2.new(0, W, 0, H),
        Position              = UDim2.new(1, W + 10, 0, 20 + (slot - 1) * (H + 8)),
        BackgroundColor3      = theme.bgSecondary,
        BackgroundTransparency= 0.08,
        BorderSizePixel       = 0,
        ZIndex                = 20,
    }, notifGui)
    Utils.corner(frame, 10)
    local fStroke = Utils.stroke(frame, accent, 1.2, 0.4)

    -- Coloured left bar
    local bar = Utils.create("Frame", {
        Size             = UDim2.new(0, 4, 1, -12),
        Position         = UDim2.new(0, 0, 0, 6),
        BackgroundColor3 = accent,
        BorderSizePixel  = 0,
        ZIndex           = 21,
    }, frame)
    Utils.corner(bar, 2)

    Utils.create("TextLabel", {
        Text                 = title,
        Font                 = Enum.Font.GothamBold,
        TextSize             = 13,
        TextColor3           = theme.text,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, -14, 0, 22),
        Position             = UDim2.new(0, 10, 0, 6),
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 21,
    }, frame)

    Utils.create("TextLabel", {
        Text                 = subtitle,
        Font                 = Enum.Font.Gotham,
        TextSize             = 11,
        TextColor3           = theme.textMuted,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(1, -14, 0, 20),
        Position             = UDim2.new(0, 10, 0, 30),
        TextXAlignment       = Enum.TextXAlignment.Left,
        TextWrapped          = true,
        ZIndex               = 21,
    }, frame)

    -- Slide in
    local slideIn  = Utils.tweenInfo(0.38, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local slideOut = Utils.tweenInfo(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    Utils.tweenPlay(frame, slideIn, {Position = UDim2.new(1, -(W + 14), 0, 20 + (slot - 1) * (H + 8))})

    task.delay(duration or 3.5, function()
        Utils.tweenPlay(frame, slideOut, {Position = UDim2.new(1, W + 10, 0, 20 + (slot - 1) * (H + 8))})
        task.delay(0.32, function()
            notifGui:Destroy()
            NotifActive = math.max(0, NotifActive - 1)
        end)
    end)
end

-- ── Build the main frame ─────────────────────────────────
function UI.build()
    local theme = ThemeManager.get()
    local cfg   = Config.UI
    local W, H  = cfg.width, cfg.height
    if IsMobile then
        W = math.floor(W * Config.Mobile.scaleFactor)
        H = math.floor(H * Config.Mobile.scaleFactor)
    end

    -- Root ScreenGui
    local screenGui = Utils.create("ScreenGui", {
        Name            = "MH2_Main",
        ZIndexBehavior  = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset  = false,
        ResetOnSpawn    = false,
    })
    Utils.hideGui(screenGui)
    UI.screenGui = screenGui

    -- UIScale for mobile
    if IsMobile then
        Utils.create("UIScale", {Scale = 0.92}, screenGui)
    end

    -- ── Main window frame ────────────────────────────────
    local mainFrame = Utils.create("Frame", {
        Name                  = "MainWindow",
        Size                  = UDim2.new(0, 0, 0, H),   -- animates open from 0 width
        AnchorPoint           = Vector2.new(0.5, 0.5),
        Position              = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundColor3      = theme.bg,
        BackgroundTransparency= 0.06,
        BorderSizePixel       = 0,
        ZIndex                = cfg.zIndex,
    }, screenGui)
    Utils.corner(mainFrame, cfg.cornerRadius)
    local mainStroke = Utils.stroke(mainFrame, theme.stroke, 1.5, 0.3)
    UI.mainFrame  = mainFrame
    UI.mainStroke = mainStroke

    -- Animated gradient border
    local borderGrad = Utils.create("UIGradient", {Rotation = 45}, mainStroke)
    if State.gradientEnabled then
        ThemeManager.animateGradient(borderGrad, theme.gradKey)
    end

    -- ── Header bar ──────────────────────────────────────
    local header = Utils.create("Frame", {
        Name                  = "Header",
        Size                  = UDim2.new(1, 0, 0, cfg.headerHeight),
        BackgroundColor3      = theme.bgSecondary,
        BackgroundTransparency= 0.05,
        BorderSizePixel       = 0,
        ZIndex                = cfg.zIndex + 1,
    }, mainFrame)
    Utils.corner(header, cfg.cornerRadius)
    -- Cover bottom half of header's rounded corners
    Utils.create("Frame", {
        Size             = UDim2.new(1, 0, 0, cfg.cornerRadius),
        Position         = UDim2.new(0, 0, 1, -cfg.cornerRadius),
        BackgroundColor3 = theme.bgSecondary,
        BackgroundTransparency = 0.05,
        BorderSizePixel  = 0,
        ZIndex           = cfg.zIndex + 1,
    }, header)
    UI.header = header

    -- Header gradient shimmer
    local hGrad = Utils.create("UIGradient", {
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0,   0.85),
            NumberSequenceKeypoint.new(0.5, 0.65),
            NumberSequenceKeypoint.new(1,   0.85),
        }),
        Rotation = 0,
    }, header)
    -- Animate offset for shimmer
    do
        local t2 = 0
        Services.RunService.Heartbeat:Connect(function(dt)
            if not header.Parent then return end
            t2 = (t2 + dt * 0.4) % 1
            hGrad.Offset = Vector2.new(t2 * 2 - 1, 0)
        end)
    end

    -- Icon + title
    Utils.create("ImageLabel", {
        Image                = "rbxassetid://7072717762",
        Size                 = UDim2.new(0, 20, 0, 20),
        Position             = UDim2.new(0, 10, 0.5, -10),
        BackgroundTransparency = 1,
        ZIndex               = cfg.zIndex + 2,
    }, header)

    Utils.create("TextLabel", {
        Text                 = "MEGAHACK  V2",
        Font                 = Enum.Font.GothamBlack,
        TextSize             = 15,
        TextColor3           = theme.text,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(0.6, 0, 1, 0),
        Position             = UDim2.new(0, 36, 0, 0),
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = cfg.zIndex + 2,
    }, header)

    -- Game name (right side of header)
    local gameName = Utils.create("TextLabel", {
        Text                 = "…",
        Font                 = Enum.Font.Gotham,
        TextSize             = 10,
        TextColor3           = theme.textMuted,
        BackgroundTransparency = 1,
        Size                 = UDim2.new(0.35, 0, 1, 0),
        Position             = UDim2.new(0.6, 0, 0, 0),
        TextXAlignment       = Enum.TextXAlignment.Right,
        ZIndex               = cfg.zIndex + 2,
    }, header)
    task.spawn(function()
        local ok, info = pcall(function()
            return Services.MarketplaceService:GetProductInfo(game.PlaceId)
        end)
        if ok and info then
            gameName.Text = info.Name
        end
    end)

    -- Close button
    local closeBtn = Utils.create("ImageButton", {
        Image                = "rbxassetid://14397748477",
        Size                 = UDim2.new(0, 18, 0, 18),
        Position             = UDim2.new(1, -26, 0.5, -9),
        BackgroundTransparency = 1,
        ZIndex               = cfg.zIndex + 3,
    }, header)
    UI.closeBtn = closeBtn

    -- ── Divider below header ─────────────────────────────
    local divider = Utils.create("Frame", {
        Size             = UDim2.new(1, -20, 0, 1),
        Position         = UDim2.new(0, 10, 0, cfg.headerHeight),
        BackgroundColor3 = theme.stroke,
        BackgroundTransparency = 0.5,
        BorderSizePixel  = 0,
        ZIndex           = cfg.zIndex,
    }, mainFrame)

    -- ── Sidebar ──────────────────────────────────────────
    local sideW    = cfg.sidebarWidth
    local contentY = cfg.headerHeight + 2
    local contentH = H - contentY

    local sidebar = Utils.create("ScrollingFrame", {
        Name                  = "Sidebar",
        Size                  = UDim2.new(0, sideW, 0, contentH),
        Position              = UDim2.new(0, 0, 0, contentY),
        BackgroundTransparency= 1,
        BorderSizePixel       = 0,
        CanvasSize            = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness    = cfg.scrollBarW,
        ScrollBarImageColor3  = theme.accent,
        ZIndex                = cfg.zIndex,
    }, mainFrame)
    UI.sidebar = sidebar

    local sideLayout = Utils.listLayout(sidebar, 4)
    Utils.padding(sidebar, 6)
    Utils.autoCanvasSize(sidebar, sideLayout)

    -- Sidebar divider line
    Utils.create("Frame", {
        Size             = UDim2.new(0, 1, 0, contentH - 12),
        Position         = UDim2.new(0, sideW, 0, contentY + 6),
        BackgroundColor3 = theme.stroke,
        BackgroundTransparency = 0.5,
        BorderSizePixel  = 0,
        ZIndex           = cfg.zIndex,
    }, mainFrame)

    -- ── Content panel ────────────────────────────────────
    local contentX = sideW + 4
    local contentW = W - contentX - 6

    local contentScroll = Utils.create("ScrollingFrame", {
        Name                  = "ContentPanel",
        Size                  = UDim2.new(0, contentW, 0, contentH),
        Position              = UDim2.new(0, contentX, 0, contentY),
        BackgroundTransparency= 1,
        BorderSizePixel       = 0,
        CanvasSize            = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness    = cfg.scrollBarW,
        ScrollBarImageColor3  = theme.accent,
        ZIndex                = cfg.zIndex,
    }, mainFrame)
    UI.contentScroll  = contentScroll
    UI.contentWidth   = contentW

    local contentLayout = Utils.listLayout(contentScroll, 5)
    Utils.padding(contentScroll, 6, 4, 8, 8, 6)
    Utils.autoCanvasSize(contentScroll, contentLayout)

    -- ── Reopen floating button ───────────────────────────
    local reopenBtn = Utils.create("ImageButton", {
        Image                 = "rbxassetid://74283928898866",
        Size                  = IsMobile
                                    and UDim2.new(0, 60, 0, 60)
                                    or  UDim2.new(0, 46, 0, 46),
        Position              = UDim2.new(0.5, -23, 0.92, -23),
        BackgroundColor3      = theme.bgSecondary,
        BackgroundTransparency= 0.1,
        ImageTransparency     = 0.15,
        Visible               = false,
        ZIndex                = cfg.zIndex + 5,
    }, screenGui)
    Utils.corner(reopenBtn, 50)
    Utils.stroke(reopenBtn, theme.accent, 1.5, 0.3)
    UI.reopenBtn = reopenBtn

    -- ── Wire up close / reopen ───────────────────────────
    closeBtn.MouseButton1Click:Connect(function()
        local ti = Utils.tweenInfo(Config.Anim.closeDuration, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
        Utils.tweenPlay(mainFrame, ti, {Size = UDim2.new(0, 0, 0, H), BackgroundTransparency = 1})
        task.delay(Config.Anim.closeDuration, function()
            mainFrame.Visible = false
            reopenBtn.Visible = true
        end)
    end)

    reopenBtn.MouseButton1Click:Connect(function()
        mainFrame.Visible = true
        mainFrame.BackgroundTransparency = 1
        mainFrame.Size = UDim2.new(0, 0, 0, H)
        local ti = Utils.tweenInfo(Config.Anim.openDuration, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        Utils.tweenPlay(mainFrame, ti, {Size = UDim2.new(0, W, 0, H), BackgroundTransparency = 0.06})
        reopenBtn.Visible = false
    end)

    -- ── Draggable header ─────────────────────────────────
    if not State.locked then
        local dragging, dragInput, mousePos, framePos
        header.InputBegan:Connect(function(input)
            if State.locked then return end
            local isTouch = input.UserInputType == Enum.UserInputType.Touch
            local isMouse = input.UserInputType == Enum.UserInputType.MouseButton1
            if isTouch or isMouse then
                dragging  = true
                mousePos  = input.Position
                framePos  = mainFrame.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)
        header.InputChanged:Connect(function(input)
            local isTouch = input.UserInputType == Enum.UserInputType.Touch
            local isMouse = input.UserInputType == Enum.UserInputType.MouseMovement
            if isTouch or isMouse then dragInput = input end
        end)
        Services.UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta   = input.Position - mousePos
                mainFrame.Position = UDim2.new(
                    framePos.X.Scale,
                    framePos.X.Offset + delta.X,
                    framePos.Y.Scale,
                    framePos.Y.Offset + delta.Y
                )
            end
        end)
    end

    -- ── Register theme change listener ───────────────────
    ThemeManager.onChange(function(t)
        mainFrame.BackgroundColor3      = t.bg
        header.BackgroundColor3         = t.bgSecondary
        mainStroke.Color                = t.stroke
        sidebar.ScrollBarImageColor3    = t.accent
        contentScroll.ScrollBarImageColor3 = t.accent
        divider.BackgroundColor3        = t.stroke
        -- Rebuild stroke gradient with new theme
        ThemeManager.stopGradients()
        if State.gradientEnabled then
            ThemeManager.animateGradient(borderGrad, t.gradKey)
        end
        -- Re-apply all category buttons
        UI.refreshSidebar()
    end)

    -- ── Populate sidebar ─────────────────────────────────
    UI.sideButtons = {}
    UI.buildSidebar()

    -- ── Opening animation ────────────────────────────────
    task.defer(function()
        local ti = Utils.tweenInfo(Config.Anim.openDuration, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        Utils.tweenPlay(mainFrame, ti, {Size = UDim2.new(0, W, 0, H), BackgroundTransparency = 0.06})
    end)
end

