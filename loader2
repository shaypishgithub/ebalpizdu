local function MakeScriptCard(name, fn, tag)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1,0,0,CARD_H); card.BackgroundColor3 = T("Surface")
    card.BorderSizePixel = 0; card.ZIndex = 12; card.Parent = ScriptScroll
