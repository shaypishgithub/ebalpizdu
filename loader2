local activeSideBtn = nil

local function createSideBtn(label, icon, callback)
    local btn = New("TextButton", {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Theme.bg3,
        BackgroundTransparency = 1,
        Text = "",
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = sideScroll,
    })
    Corner(8, btn)

    local iconLbl = New("TextLabel", {
        Text = icon,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = Theme.textMuted,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(0, 8, 0, 0),
        ZIndex = 5,
        Parent = btn,
    })
    local textLbl = New("TextLabel", {
        Text = label,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Theme.textSecondary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -34, 1, 0),
        Position = UDim2.new(0, 30, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 5,
        Parent = btn,
    })
    local activeBar = New("Frame", {
        Size = UDim2.new(0, 3, 0.6, 0),
        Position = UDim2.new(0, 0, 0.2, 0),
        BackgroundColor3 = Theme.accent,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = btn,
    })
    Corner(2, activeBar)

    local function setActive(on)
        if on then
            tween(btn,       {BackgroundTransparency = 0.5})
            tween(iconLbl,   {TextColor3 = Theme.accent})
            tween(textLbl,   {TextColor3 = Theme.textPrimary})
            tween(activeBar, {BackgroundTransparency = 0})
        else
            tween(btn,       {BackgroundTransparency = 1})
            tween(iconLbl,   {TextColor3 = Theme.textMuted})
            tween(textLbl,   {TextColor3 = Theme.textSecondary})
            tween(activeBar, {BackgroundTransparency = 1})
        end
    end

    btn.MouseEnter:Connect(function()
        if activeSideBtn ~= btn then
            tween(btn, {BackgroundTransparency = 0.75})
            tween(textLbl, {TextColor3 = Theme.textPrimary})
        end
    end)
    btn.MouseLeave:Connect(function()
        if activeSideBtn ~= btn then
            tween(btn, {BackgroundTransparency = 1})
            tween(textLbl, {TextColor3 = Theme.textSecondary})
        end
    end)
    btn.MouseButton1Click:Connect(function()
        if activeSideBtn and activeSideBtn ~= btn then
            activeSideBtn._setActive(false)
        end
        activeSideBtn = btn
        setActive(true)
        callback()
    end)
    btn._setActive = setActive

    return btn
end

