local function clearContent()
    local scroll = UI.contentScroll
    for _, c in ipairs(scroll:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
            c:Destroy()
        end
    end
    scroll.CanvasPosition = Vector2.new(0, 0)
end

local function makeButton(text, parent, callback, accent)
    local theme = ThemeManager.get()
    local H_    = IsMobile and Config.Mobile.buttonHeight or Config.UI.buttonHeight

    local btn = Utils.create("TextButton", {
        Text                   = text,
        Font                   = Enum.Font.Gotham,
        TextSize               = 12,
        TextColor3             = theme.text,
        BackgroundColor3       = accent and theme.accent or theme.bgTertiary,
        BackgroundTransparency = accent and 0.1 or 0.15,
        BorderSizePixel        = 0,
        Size                   = UDim2.new(1, 0, 0, H_),
        AutoButtonColor        = false,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = Config.UI.zIndex + 1,
    }, parent)
    Utils.corner(btn, Config.UI.buttonCorner)
    Utils.padding(btn, 0, 0, 0, 0, 10)
    Utils.stroke(btn, accent and theme.accent or theme.stroke, 1, 0.5)

    btn.MouseEnter:Connect(function()
        Utils.tweenPlay(btn, Utils.tweenInfo(Config.Anim.hoverDuration), {
            BackgroundTransparency = accent and 0.0 or 0.05,
        })
    end)
    btn.MouseLeave:Connect(function()
        Utils.tweenPlay(btn, Utils.tweenInfo(Config.Anim.hoverDuration), {
            BackgroundTransparency = accent and 0.1 or 0.15,
        })
    end)
    btn.MouseButton1Click:Connect(function()
        Utils.tweenPlay(btn, Utils.tweenInfo(0.07), {Size = UDim2.new(1, -4, 0, H_ - 4)})
        task.delay(0.08, function()
            Utils.tweenPlay(btn, Utils.tweenInfo(0.12, Enum.EasingStyle.Back), {
                Size = UDim2.new(1, 0, 0, H_)
            })
        end)
        if callback then pcall(callback) end
    end)

    return btn
end

