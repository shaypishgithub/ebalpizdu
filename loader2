--  MODULE 14 · THEME CHANGE LISTENER
--  Applies new colors to all persistent UI elements without rebuilding them.
-- ═══════════════════════════════════════════════════════════════════════════
ThemeManager.onThemeChanged(function(t)
    -- Window
    mainWin:FindFirstChildOfClass("UIStroke").Color = t.border
    header.BackgroundColor3       = t.bgSecondary
    sidebar.BackgroundColor3      = t.bgSecondary

    -- Accent line
    accentLine.BackgroundColor3   = t.accent1
    local alg = accentLine:FindFirstChildOfClass("UIGradient")
    if alg then
        alg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, t.accent1),
            ColorSequenceKeypoint.new(1, t.accent2),
        })
    end

    -- Title gradient
    local tlg = titleLbl:FindFirstChildOfClass("UIGradient")
    if tlg then
        tlg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, t.accent1),
            ColorSequenceKeypoint.new(1, t.accent2),
        })
    end
    titleLbl.TextColor3 = t.text

    -- Search
    searchCont.BackgroundColor3  = t.surface
    searchBox.TextColor3         = t.text
    searchBox.PlaceholderColor3  = t.textDim
    scriptScroll.ScrollBarImageColor3 = t.border

    -- Reopen button
    reopenBtn.BackgroundColor3   = t.surface
    local rs = reopenBtn:FindFirstChildOfClass("UIStroke")
    if rs then rs.Color = t.accent1 end

    -- Version badge
    local vb = vBadge:FindFirstChildOfClass("UIStroke")
    if vb then vb.Color = t.accent1 end
    local vbl = vBadge:FindFirstChildOfClass("TextLabel")
    if vbl then vbl.TextColor3 = t.accent1 end
end)

