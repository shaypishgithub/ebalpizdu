-- Toggle button
local function toggleBtn(label, initial, onChange)
    local state = initial or false
    local btn = New("TextButton", {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Theme.bg3,
        BackgroundTransparency = 0.4,
        Text = "",
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = contentScroll,
    })
    Corner(8, btn)
    local stroke = Stroke(1, Theme.border, 0.5, btn)

    local lbl = New("TextLabel", {
        Text = label,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = Theme.textPrimary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -56, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 5,
        Parent = btn,
    })

    -- pill toggle
    local track = New("Frame", {
        Size = UDim2.new(0, 36, 0, 18),
        Position = UDim2.new(1, -46, 0.5, -9),
        BackgroundColor3 = state and Theme.accent or Theme.bg0,
        BackgroundTransparency = 0.2,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = btn,
    })
    Corner(9, track)
    local thumb = New("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(0, state and 21 or 3, 0.5, -6),
        BackgroundColor3 = Theme.textPrimary,
        BorderSizePixel = 0,
        ZIndex = 6,
        Parent = track,
    })
    Corner(6, thumb)

    local function refresh()
        tween(track, {BackgroundColor3 = state and Theme.accent or Theme.bg0})
        tween(thumb, {Position = UDim2.new(0, state and 21 or 3, 0.5, -6)})
        tween(stroke, {Color = state and Theme.accent or Theme.border})
    end

    btn.MouseButton1Click:Connect(function()
        state = not state
        refresh()
        if onChange then onChange(state) end
    end)
    refresh()
    return btn, function() return state end
end

